---
import '../styles/global.css';
import ScrollProgress from '../components/motion/ScrollProgress';
import ScrollToTop from '../components/ScrollToTop';
import ClientRouter from 'astro/components/ClientRouter.astro';

interface Props {
  title?: string;
}

const { title = "HYEBIN.DEV" } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="AI Service Planner & Product Engineer. I design and build AI-powered financial products." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Sans+KR:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/assets/favicon.png" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="antialiased">
    <ScrollProgress variant="bar" className="text-[var(--color-accent)]" client:load />
    <ScrollToTop client:visible />
    <slot />
    <!-- Light theme only -->
  </body>
</html>
