---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer';
import { resume, boldToHtml } from '../../../data/resume';

const lang = 'ko';
const strongClass = 'text-[var(--color-text)]';
// Normalize BASE_URL to avoid `/portfolioko/...` when base has no trailing slash
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const pdfUrl = `${baseUrl}/${lang}/resume-pdf/`;
---

<Layout title="우혜빈 이력서">
  <Navbar lang={lang} client:load />

  <main class="pt-32 pb-24 px-6 md:px-12 max-w-7xl mx-auto break-keep">

    <!-- Header: 2-column (소개 + 연락처) -->
    <header class="mb-20 flex flex-col md:flex-row justify-between items-end gap-8">
      <div class="max-w-2xl">
        <div class="flex items-baseline gap-3 mb-4">
          <span class="text-2xl md:text-3xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">{resume.name.ko}</span>
          <span class="text-lg md:text-xl font-medium text-[var(--color-text-faint)]" style="font-family: var(--font-display);">{resume.name.en}</span>
        </div>
        <p class="text-xs font-bold text-[var(--color-accent)] tracking-[0.2em] uppercase mb-4 block">{resume.role}</p>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight mb-6 leading-[1.2] text-[var(--color-text)] break-keep" style="font-family: var(--font-display);">
          {resume.headline.lead}<br/>
          <span class="text-[var(--color-accent)]">{resume.headline.accent}</span>
        </h1>
        <p class="text-base md:text-lg text-[var(--color-text-muted)] leading-relaxed break-keep mb-4" set:html={boldToHtml(resume.summary.body.split('현재는')[0].trim(), strongClass)} />
        <p class="text-base md:text-lg text-[var(--color-text-muted)] leading-relaxed break-keep">
          현재는 퀀트 리서치팀이 매일 쓰는 대시보드를 처음부터 다시 설계하고 있으며, 화면 설계부터 AI 코딩 도구를 활용한 구현까지 직접 수행합니다.
        </p>
      </div>
      <div class="flex flex-col gap-3 items-start md:items-end w-full md:w-auto">
        <a href={`mailto:${resume.contact.email}`} class="flex items-center gap-3 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <span class="text-sm font-medium">{resume.contact.email}</span>
        </a>
        {resume.contact.linkedinUrl && (
          <a href={resume.contact.linkedinUrl} target="_blank" class="flex items-center gap-3 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
            <span class="text-sm font-medium">LinkedIn</span>
          </a>
        )}
        <a href={resume.contact.githubUrl} target="_blank" class="flex items-center gap-3 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>
          <span class="text-sm font-medium">GitHub</span>
        </a>
        {resume.contact.location && (
          <div class="flex items-center gap-3 text-[var(--color-text-muted)]">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="text-sm font-medium">{resume.contact.location}</span>
          </div>
        )}
        <a href={pdfUrl} target="_blank" rel="noopener"
           class="mt-3 inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-[var(--color-accent)] text-[var(--color-on-accent)] text-sm font-bold hover:opacity-90 transition-all shadow-ambient-sm">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
          PDF 다운로드
        </a>
      </div>
    </header>

    <!-- 2-column: 8/12 + 4/12 -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">

      <!-- Left: Experience Timeline -->
      <div class="lg:col-span-8">
        <h2 class="text-3xl font-bold tracking-tight mb-12 flex items-center gap-4 text-[var(--color-text)]" style="font-family: var(--font-display);">
          경력
          <span class="h-[2px] flex-grow bg-[var(--color-bg-emphasis)]"></span>
        </h2>

        <div class="relative pl-8">
          <!-- Timeline vertical line -->
          <div class="absolute left-0 top-2 bottom-0 w-[2px] bg-[var(--color-bg-emphasis)]"></div>

          {resume.jobs.map((job) => (
            <div class="mb-16 relative">
              <div class="absolute -left-[37px] top-1.5 w-4 h-4 rounded-full border-4 border-[var(--color-bg)] bg-[var(--color-accent)]"></div>
              <div class="flex flex-col md:flex-row justify-between items-start mb-5 gap-2">
                <div>
                  <h3 class="text-2xl font-bold text-[var(--color-text)]">
                    {job.department ? `${job.company} · ${job.department}` : job.company}
                  </h3>
                  {job.org && <p class="text-sm text-[var(--color-text-muted)] mt-1">{job.org}</p>}
                </div>
                <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] bg-[var(--color-bg-detail)] px-3 py-1 rounded-full">{job.period}</span>
              </div>

              {job.projects.map((project, pIdx) => (
                <div class={pIdx < job.projects.length - 1 ? 'mb-7' : ''}>
                  <p class="font-bold text-[var(--color-text)] mb-3 text-[15px]" style="font-family: var(--font-display);">
                    {project.title}
                  </p>
                  {project.description && (
                    <p class="text-sm text-[var(--color-text-muted)] mb-3 italic">
                      {project.description}
                    </p>
                  )}
                  <ul class="space-y-2 text-[13.5px] text-[var(--color-text-muted)] leading-[1.75]">
                    {project.bullets.map((bullet) => (
                      <li class="flex gap-2.5">
                        <span class="text-[var(--color-accent)] mt-[9px] flex-shrink-0 text-[6px] leading-none">●</span>
                        <span set:html={boldToHtml(bullet, strongClass)} />
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          ))}

          <!-- 사이드 프로젝트 -->
          <div class="relative">
            <div class="absolute -left-[37px] top-1.5 w-4 h-4 rounded-full border-4 border-[var(--color-bg)] bg-[var(--color-accent)]"></div>
            <div class="flex flex-col md:flex-row justify-between items-start mb-4 gap-2">
              <div>
                <h3 class="text-2xl font-bold text-[var(--color-text)]">{resume.sideProject.title} · {resume.sideProject.sub}</h3>
                <p class="text-sm text-[var(--color-text-muted)] mt-1">사이드 프로젝트 · {resume.sideProject.role}</p>
              </div>
            </div>
            <p class="text-[var(--color-text-muted)] leading-relaxed italic mb-4 pl-4 border-l-2 border-[var(--color-accent)]">
              "{resume.sideProject.quote}"
            </p>
            <ul class="space-y-2 text-[13.5px] text-[var(--color-text-muted)] leading-[1.75]">
              {resume.sideProject.bullets.map((bullet) => (
                <li class="flex gap-2.5">
                  <span class="text-[var(--color-accent)] mt-[9px] flex-shrink-0 text-[6px] leading-none">●</span>
                  <span set:html={boldToHtml(bullet, strongClass)} />
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- Right: Sidebar -->
      <div class="lg:col-span-4 space-y-12">

        <!-- 학력 -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            학력
          </h2>
          <div class="space-y-6">
            {resume.education.map((edu) => (
              <div class="bg-[var(--color-bg-card)] p-6 rounded-xl">
                <h4 class="font-bold text-lg mb-1 text-[var(--color-text)]">{edu.name}</h4>
                <p class="text-[var(--color-accent)] font-medium mb-2">{edu.degree}</p>
                <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-faint)]">{edu.period}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- 역량 -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            역량
          </h2>
          <div class="space-y-4">
            {resume.skills.map((row) => (
              <div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-text-faint)] mb-2">{row.label}</p>
                <div class="flex flex-wrap gap-2">
                  {row.items.split(' · ').slice(0, 3).map((skill) => (
                    <span class="px-3 py-1.5 bg-[var(--color-secondary-container)] text-[var(--color-on-secondary-container)] rounded-full text-xs font-semibold">{skill}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Stack & Tools -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            도구
          </h2>
          <div class="grid grid-cols-2 gap-4">
            <div class="flex items-center gap-3 p-3 bg-[var(--color-bg-secondary)] rounded-lg">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              <span class="text-sm font-bold text-[var(--color-text)]">Claude Code</span>
            </div>
            <div class="flex items-center gap-3 p-3 bg-[var(--color-bg-secondary)] rounded-lg">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
              <span class="text-sm font-bold text-[var(--color-text)]">ClickUp</span>
            </div>
            <div class="flex items-center gap-3 p-3 bg-[var(--color-bg-secondary)] rounded-lg">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
              <span class="text-sm font-bold text-[var(--color-text)]">Slack</span>
            </div>
            <div class="flex items-center gap-3 p-3 bg-[var(--color-bg-secondary)] rounded-lg">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>
              <span class="text-sm font-bold text-[var(--color-text)]">GitHub</span>
            </div>
          </div>
        </section>

        <!-- 자격증 -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            자격증
          </h2>
          <div class="space-y-3">
            {resume.certifications.map((cert) => (
              <div class="flex items-baseline justify-between">
                <p class="font-bold text-sm text-[var(--color-text)]">{cert.name}</p>
                <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-faint)]">{cert.date}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- 언어 -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            언어
          </h2>
          <div class="space-y-2">
            <p class="font-bold text-[var(--color-text)]">{resume.language.primary}</p>
            {resume.language.note && <p class="text-sm text-[var(--color-text-faint)]">{resume.language.note}</p>}
          </div>
        </section>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
