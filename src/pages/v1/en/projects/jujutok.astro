---
import Layout from '../../../../layouts/Layout.astro';
import Navbar from '../../../../components/Navbar';
import ProjectDetail from '../../../../components/ProjectDetail';
import Footer from '../../../../components/Footer';
import BottomNav from '../../../../components/BottomNav';
import { jujutok } from '../../../../data/projects';

const lang = 'en';
const project = jujutok[lang];
---

<Layout title={`${project.title}${project.titleAccent} — HYEBIN.DEV`}>
  <Navbar lang={lang} client:load />
  <main>
    <ProjectDetail project={project} lang={lang} client:load />
  </main>
  <Footer />
  <BottomNav lang={lang} client:load />
</Layout>
