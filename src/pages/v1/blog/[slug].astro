---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer';
import FloatingTOC from '../../../components/blog/FloatingTOC';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const base = import.meta.env.BASE_URL;

// Series navigation
const allPosts = await getCollection('blog');
const seriesPosts = post.data.series
  ? allPosts
      .filter((p) => p.data.series === post.data.series)
      .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0))
  : [];

const currentSeriesIndex = seriesPosts.findIndex((p) => p.id === post.id);
const prevSeriesPost = currentSeriesIndex > 0 ? seriesPosts[currentSeriesIndex - 1] : null;
const nextSeriesPost = currentSeriesIndex < seriesPosts.length - 1 ? seriesPosts[currentSeriesIndex + 1] : null;

const seriesLabels: Record<string, string> = {
  'quant-platform': 'Quant Research Platform',
  'jujutok': 'JujuTok',
};
---

<Layout title={`${post.data.title} — HYEBIN.DEV`}>
  <Navbar client:load />

  <main class="px-6 pt-32 pb-20">
    <FloatingTOC client:load />
    <div class="mx-auto max-w-7xl">
      <a
        href={`${base}blog/`}
        class="mb-8 inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text)]"
      >
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Back to Blog
      </a>

      <header class="mb-12">
        <div class="mb-4 flex items-center gap-3">
          <span class="rounded-full bg-[var(--color-accent)]/10 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-[var(--color-accent-light)]">
            {post.data.category}
          </span>
          <span class="font-mono text-xs text-[var(--color-text-muted)]">
            {post.data.date.toISOString().slice(0, 10)}
          </span>
        </div>
        <h1 class="mb-4 text-3xl font-bold leading-snug sm:text-4xl" style="font-family: var(--font-display);">
          {post.data.title}
        </h1>
        <p class="text-[var(--color-text-muted)]">
          {post.data.description}
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          {post.data.tags.map((tag: string) => (
            <span class="rounded-full border border-[var(--color-border)] px-2.5 py-0.5 font-mono text-[10px] text-[var(--color-text-muted)]">
              {tag}
            </span>
          ))}
        </div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <article class="lg:col-span-8">
      <div class="prose-custom" style="max-width: 66ch;">
        <Content />
      </div>

      {seriesPosts.length > 1 && (
        <div class="mt-16 border-t border-[var(--color-border)] pt-10">
          <div class="mb-1 flex items-center justify-between">
            <h3 class="text-sm font-semibold uppercase tracking-[0.15em] text-[var(--color-text-muted)]">Series</h3>
            <span class="font-mono text-[10px] text-[var(--color-accent)]">{currentSeriesIndex + 1}/{seriesPosts.length}</span>
          </div>
          <p class="mb-3 text-xs text-[var(--color-text-muted)]">
            {seriesLabels[post.data.series!] || post.data.series}
          </p>
          <div class="mb-4 h-0.5 w-full overflow-hidden rounded-full bg-[var(--color-border)]">
            <div class="h-full rounded-full bg-[var(--color-accent)]" style={`width: ${((currentSeriesIndex + 1) / seriesPosts.length) * 100}%`} />
          </div>
          <div class="flex flex-col gap-1.5">
            {seriesPosts.map((sp, i) => {
              const isCurrent = sp.id === post.id;
              return (
                <a
                  href={isCurrent ? undefined : `${base}blog/${sp.id}/`}
                  class:list={[
                    'group flex items-center gap-3 rounded-lg px-4 py-3 text-sm transition-all',
                    isCurrent
                      ? 'bg-[var(--color-accent)]/10 text-[var(--color-accent-light)] font-medium'
                      : 'text-[var(--color-text-muted)] hover:bg-[var(--color-bg-card)] hover:text-[var(--color-text)]',
                  ]}
                >
                  <span class:list={[
                    'flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full font-mono text-[10px] font-bold',
                    isCurrent
                      ? 'bg-[var(--color-accent)] text-white'
                      : 'border border-[var(--color-border)] text-[var(--color-text-muted)]',
                  ]}>
                    {i + 1}
                  </span>
                  <span class="leading-snug">{sp.data.title}</span>
                </a>
              );
            })}
          </div>
          <!-- C6: prev/next stepper -->
          <div class="mt-4 flex gap-2">
            {prevSeriesPost ? (
              <a href={`${base}blog/${prevSeriesPost.id}/`} class="flex flex-1 items-center gap-1.5 rounded-lg border border-[var(--color-border)] px-3 py-2 text-xs text-[var(--color-text-muted)] transition-all hover:border-[var(--color-accent)]/40 hover:text-[var(--color-accent)]">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
                <span class="truncate">Prev</span>
              </a>
            ) : <span class="flex-1" />}
            {nextSeriesPost ? (
              <a href={`${base}blog/${nextSeriesPost.id}/`} class="flex flex-1 items-center justify-end gap-1.5 rounded-lg border border-[var(--color-border)] px-3 py-2 text-xs text-[var(--color-text-muted)] transition-all hover:border-[var(--color-accent)]/40 hover:text-[var(--color-accent)]">
                <span class="truncate">Next</span>
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
              </a>
            ) : <span class="flex-1" />}
          </div>
        </div>
      )}

      {post.data.relatedLinks.length > 0 && (
        <div class="mt-16 border-t border-[var(--color-border)] pt-10">
          <h3 class="mb-6 text-sm font-semibold uppercase tracking-[0.15em] text-[var(--color-text-muted)]">
            함께 보면 좋은 글
          </h3>
          <div class="flex flex-col gap-3">
            {post.data.relatedLinks.map((link: { label: string; url: string; type: string }) => (
              <a
                href={link.url}
                target={link.type === 'github' || link.type === 'linkedin' ? '_blank' : undefined}
                rel={link.type === 'github' || link.type === 'linkedin' ? 'noopener noreferrer' : undefined}
                class="group flex items-center gap-3 rounded-lg border border-[var(--color-border)] px-5 py-4 transition-all hover:border-[var(--color-accent-light)] hover:bg-[var(--color-bg-card)]"
              >
                <span class="flex h-8 w-8 items-center justify-center rounded-full bg-[var(--color-accent)]/10 text-sm text-[var(--color-accent-light)]">
                  {link.type === 'project' ? '📂' : link.type === 'blog' ? '📝' : link.type === 'linkedin' ? '💼' : '💻'}
                </span>
                <div class="flex-1">
                  <span class="text-sm font-medium text-[var(--color-text)] transition-colors group-hover:text-[var(--color-accent-light)]">
                    {link.label}
                  </span>
                  <span class="ml-2 font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-muted)]">
                    {link.type}
                  </span>
                </div>
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-text-muted)] transition-colors group-hover:text-[var(--color-accent-light)]">
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            ))}
          </div>
        </div>
      )}
    </article>

      <!-- Sidebar -->
      <aside class="lg:col-span-4 hidden lg:block">
        <div class="sticky top-32">
          {seriesPosts.length > 1 && (
            <div class="pb-8 border-b border-[var(--color-border)]">
              <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-[var(--color-text-faint)] mb-3">SERIES</p>
              <div class="flex items-baseline justify-between mb-1">
                <h3 class="text-sm font-bold text-[var(--color-text)]" style="font-family: var(--font-display);">
                  {seriesLabels[post.data.series!] || post.data.series}
                </h3>
                <span class="font-mono text-[10px] text-[var(--color-text-faint)] ml-2 flex-shrink-0">
                  {String(currentSeriesIndex + 1).padStart(2, '0')} / {String(seriesPosts.length).padStart(2, '0')}
                </span>
              </div>
              <!-- progress line -->
              <div class="mb-4 h-px w-full bg-[var(--color-border)]">
                <div class="h-full bg-[var(--color-accent)] transition-none" style={`width: ${((currentSeriesIndex + 1) / seriesPosts.length) * 100}%`} />
              </div>
              <div class="flex flex-col">
                {seriesPosts.map((sp, i) => {
                  const isCurrent = sp.id === post.id;
                  return (
                    <a
                      href={isCurrent ? undefined : `${base}blog/${sp.id}/`}
                      class:list={[
                        'group flex items-start gap-2.5 py-2 text-xs transition-colors',
                        isCurrent
                          ? 'text-[var(--color-accent)] font-medium cursor-default'
                          : 'text-[var(--color-text-muted)] hover:text-[var(--color-accent)]',
                      ]}
                    >
                      <span class="font-mono text-[10px] flex-shrink-0 mt-0.5 text-[var(--color-text-faint)]">
                        {String(i + 1).padStart(2, '0')}
                      </span>
                      <span class="leading-snug">{sp.data.title}</span>
                    </a>
                  );
                })}
              </div>
              <!-- prev/next text links -->
              <div class="mt-4 flex justify-between text-xs">
                {prevSeriesPost ? (
                  <a href={`${base}blog/${prevSeriesPost.id}/`} class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
                    ← Prev
                  </a>
                ) : <span />}
                {nextSeriesPost ? (
                  <a href={`${base}blog/${nextSeriesPost.id}/`} class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
                    Next →
                  </a>
                ) : <span />}
              </div>
            </div>
          )}
        </div>
      </aside>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  .prose-custom { line-height: 1.8; color: var(--color-text-muted); }
  .prose-custom h2 { margin-top: 2.5rem; margin-bottom: 1rem; font-size: 1.5rem; font-weight: 700; color: var(--color-text); font-family: var(--font-display); position: relative; }
  .prose-custom h3 { margin-top: 2rem; margin-bottom: 0.75rem; font-size: 1.25rem; font-weight: 600; color: var(--color-text); position: relative; }
  .prose-custom h2:hover::before, .prose-custom h3:hover::before { content: '#'; position: absolute; left: -1.5em; color: var(--color-accent); opacity: 0.5; font-weight: 400; }
  .prose-custom p { margin-bottom: 1.25rem; font-size: 0.9375rem; }
  .prose-custom ul, .prose-custom ol { margin-bottom: 1.25rem; padding-left: 1.5rem; }
  .prose-custom li { margin-bottom: 0.5rem; font-size: 0.9375rem; }
  .prose-custom ul li { list-style-type: disc; }
  .prose-custom ol li { list-style-type: decimal; }
  .prose-custom strong { color: var(--color-text); font-weight: 600; }
  .prose-custom a { color: var(--color-accent-light); text-decoration: underline; text-underline-offset: 2px; }
  .prose-custom a:hover { color: var(--color-text); }
  .prose-custom pre { position: relative; margin-bottom: 1.5rem; border-radius: 0.75rem; border: 1px solid var(--color-border); background-color: var(--color-bg-card) !important; padding: 1.25rem; overflow-x: auto; font-size: 0.8125rem; line-height: 1.7; }
  .prose-custom pre:hover .copy-btn { opacity: 1; }
  .prose-custom pre code { color: var(--color-text) !important; }
  .prose-custom code { font-family: var(--font-mono); font-size: 0.85em; }
  .prose-custom :not(pre) > code { padding: 0.15em 0.4em; border-radius: 0.25rem; background-color: var(--color-bg-card); border: 1px solid var(--color-border); color: var(--color-accent-light); }
  .prose-custom blockquote { margin-bottom: 1.25rem; border-left: 3px solid var(--color-accent); padding-left: 1rem; color: var(--color-text-muted); font-style: italic; }
  .prose-custom hr { margin: 2rem 0; border-color: var(--color-border); }
  .prose-custom img { border-radius: 0.75rem; margin-bottom: 0.5rem; }
  .prose-custom img + em { display: block; font-size: 0.75rem; color: var(--color-text-muted); font-style: normal; margin-bottom: 1.5rem; opacity: 0.7; }
  .prose-custom table { width: 100%; margin-bottom: 1.5rem; border-collapse: collapse; font-size: 0.875rem; }
  .prose-custom th { text-align: left; padding: 0.75rem 1rem; border-bottom: 2px solid var(--color-border); color: var(--color-text); font-weight: 600; font-size: 0.8125rem; }
  .prose-custom td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--color-border); color: var(--color-text-muted); }
  .prose-custom tr:last-child td { border-bottom: none; }
  .prose-custom tbody tr:hover { background-color: var(--color-bg-card); }
  .copy-btn { position: absolute; top: 0.5rem; right: 0.5rem; padding: 0.25rem 0.6rem; font-size: 0.7rem; font-family: var(--font-mono); background: var(--color-bg-detail); color: var(--color-text-muted); border: 1px solid var(--color-border); border-radius: 0.375rem; cursor: pointer; opacity: 0; transition: opacity 0.15s ease, background 0.15s ease, color 0.15s ease; }
  .copy-btn.copied { background: var(--color-accent); color: var(--color-on-accent); border-color: var(--color-accent); opacity: 1; }
</style>

<script>
  document.querySelectorAll('.prose-custom pre').forEach((pre) => {
    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.textContent = 'Copy';
    btn.setAttribute('aria-label', 'Copy code');
    pre.appendChild(btn);
    btn.addEventListener('click', () => {
      const code = pre.querySelector('code');
      const text = code ? code.innerText : (pre as HTMLElement).innerText;
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 800);
      });
    });
  });
</script>

<script>
  // C5: Blog Image Zoom
  (function() {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const overlay = document.createElement('div');
    overlay.setAttribute('role', 'dialog');
    overlay.setAttribute('aria-modal', 'true');
    overlay.setAttribute('aria-label', 'Image preview');
    overlay.style.cssText = [
      'position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;',
      'background:rgba(0,0,0,0.85);backdrop-filter:blur(4px);',
      'opacity:0;pointer-events:none;cursor:zoom-out;',
      prefersReduced ? '' : 'transition:opacity 0.2s ease;',
    ].join('');
    const img = document.createElement('img');
    img.style.cssText = [
      'max-width:90vw;max-height:90vh;border-radius:8px;object-fit:contain;',
      'box-shadow:0 25px 60px rgba(0,0,0,0.5);',
      prefersReduced ? '' : 'transition:transform 0.2s ease;transform:scale(0.92);',
    ].join('');
    img.alt = '';
    overlay.appendChild(img);
    document.body.appendChild(overlay);

    function open(src: string, alt: string) {
      img.src = src; img.alt = alt;
      overlay.style.pointerEvents = 'auto';
      overlay.style.opacity = '1';
      if (!prefersReduced) img.style.transform = 'scale(1)';
      document.body.style.overflow = 'hidden';
      document.addEventListener('keydown', onKey);
    }
    function close() {
      overlay.style.opacity = '0';
      overlay.style.pointerEvents = 'none';
      if (!prefersReduced) img.style.transform = 'scale(0.92)';
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onKey);
    }
    function onKey(e: KeyboardEvent) { if (e.key === 'Escape') close(); }
    overlay.addEventListener('click', close);
    img.addEventListener('click', (e) => e.stopPropagation());

    document.querySelectorAll<HTMLImageElement>('.prose-custom img').forEach((el) => {
      el.style.cursor = 'zoom-in';
      el.addEventListener('click', () => open(el.src, el.alt));
    });
  })();
</script>
