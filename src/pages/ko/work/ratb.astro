<script>
  // Page transition — enter animation (split-panel reveal)
  const pt = document.getElementById('pageTransition');
  if (pt) {
    pt.classList.add('enter');
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        pt.classList.add('done');
        setTimeout(() => { pt.classList.remove('enter', 'done'); }, 600);
      });
    });
  }

  // Nav scroll
  const nav = document.getElementById('csNav');
  window.addEventListener('scroll', () => { nav.classList.toggle('scrolled', window.scrollY > 60); });

  // Theme toggle
  const themeBtn = document.getElementById('csThemeBtn');
  if (themeBtn) {
    themeBtn.addEventListener('click', () => {
      const html = document.documentElement;
      const isDark = html.getAttribute('data-theme') === 'dark';
      html.setAttribute('data-theme', isDark ? 'light' : 'dark');
      themeBtn.textContent = isDark ? '◐ Light' : '◐ Dark';
    });
  }

  // Reveal on scroll
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.ratb-rv').forEach(el => io.observe(el));

  // Dot cursor
  const cursor = document.getElementById('cursor');
  const cursorLabel = document.getElementById('cursorLabel');
  if (cursor) {
    let mx = 0, my = 0, cx = 0, cy = 0;
    document.addEventListener('mousemove', (e) => { mx = e.clientX; my = e.clientY; });
    function cursorLoop() {
      cx += (mx - cx) * 0.15; cy += (my - cy) * 0.15;
      cursor.style.transform = 'translate(' + cx + 'px,' + cy + 'px)';
      requestAnimationFrame(cursorLoop);
    }
    cursorLoop();

    document.querySelectorAll('a, button, [data-cursor]').forEach(el => {
      el.addEventListener('mouseenter', () => {
        cursor.classList.add('hover');
        if (el.dataset.cursor) {
          cursor.classList.add('has-label');
          cursorLabel.textContent = el.dataset.cursor;
        }
      });
      el.addEventListener('mouseleave', () => {
        cursor.classList.remove('hover', 'has-label');
      });
    });
  }

  // Back button — exit transition
  document.querySelectorAll('.cs-back-link').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const href = link.getAttribute('href');
      pt.classList.add('exit');
      setTimeout(() => { window.location.href = href; }, 500);
    });
  });
</script>

