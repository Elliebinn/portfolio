<script is:inline>
  // Nav scroll
  const nav = document.getElementById('csNav');
  if (nav) window.addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 80), { passive: true });

  // Theme toggle
  const themeBtn = document.getElementById('csThemeBtn');
  if (themeBtn) {
    themeBtn.addEventListener('click', () => {
      const html = document.documentElement;
      const isDark = html.getAttribute('data-theme') !== 'light';
      html.setAttribute('data-theme', isDark ? 'light' : 'dark');
      themeBtn.textContent = isDark ? '◐ Light' : '◐ Dark';
    });
  }

  // Reveal on scroll
  document.querySelectorAll('.rv').forEach(el => {
    new IntersectionObserver(([e]) => { if (e.isIntersecting) e.target.classList.add('vis'); },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }).observe(el);
  });


  // Debate flow stagger animation
  const debateCard = document.querySelector('.debate-flow-card');
  if (debateCard) {
    new IntersectionObserver(([e]) => {
      if (e.isIntersecting) debateCard.classList.add('animate');
    }, { threshold: 0.3 }).observe(debateCard);
  }

  // Agent card expand
  document.querySelectorAll('.agent-expandable').forEach(node => {
    node.addEventListener('click', () => {
      const wasActive = node.classList.contains('active');
      document.querySelectorAll('.agent-expandable').forEach(n => {
        n.classList.remove('active');
        n.querySelector('.agent-detail').textContent = '';
      });
      if (!wasActive) {
        node.classList.add('active');
        node.querySelector('.agent-detail').textContent = node.dataset.detail;
      }
    });
  });

  // Crosshair cursor
  const cursor = document.getElementById('cursor');
  const cursorLabel = document.getElementById('cursorLabel');
  if (cursor) {
    let mx = 0, my = 0, cx = 0, cy = 0;
    document.addEventListener('mousemove', (e) => { mx = e.clientX; my = e.clientY; });
    function cursorLoop() {
      cx += (mx - cx) * 0.15; cy += (my - cy) * 0.15;
      cursor.style.transform = 'translate(' + cx + 'px,' + cy + 'px)';
      requestAnimationFrame(cursorLoop);
    }
    cursorLoop();
    document.querySelectorAll('a, button, [data-cursor]').forEach(el => {
      el.addEventListener('mouseenter', () => {
        cursor.classList.add('active');
        if (cursorLabel && el.dataset.cursor) cursorLabel.textContent = el.dataset.cursor;
      });
      el.addEventListener('mouseleave', () => {
        cursor.classList.remove('active');
        if (cursorLabel) cursorLabel.textContent = '';
      });
    });
  }
</script>

