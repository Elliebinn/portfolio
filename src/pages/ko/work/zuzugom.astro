---
import V2Layout from '../../../layouts/V2Layout.astro';
import '../../../styles/v2-casestudy.css';
---
<V2Layout title="주주곰 — AI Multi-Agent Stock Analysis" lang="ko">

<script is:inline src="https://cdn.tailwindcss.com"></script>
<script is:inline src="https://unpkg.com/@phosphor-icons/web@2.1.1"></script>
<script is:inline>
tailwind.config = {
  theme: { extend: {
    colors: {
      surface: { page:'var(--s-page)', card:'var(--s-card)', subtle:'var(--s-subtle)', elevated:'var(--s-elevated)', dark:'var(--s-dark)', darker:'var(--s-darker)' },
      jj: { blue:'#3B82F6', 'blue-soft':'#60A5FA', emerald:'#10B981', red:'#EF4444', amber:'#F59E0B', violet:'#8B5CF6', pink:'#EC4899' },
      txt: { primary:'var(--t-primary)', secondary:'var(--t-secondary)', muted:'var(--t-muted)', faint:'var(--t-faint)' },
      bdr: { card:'var(--b-card)', hover:'var(--b-hover)', subtle:'var(--b-subtle)' },
    },
    fontFamily: {
      sans: ['Pretendard','-apple-system','system-ui','sans-serif'],
      display: ['Space Grotesk','Pretendard','sans-serif'],
      mono: ['JetBrains Mono','monospace'],
    },
  }},
}
</script>

<style is:inline>
  :root, html[data-theme="dark"] {
    --s-page:#131313; --s-card:#1e1e1e; --s-subtle:#1a1a1a; --s-elevated:#2a2a2a;
    --s-dark:#0e0e0e; --s-darker:#0a0a0a;
    --t-primary:#f2f2f0; --t-secondary:#a0a0a0; --t-muted:#666666; --t-faint:#444444;
    --b-card:rgba(226,226,226,0.15); --b-hover:rgba(226,226,226,0.25); --b-subtle:rgba(226,226,226,0.08);
    --nav-pill-bg:rgba(12,12,11,0.80);
  }
  html[data-theme="light"] {
    --s-page:#F0EDE5; --s-card:#ffffff; --s-subtle:#E8E4DA; --s-elevated:#f5f3ef;
    --s-dark:#E8E4DA; --s-darker:#DDD9CF;
    --t-primary:#161513; --t-secondary:#5a5754; --t-muted:#8a8784; --t-faint:#bbb8b4;
    --b-card:rgba(0,0,0,0.08); --b-hover:rgba(0,0,0,0.12); --b-subtle:rgba(0,0,0,0.04);
    --nav-pill-bg:rgba(240,237,229,0.80);
  }

  .label { font-family:'Space Grotesk',sans-serif; font-size:11px; font-weight:700; letter-spacing:.15em; text-transform:uppercase; color:#3B82F6; }
  .giant { font-family:'Space Grotesk',sans-serif; font-weight:800; line-height:1; letter-spacing:-0.04em; color:#f2f2f0; }
  .agent-node { background:var(--s-card); border:1px solid var(--b-card); border-radius:16px; padding:20px; transition:all .3s cubic-bezier(0.16,1,0.3,1); }
  .agent-node:hover { transform:translateY(-2px); border-color:var(--b-hover); }
  .debate-step { opacity:0; transform:translateY(16px) scale(0.95); transition:all .5s cubic-bezier(0.16,1,0.3,1); transition-delay:calc(var(--step) * 120ms); }
  .debate-flow-card.animate .debate-step { opacity:1; transform:translateY(0) scale(1); }
  .agent-expandable { cursor:pointer; position:relative; }
  .agent-expandable.active { border-color:#3B82F6; background:rgba(59,130,246,0.06); grid-column:1/-1; text-align:left; padding:12px 16px; }
  .agent-detail { max-height:0; overflow:hidden; transition:max-height .3s ease, opacity .3s ease, margin .3s ease; opacity:0; margin-top:0; font-size:11px; color:var(--t-secondary); line-height:1.6; }
  .agent-expandable.active .agent-detail { max-height:80px; opacity:1; margin-top:8px; }

  .screenshot-placeholder {
    background: linear-gradient(135deg, rgba(59,130,246,0.05), rgba(139,92,246,0.05));
    border: 2px dashed var(--b-card);
    border-radius: 16px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    color: var(--t-muted); font-size: 14px; font-weight: 500;
    text-align: center; padding: 32px; min-height: 280px;
    transition: border-color .3s;
  }
  .screenshot-placeholder:hover { border-color: var(--b-hover); }
  .screenshot-placeholder .ph-icon { font-size: 32px; margin-bottom: 12px; opacity: 0.5; }
  .screenshot-placeholder .ph-label { font-size: 11px; letter-spacing: .1em; text-transform: uppercase; margin-top: 8px; color: var(--t-faint); }

  .phone-mockup {
    position: relative;
    display: inline-block;
    padding: 12px;
    background: #1a1a1a;
    border-radius: 40px;
    box-shadow: 0 0 0 2px #333, 0 20px 60px rgba(0,0,0,0.4);
  }
  .phone-mockup::before {
    content: '';
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 22px;
    background: #1a1a1a;
    border-radius: 0 0 14px 14px;
    z-index: 2;
  }
  .phone-mockup img {
    display: block;
    width: 100%;
    border-radius: 28px;
  }
  .phone-mockup--sm { max-width: 260px; }
  .phone-mockup--md { max-width: 300px; }
  .phone-mockup--lg { max-width: 340px; }

  .callout { background: var(--s-subtle); border: 1px solid var(--b-card); border-radius: 12px; padding: 16px 20px; margin-bottom: 24px; }
  .callout-title { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 500; letter-spacing: .05em; text-transform: uppercase; color: var(--t-muted); margin-bottom: 8px; }
  .callout-body { font-size: 13px; line-height: 1.7; color: var(--t-secondary); }

  .persona-item { padding-bottom: 16px; margin-bottom: 16px; border-bottom: 1px solid var(--b-subtle); }
  .persona-item:last-child { padding-bottom: 0; margin-bottom: 0; border-bottom: none; }
  .persona-dot { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; background: var(--s-elevated); color: var(--t-muted); }

  .tag { font-size: 10px; font-weight: 500; letter-spacing: .05em; text-transform: uppercase; padding: 2px 8px; border-radius: 6px; background: var(--s-elevated); color: var(--t-muted); }

  .cs-nav { position:fixed; top:0; left:0; right:0; z-index:9990; padding:22px 44px; display:flex; justify-content:space-between; align-items:center; transition: all .45s cubic-bezier(.25,.46,.45,.94); }
  .cs-nav.scrolled { top:16px; left:22%; right:22%; padding:14px 36px; border-radius:100px; background:var(--nav-pill-bg); backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px); box-shadow:0 4px 24px rgba(0,0,0,0.25); }
  .cs-nav-brand { font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:18px; color:#e2e2e2; text-decoration:none; }
  .cs-nav-right { display: flex; align-items: center; gap: 24px; }
  .cs-back-link { font-size:12px; font-weight:400; letter-spacing:0.1em; text-transform:uppercase; color:#888; text-decoration:none; position:relative; transition:color .3s; }
  .cs-back-link::after { content:''; position:absolute; bottom:-2px; left:0; width:0; height:1px; background:#e2e2e2; transition:width .3s; }
  .cs-back-link:hover { color:#e2e2e2; }
  .cs-back-link:hover::after { width:100%; }
  .cs-theme-btn { display:inline-flex; align-items:center; gap:8px; padding:8px 16px; border-radius:100px; border:1px solid rgba(226,226,226,0.15); background:transparent; color:#e2e2e2; font-size:12px; font-weight:500; letter-spacing:.08em; text-transform:uppercase; cursor:pointer; transition:border-color .3s; }
  .cs-theme-btn:hover { border-color:#e2e2e2; }
  @media (max-width:900px) { .cs-nav.scrolled { left:5%; right:5%; } .cs-nav { padding:16px 20px; } }
  @media (max-width:480px) { .cs-nav.scrolled { left:3%; right:3%; padding:10px 16px; } .cs-nav-brand { font-size:16px; } .cs-back-link { font-size:10px; } .cs-theme-btn { font-size:10px; padding:6px 12px; } .cs-nav-right { gap:12px; } }
  .case-hero-title .hl { color:#60A5FA; }

  @media (max-width:640px) {
    .font-display.text-4xl { font-size:1.5rem !important; }
    h3.font-display { font-size:1.25rem !important; }
    .giant.text-6xl { font-size:2.5rem !important; }
    .label { font-size:10px !important; }
  }
</style>

<nav class="cs-nav" id="csNav" style="z-index:9990;">
  <a href="/ko/" class="cs-nav-brand">Hyebin.</a>
  <div class="cs-nav-right">
    <a href="/ko/" class="cs-back-link">Back Home</a>
    <button class="cs-theme-btn" id="csThemeBtn">◐ Dark</button>
  </div>
</nav>

<!-- Crosshair cursor -->
<div class="cursor" id="cursor">
  <div class="cursor-dot"></div>
  <div class="cursor-ring"></div>
  <div class="cursor-label" id="cursorLabel"></div>
</div>

<!-- ═══════ 01. HERO ═══════ -->
<section class="case-hero" id="hero">
  <div style="position:absolute; inset:0; z-index:0;">
    <img src="/assets/projects/zuzugom-hero.jpg" alt="" style="width:100%; height:100%; object-fit:cover;" />
    <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.5) 40%, rgba(0,0,0,0.3) 100%);"></div>
  </div>
  <div style="position:absolute; right:40px; top:50%; transform:translateY(-50%); font-family:'Space Grotesk'; font-size:clamp(120px,20vw,280px); font-weight:700; letter-spacing:-0.05em; color:rgba(226,226,226,0.03); z-index:0;">03</div>
  <div class="case-hero-inner">
    <h1 class="case-hero-title">
      <span class="line"><span>Designing how</span></span>
      <span class="line"><span>AI agents</span></span>
      <span class="line"><span><span class="hl">debate</span>.</span></span>
    </h1>
    <dl class="case-hero-meta">
      <div class="case-hero-meta-item"><dt>Project</dt><dd>주주곰</dd></div>
      <div class="case-hero-meta-item"><dt>Year</dt><dd>2026 — Now</dd></div>
      <div class="case-hero-meta-item"><dt>Type</dt><dd>FinTech · AI Agent</dd></div>
      <div class="case-hero-meta-item"><dt>Role</dt><dd>PM · 1인 기획/개발</dd></div>
    </dl>
  </div>
</section>


<!-- ═══════ 02. ORIGIN STORY ═══════ -->
<section class="py-32">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-[1fr_1fr] gap-16 items-start rv">
      <div>
        <p class="label mb-4">Origin</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight leading-tight">
          이 종목 괜찮아?에<br/>답할 수 있는 도구가 없었다
        </h2>
        <p class="mt-6 text-txt-secondary text-[16px] leading-relaxed">
          시작은 부모님이었습니다. 담고 있는 종목이 궁금한데, 검색하면 복잡한 지표와 전문 용어만 나왔습니다.
          이 종목 왜 샀어?라는 질문에 답할 수 있는 도구는 없었습니다.
        </p>
        <p class="mt-4 text-txt-secondary text-[16px] leading-relaxed">
          그런데 부모님만의 문제가 아니었습니다.
          AED에서 퀀트 리서처를 위한 대시보드를 만들면서 — 전문가조차 여러 분석을 직접 종합하는 데 시간을 쓴다는 걸 알았습니다.
          하물며 개인투자자는요.
        </p>
        <div class="mt-8 pt-6 border-t border-[rgba(226,226,226,0.08)] space-y-2 text-[14px]">
          <div class="flex items-start gap-3">
            <span class="text-txt-muted font-medium w-14 flex-shrink-0">역할</span>
            <span class="text-txt-secondary">기획 · 에이전트 설계 · 프롬프트 · 풀스택 구현</span>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-txt-muted font-medium w-14 flex-shrink-0">기간</span>
            <span class="text-txt-secondary">2026.02 ~ 현재 (진행 중)</span>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-txt-muted font-medium w-14 flex-shrink-0">스택</span>
            <span class="text-txt-secondary">FastAPI · React 19 · Claude · SSE · Supabase</span>
          </div>
        </div>
      </div>
      <div>
        <!-- 타겟 페르소나 카드 -->
        <div class="bg-surface-card rounded-[20px] p-6 border border-bdr-card">
          <p class="text-[11px] font-bold tracking-wider uppercase text-jj-blue mb-5">Who is this for?</p>

          <!-- 페르소나 1: 재현 -->
          <div class="persona-item">
            <div class="flex items-center gap-3 mb-2.5">
              <div class="persona-dot"><i class="ph ph-briefcase"></i></div>
              <div>
                <p class="font-display font-bold text-[15px]">재현, 36</p>
                <p class="text-txt-muted text-[12px]">IT기업 팀장 · 투자 4년차</p>
              </div>
              <span class="tag ml-auto">Primary</span>
            </div>
            <p class="text-txt-secondary text-[13px] leading-relaxed">"출퇴근길에 종목 뉴스는 보는데, 여러 소스를 직접 종합할 시간은 없다. AI가 <strong class="text-txt-primary">'왜'</strong>를 설명해줬으면."</p>
          </div>

          <!-- 페르소나 2: 부모님 -->
          <div class="persona-item">
            <div class="flex items-center gap-3 mb-2.5">
              <div class="persona-dot"><i class="ph ph-users-three"></i></div>
              <div>
                <p class="font-display font-bold text-[15px]">영호 & 미영, 50대</p>
                <p class="text-txt-muted text-[12px]">5개 계좌 · 15+ 종목 · 엑셀 관리</p>
              </div>
              <span class="tag ml-auto">Origin</span>
            </div>
            <p class="text-txt-secondary text-[13px] leading-relaxed">"종목 팔아야 하는지 모르겠어. 누가 쉽게 설명해주면 좋겠는데." 이 프로젝트의 <strong class="text-txt-primary">시작점</strong>이자 첫 번째 실사용자.</p>
          </div>

          <!-- 페르소나 3: 수민 -->
          <div class="persona-item">
            <div class="flex items-center gap-3 mb-2.5">
              <div class="persona-dot"><i class="ph ph-graduation-cap"></i></div>
              <div>
                <p class="font-display font-bold text-[15px]">수민, 28</p>
                <p class="text-txt-muted text-[12px]">대기업 주니어 · 투자 1년차</p>
              </div>
              <span class="tag ml-auto">Growth</span>
            </div>
            <p class="text-txt-secondary text-[13px] leading-relaxed">"유튜버마다 말이 달라서 누구를 믿어야 할지 모르겠다. 분석 <strong class="text-txt-primary">과정 자체</strong>를 배우고 싶다."</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════ 02-B. RESEARCH — WHY THIS PROBLEM ═══════ -->
<section class="py-32" style="background:var(--s-subtle);">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="grid lg:grid-cols-[1fr_1fr] gap-16 items-start rv">
      <div>
        <p class="label mb-4">Research</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight leading-tight">
          1,400만 개인투자자,<br/>대부분 이렇게 관리하고 있다
        </h2>
        <p class="mt-6 text-txt-secondary text-[16px] leading-relaxed">
          한국 성인 3명 중 1명이 주식을 합니다. 상당수가 위탁·ISA·연금저축·퇴직연금 등 여러 계좌에 종목을 분산하고 있지만,
          한눈에 볼 도구는 없습니다.
        </p>
        <p class="mt-4 text-txt-secondary text-[16px] leading-relaxed">
          실제로 저도 부모님 포트폴리오를 엑셀로 관리하고 있었습니다.
          5개 계좌, 15개 이상 종목, 매주 현재가를 수동으로 갱신하고, 수익률을 직접 계산했습니다.
          #DIV/0! 에러가 나면 수식을 하나하나 고쳤습니다.
        </p>
      </div>
      <div>
        <!-- 실제 엑셀 스크린샷 -->
        <div class="rounded-[16px] overflow-hidden border border-bdr-card" style="background:#1a1a1a;">
          <div class="flex items-center gap-2 px-4 py-2.5" style="background:#222; border-bottom:1px solid rgba(226,226,226,0.08);">
            <div style="display:flex; gap:5px;">
              <span style="width:8px; height:8px; border-radius:50%; background:rgba(226,226,226,0.12);"></span>
              <span style="width:8px; height:8px; border-radius:50%; background:rgba(226,226,226,0.12);"></span>
              <span style="width:8px; height:8px; border-radius:50%; background:rgba(226,226,226,0.12);"></span>
            </div>
            <span style="font-family:'JetBrains Mono'; font-size:10px; color:#666; margin-left:auto; letter-spacing:.05em;">자산_포트폴리오.xlsx</span>
          </div>
          <div style="border-radius:0; overflow:hidden;">
            <img src="/images/zuzugom/excel-portfolio.png" alt="실제 엑셀 포트폴리오 — 5개 계좌 × 15+ 종목" style="width:100%; display:block;" loading="lazy" />
          </div>
        </div>
      </div>
    </div>


    <!-- Pain Points -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mt-16 rv">
      <div class="bg-surface-card rounded-[16px] p-5 border border-bdr-card">
        <p class="font-display font-bold text-2xl text-txt-muted mb-1">수동 갱신</p>
        <p class="text-txt-secondary text-sm">매주 1~2시간 현재가 입력, 수익률 재계산. GOOGLEFINANCE도 20분 지연</p>
      </div>
      <div class="bg-surface-card rounded-[16px] p-5 border border-bdr-card">
        <p class="font-display font-bold text-2xl text-txt-muted mb-1">수식 깨짐</p>
        <p class="text-txt-secondary text-sm">#DIV/0!, #N/A 에러. 종목 추가할 때마다 VLOOKUP 수정 필요</p>
      </div>
      <div class="bg-surface-card rounded-[16px] p-5 border border-bdr-card">
        <p class="font-display font-bold text-2xl text-txt-muted mb-1">계좌 분산</p>
        <p class="text-txt-secondary text-sm">위탁·ISA·연금저축·퇴직연금 — 각각 다른 증권사, 통합 뷰 없음</p>
      </div>
      <div class="bg-surface-card rounded-[16px] p-5 border border-bdr-card">
        <p class="font-display font-bold text-2xl text-txt-muted mb-1">분석 불가</p>
        <p class="text-txt-secondary text-sm">가격은 알지만 "왜 올랐는지", "팔아야 하는지" 판단 도구 없음</p>
      </div>
    </div>

    <!-- Competitor Gap -->
    <div class="mt-16 rv">
      <div class="bg-surface-card rounded-[20px] border border-bdr-card overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-bdr-subtle">
              <th class="text-left px-6 py-4 text-txt-muted font-mono text-[11px] tracking-wider uppercase">기존 대안</th>
              <th class="text-left px-6 py-4 text-txt-muted font-mono text-[11px] tracking-wider uppercase">한계</th>
              <th class="text-left px-6 py-4 text-jj-blue font-mono text-[11px] tracking-wider uppercase">주주곰</th>
            </tr>
          </thead>
          <tbody class="text-txt-secondary">
            <tr class="border-b border-bdr-subtle">
              <td class="px-6 py-3 font-medium text-txt-primary">토스증권</td>
              <td class="px-6 py-3">한 증권사 계좌만. 타사 + 연금 통합 불가</td>
              <td class="px-6 py-3 text-txt-primary">OCR로 어떤 증권사든 스크린샷 한 장</td>
            </tr>
            <tr class="border-b border-bdr-subtle">
              <td class="px-6 py-3 font-medium text-txt-primary">엑셀/구글시트</td>
              <td class="px-6 py-3">수동 갱신, 수식 에러, 분석 기능 없음</td>
              <td class="px-6 py-3 text-txt-primary">자동 시세 + AI 6개 에이전트 분석</td>
            </tr>
            <tr class="border-b border-bdr-subtle">
