---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/translations';

const lang = 'ko';
const tr = t(lang);

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categoryLabels: Record<string, string> = {
  project: '프로젝트',
  planning: '기획',
  'deep-dive': '삽질기',
  skill: '스킬',
};

const base = import.meta.env.BASE_URL;
const featured = posts.find(p => p.data.featured) || posts[0];
const restPosts = posts.filter(p => p.id !== featured.id);
const mostRead = posts.slice(0, 3);
---

<Layout title={`${tr.blog.pageTitle} — HYEBIN.DEV`}>
  <Navbar lang={lang} client:load />

  <main class="pt-32 pb-20 px-6 md:px-12 max-w-7xl mx-auto">
    <!-- Header -->
    <header class="mb-20 flex flex-col md:flex-row md:items-end justify-between gap-8">
      <div class="max-w-2xl">
        <span class="text-xs font-bold text-[var(--color-accent)] uppercase tracking-widest mb-4 block">{tr.blog.section}</span>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-[var(--color-text)] mb-4 leading-[1.1]" style="font-family: var(--font-display);">
          {tr.blog.pageTitle}
        </h1>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
          {tr.blog.pageDescription}
        </p>
      </div>
    </header>

    <!-- Category Filter -->
    <div class="flex flex-wrap gap-3 mb-16 items-center" id="category-filters">
      <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-faint)] mr-2">필터:</span>
      <button data-category="all" class="category-btn active px-5 py-2 rounded-full bg-[var(--color-accent)] text-[var(--color-on-accent)] text-sm font-semibold transition-all">전체</button>
      {Object.entries(categoryLabels).map(([key, label]) => (
        <button data-category={key} class="category-btn px-5 py-2 rounded-full bg-[var(--color-secondary-container)] text-[var(--color-on-secondary-container)] text-sm font-semibold hover:bg-[var(--color-bg-detail)] transition-all">{label}</button>
      ))}
    </div>

    <!-- Blog Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

      <!-- Featured Post -->
      <a href={`${base}${lang}/blog/${featured.id}/`} class="lg:col-span-8 group cursor-pointer blog-post" data-category={featured.data.category}>
        <div class="relative h-[400px] sm:h-[500px] w-full rounded-xl overflow-hidden mb-6 bg-[var(--color-bg-detail)]">
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-text)]/70 via-transparent to-transparent z-10"></div>
          <div class="absolute bottom-8 left-8 right-8 z-20">
            <div class="flex gap-3 mb-4">
              <span class="bg-[var(--color-secondary-container)] text-[var(--color-on-secondary-container)] text-[10px] uppercase font-bold tracking-widest px-3 py-1 rounded-full">
                {categoryLabels[featured.data.category] || featured.data.category}
              </span>
              <span class="text-white/70 text-[10px] uppercase font-bold tracking-widest px-3 py-1">
                {featured.data.date.toISOString().slice(0, 10)}
              </span>
            </div>
            <h2 class="text-2xl sm:text-3xl font-bold text-white mb-2 group-hover:underline decoration-2 underline-offset-4" style="font-family: var(--font-display);">
              {featured.data.title}
            </h2>
            <p class="text-white/80 line-clamp-2 max-w-xl text-sm">{featured.data.description}</p>
          </div>
        </div>
      </a>

      <!-- Sidebar: Most Read -->
      <aside class="lg:col-span-4 space-y-6">
        <h3 class="text-sm font-bold uppercase tracking-widest text-[var(--color-text-faint)]">인기 글</h3>
        <div class="space-y-5">
          {mostRead.map((post) => (
            <a href={`${base}${lang}/blog/${post.id}/`} class="group flex gap-4 cursor-pointer">
              <div class="flex-shrink-0 w-20 h-20 rounded-lg overflow-hidden bg-[var(--color-bg-detail)]">
                <div class="w-full h-full flex items-center justify-center text-[var(--color-text-faint)] text-lg font-bold" style="font-family: var(--font-display);">
                  {categoryLabels[post.data.category]?.charAt(0) || '글'}
                </div>
              </div>
              <div>
                <span class="text-[10px] font-bold text-[var(--color-accent)] uppercase tracking-wider">
                  {categoryLabels[post.data.category] || post.data.category}
                </span>
                <h4 class="font-bold text-sm text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors leading-snug line-clamp-2">
                  {post.data.title}
                </h4>
              </div>
            </a>
          ))}
        </div>

        <!-- Series -->
        <div class="mt-8 rounded-xl bg-[var(--color-bg-card)] p-5 shadow-ambient-sm">
          <h3 class="text-sm font-bold uppercase tracking-widest text-[var(--color-text-faint)] mb-4">시리즈</h3>
          <div class="space-y-3">
            <a href={`${base}${lang}/blog/2024-01-15-ratb-ai-national-exam/`} class="block text-sm font-medium text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors">
              RATB 운용기 (5편)
            </a>
            <a href={`${base}${lang}/blog/2026-03-23-aed-quant-tool-overview/`} class="block text-sm font-medium text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors">
              퀀트 플랫폼 (7편)
            </a>
          </div>
        </div>
      </aside>

      <!-- Rest of posts: 2-column grid -->
      <div class="lg:col-span-12 grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-14 mt-4">
        {restPosts.map((post) => (
          <a href={`${base}${lang}/blog/${post.id}/`} class="group blog-post" data-category={post.data.category}>
            <div class="flex flex-col gap-4">
              <div class="space-y-3">
                <div class="flex items-center gap-4 text-xs font-bold uppercase tracking-wider text-[var(--color-text-faint)]">
                  <span>{post.data.date.toISOString().slice(0, 10)}</span>
                  <span class="w-1 h-1 rounded-full bg-[var(--color-outline-variant)]"></span>
                  <span class="text-[var(--color-accent)]">{categoryLabels[post.data.category] || post.data.category}</span>
                </div>
                <h3 class="text-xl font-bold text-[var(--color-text)] leading-tight group-hover:text-[var(--color-accent)] transition-colors" style="font-family: var(--font-display);">
                  {post.data.title}
                </h3>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed line-clamp-3">
                  {post.data.description}
                </p>
                <div class="flex flex-wrap gap-2 pt-1">
                  {post.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="rounded-full bg-[var(--color-secondary-container)] px-2.5 py-0.5 text-[10px] font-medium text-[var(--color-on-secondary-container)]">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn');
  const posts = document.querySelectorAll<HTMLElement>('.blog-post');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;

      buttons.forEach(b => {
        b.classList.remove('active', 'bg-[var(--color-accent)]', 'text-[var(--color-on-accent)]');
        b.classList.add('bg-[var(--color-secondary-container)]', 'text-[var(--color-on-secondary-container)]');
      });
      btn.classList.remove('bg-[var(--color-secondary-container)]', 'text-[var(--color-on-secondary-container)]');
      btn.classList.add('active', 'bg-[var(--color-accent)]', 'text-[var(--color-on-accent)]');

      posts.forEach(post => {
        if (category === 'all' || post.dataset.category === category) {
          post.style.display = '';
        } else {
          post.style.display = 'none';
        }
      });
    });
  });
</script>
