---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/translations';

const lang = 'ko';
const tr = t(lang);

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categoryLabels: Record<string, string> = {
  project: '프로젝트',
  planning: '기획',
  'deep-dive': '삽질기',
  skill: '스킬',
};

const categoryColors: Record<string, string> = {
  project: '#4f6354',   // deep sage
  planning: '#456272',  // sage blue (accent)
  'deep-dive': '#615a7d', // muted violet
  skill: '#8a6d3b',     // warm taupe
};

const getColor = (cat: string) => categoryColors[cat] || 'var(--color-accent)';

const base = import.meta.env.BASE_URL;
const featured = posts.find(p => p.data.featured) || posts[0];
const restPosts = posts.filter(p => p.id !== featured.id);
const mostRead = posts.slice(0, 3);

const formatDate = (d: Date) => {
  const yyyy = d.getFullYear();
  const mm = String(d.getMonth() + 1).padStart(2, '0');
  const dd = String(d.getDate()).padStart(2, '0');
  return `${yyyy}.${mm}.${dd}`;
};
---

<Layout title={`${tr.blog.pageTitle} — HYEBIN.DEV`}>
  <Navbar lang={lang} client:load />

  <main class="pt-32 pb-20 px-6 md:px-12 max-w-7xl mx-auto">
    <!-- Masthead: 에디토리얼 신문 제호 톤 -->
    <header class="mb-24">
      <div class="flex items-baseline justify-between border-b-2 border-[var(--color-text)] pb-2 mb-8">
        <span class="text-[10px] font-extrabold uppercase tracking-[0.3em] text-[var(--color-text)]">HYEBIN · JOURNAL</span>
        <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--color-text-muted)]">Vol. {posts.length.toString().padStart(2, '0')} · {formatDate(new Date())}</span>
      </div>
      <h1 class="text-5xl sm:text-6xl md:text-8xl font-extrabold tracking-tight text-[var(--color-text)] leading-[0.95] mb-6" style="font-family: var(--font-display);">
        {tr.blog.pageTitle}
      </h1>
      <p class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-2xl">
        {tr.blog.pageDescription}
      </p>
    </header>

    <!-- Category Filter: 인라인 텍스트 메뉴 -->
    <nav class="mb-20 flex flex-wrap items-baseline gap-x-8 gap-y-3" id="category-filters">
      <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--color-text-faint)]">Filter</span>
      <button data-category="all" class="category-btn active text-sm font-extrabold uppercase tracking-wider text-[var(--color-text)] transition-all">
        전체 <span class="text-[var(--color-text-faint)] font-medium">({posts.length})</span>
      </button>
      {Object.entries(categoryLabels).map(([key, label]) => {
        const count = posts.filter(p => p.data.category === key).length;
        return (
          <button data-category={key} class="category-btn text-sm font-bold uppercase tracking-wider text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-all">
            {label} <span class="text-[var(--color-text-faint)] font-medium">({count})</span>
          </button>
        );
      })}
    </nav>

    <!-- Blog Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-x-12 gap-y-20">

      <!-- Featured: 전면 타이포그래피 히어로, 카드/보더 없음 -->
      <a href={`${base}${lang}/blog/${featured.id}/`} class="lg:col-span-8 group relative blog-post block" data-category={featured.data.category}>
        <!-- Giant background number -->
        <div class="absolute -top-12 -left-6 text-[260px] sm:text-[340px] md:text-[420px] font-extrabold leading-none pointer-events-none select-none opacity-[0.04] z-0"
             style="font-family: var(--font-display); color: var(--color-text);">
          №1
        </div>

        <div class="relative z-10 pt-8">
          <!-- Section marker line (no border, just a typographic rule) -->
          <div class="flex items-baseline gap-4 mb-10">
            <span class="text-[10px] font-extrabold uppercase tracking-[0.3em]"
                  style={`color: ${getColor(featured.data.category)};`}>
              ■ Featured Essay
            </span>
            <span class="flex-1 h-[1px]" style={`background-color: ${getColor(featured.data.category)};`}></span>
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--color-text-faint)]">
              {formatDate(featured.data.date)}
            </span>
          </div>

          <!-- Category dropcap -->
          <p class="text-xs font-extrabold uppercase tracking-[0.3em] mb-6" style={`color: ${getColor(featured.data.category)};`}>
            — {categoryLabels[featured.data.category] || featured.data.category}
          </p>

          <!-- Giant title -->
          <h2 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-[var(--color-text)] leading-[1.05] tracking-tight max-w-3xl mb-8 group-hover:text-[var(--color-accent)] transition-colors"
              style="font-family: var(--font-display);">
            {featured.data.title}
          </h2>

          <!-- Lede -->
          <p class="text-base md:text-lg text-[var(--color-text-muted)] leading-[1.7] max-w-2xl mb-10 font-serif italic">
            {featured.data.description}
          </p>

          <!-- CTA -->
          <div class="flex items-center gap-3 text-xs font-extrabold uppercase tracking-[0.25em] group-hover:gap-5 transition-all"
               style={`color: ${getColor(featured.data.category)};`}>
            <span class="inline-block w-8 h-[1px]" style={`background-color: ${getColor(featured.data.category)};`}></span>
            <span>Continue Reading</span>
          </div>
        </div>
      </a>

      <!-- Sidebar -->
      <aside class="lg:col-span-4 space-y-14">
        <!-- Most Read: 번호 타이포그래피, 블록 없음 -->
        <div>
          <div class="flex items-baseline justify-between mb-8">
            <h3 class="text-[10px] font-extrabold uppercase tracking-[0.3em] text-[var(--color-text)]">Most Read</h3>
            <span class="flex-1 ml-4 h-[1px] bg-[var(--color-outline-variant)]"></span>
          </div>
          <div class="space-y-6">
            {mostRead.map((post, idx) => (
              <a href={`${base}${lang}/blog/${post.id}/`} class="group grid grid-cols-[auto_1fr] gap-5 items-baseline cursor-pointer">
                <span class="text-3xl font-extrabold leading-none text-[var(--color-text-faint)] group-hover:text-[var(--color-text)] transition-colors tabular-nums" style="font-family: var(--font-display);">
                  {String(idx + 1).padStart(2, '0')}
                </span>
                <div class="flex-1 min-w-0">
                  <span class="text-[9px] font-extrabold uppercase tracking-[0.25em] block mb-1"
                        style={`color: ${getColor(post.data.category)};`}>
                    {categoryLabels[post.data.category] || post.data.category}
                  </span>
                  <h4 class="font-bold text-[15px] text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors leading-snug line-clamp-2" style="font-family: var(--font-display);">
                    {post.data.title}
                  </h4>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Series: 목차 톤 -->
        <div>
          <div class="flex items-baseline justify-between mb-8">
            <h3 class="text-[10px] font-extrabold uppercase tracking-[0.3em] text-[var(--color-text)]">Series Index</h3>
            <span class="flex-1 ml-4 h-[1px] bg-[var(--color-outline-variant)]"></span>
          </div>
          <div class="space-y-5">
            <a href={`${base}${lang}/blog/2024-01-15-ratb-ai-national-exam/`} class="group block">
              <div class="flex items-baseline justify-between gap-3 mb-1">
                <p class="text-base font-extrabold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors" style="font-family: var(--font-display);">RATB 운용기</p>
                <span class="text-[10px] font-bold uppercase tracking-wider text-[var(--color-text-faint)] tabular-nums">5 parts</span>
              </div>
              <p class="text-[11px] uppercase tracking-[0.2em]" style={`color: ${categoryColors.planning};`}>Planning Journal</p>
            </a>
            <a href={`${base}${lang}/blog/2026-03-23-aed-quant-tool-overview/`} class="group block">
              <div class="flex items-baseline justify-between gap-3 mb-1">
                <p class="text-base font-extrabold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors" style="font-family: var(--font-display);">퀀트 플랫폼</p>
                <span class="text-[10px] font-bold uppercase tracking-wider text-[var(--color-text-faint)] tabular-nums">7 parts</span>
              </div>
              <p class="text-[11px] uppercase tracking-[0.2em]" style={`color: ${categoryColors.project};`}>Project Chronicle</p>
            </a>
          </div>
        </div>
      </aside>

      <!-- Rest of posts: 에디토리얼 목차 스타일, 보더/박스 없음 -->
      <div class="lg:col-span-12 mt-8">
        <div class="flex items-baseline justify-between mb-14 border-t border-[var(--color-text)] pt-4">
          <h3 class="text-[10px] font-extrabold uppercase tracking-[0.3em] text-[var(--color-text)]">Archive</h3>
          <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--color-text-faint)] tabular-nums">{restPosts.length.toString().padStart(2, '0')} Entries</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-16">
          {restPosts.map((post, idx) => (
            <a href={`${base}${lang}/blog/${post.id}/`} class="group blog-post block relative" data-category={post.data.category}>
              <!-- Header line: number + category + date (typographic rule) -->
              <div class="flex items-baseline gap-4 mb-5">
                <span class="text-[11px] font-extrabold tabular-nums text-[var(--color-text-faint)] group-hover:text-[var(--color-text)] transition-colors" style="font-family: var(--font-display);">
                  {String(idx + 2).padStart(2, '0')}.
                </span>
                <span class="text-[10px] font-extrabold uppercase tracking-[0.25em]" style={`color: ${getColor(post.data.category)};`}>
                  {categoryLabels[post.data.category] || post.data.category}
                </span>
                <span class="flex-1 h-[1px] bg-[var(--color-outline-variant)] opacity-40"></span>
                <span class="text-[10px] font-bold uppercase tracking-[0.15em] text-[var(--color-text-faint)] tabular-nums">
                  {formatDate(post.data.date)}
                </span>
              </div>

              <!-- Big title, editorial -->
              <h3 class="text-2xl md:text-[28px] font-extrabold text-[var(--color-text)] leading-[1.15] tracking-tight mb-4 group-hover:text-[var(--color-accent)] transition-colors max-w-[22ch]" style="font-family: var(--font-display);">
                {post.data.title}
              </h3>

              <!-- Lede italic serif -->
              <p class="text-[14px] text-[var(--color-text-muted)] leading-[1.75] line-clamp-3 italic font-serif max-w-[38ch]">
                {post.data.description}
              </p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn');
  const posts = document.querySelectorAll<HTMLElement>('.blog-post');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;

      buttons.forEach(b => {
        b.classList.remove('active', 'text-[var(--color-text)]');
        b.classList.add('text-[var(--color-text-muted)]');
      });
      btn.classList.remove('text-[var(--color-text-muted)]');
      btn.classList.add('active', 'text-[var(--color-text)]');

      posts.forEach(post => {
        if (category === 'all' || post.dataset.category === category) {
          post.style.display = '';
        } else {
          post.style.display = 'none';
        }
      });
    });
  });
</script>
