---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/translations';

const lang = 'ko';
const tr = t(lang);

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categoryLabels: Record<string, string> = {
  project: '프로젝트',
  planning: '기획',
  'deep-dive': '삽질기',
  skill: '스킬',
};

const categoryColors: Record<string, string> = {
  project: '#4f6354',   // deep sage
  planning: '#456272',  // sage blue (accent)
  'deep-dive': '#615a7d', // muted violet
  skill: '#8a6d3b',     // warm taupe
};

const getColor = (cat: string) => categoryColors[cat] || 'var(--color-accent)';

const base = import.meta.env.BASE_URL;
const featured = posts.find(p => p.data.featured) || posts[0];
const restPosts = posts.filter(p => p.id !== featured.id);
const mostRead = posts.slice(0, 3);
---

<Layout title={`${tr.blog.pageTitle} — HYEBIN.DEV`}>
  <Navbar lang={lang} client:load />

  <main class="pt-32 pb-20 px-6 md:px-12 max-w-7xl mx-auto">
    <!-- Header -->
    <header class="mb-20 flex flex-col md:flex-row md:items-end justify-between gap-8">
      <div class="max-w-2xl">
        <span class="text-xs font-bold text-[var(--color-accent)] uppercase tracking-widest mb-4 block">{tr.blog.section}</span>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-[var(--color-text)] mb-4 leading-[1.1]" style="font-family: var(--font-display);">
          {tr.blog.pageTitle}
        </h1>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
          {tr.blog.pageDescription}
        </p>
      </div>
    </header>

    <!-- Category Filter -->
    <div class="flex flex-wrap gap-3 mb-16 items-center" id="category-filters">
      <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-faint)] mr-2">필터:</span>
      <button data-category="all" class="category-btn active px-5 py-2 rounded-full bg-[var(--color-accent)] text-[var(--color-on-accent)] text-sm font-semibold transition-all">전체</button>
      {Object.entries(categoryLabels).map(([key, label]) => (
        <button data-category={key} class="category-btn px-5 py-2 rounded-full bg-[var(--color-secondary-container)] text-[var(--color-on-secondary-container)] text-sm font-semibold hover:bg-[var(--color-bg-detail)] transition-all">{label}</button>
      ))}
    </div>

    <!-- Blog Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

      <!-- Featured Post — 타이포그래피 히어로 (이미지 없음) -->
      <a href={`${base}${lang}/blog/${featured.id}/`} class="lg:col-span-8 group cursor-pointer blog-post relative overflow-hidden rounded-2xl" data-category={featured.data.category}
         style={`background-color: var(--color-bg-card); border-left: 6px solid ${getColor(featured.data.category)};`}>
        <!-- Big decorative number -->
        <div class="absolute top-6 right-8 text-[180px] sm:text-[220px] md:text-[280px] font-extrabold leading-none pointer-events-none select-none opacity-[0.05]"
             style="font-family: var(--font-display); color: var(--color-text);">
          01
        </div>

        <div class="relative z-10 p-8 md:p-14 min-h-[400px] sm:min-h-[460px] flex flex-col justify-between">
          <!-- Top meta -->
          <div class="flex items-center gap-3 mb-6">
            <span class="px-3 py-1 text-[10px] uppercase font-extrabold tracking-widest rounded-full text-white"
                  style={`background-color: ${getColor(featured.data.category)};`}>
              Featured
            </span>
            <span class="text-[10px] font-bold uppercase tracking-widest"
                  style={`color: ${getColor(featured.data.category)};`}>
              {categoryLabels[featured.data.category] || featured.data.category}
            </span>
            <span class="w-1 h-1 rounded-full bg-[var(--color-outline-variant)]"></span>
            <span class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-text-faint)]">
              {featured.data.date.toISOString().slice(0, 10)}
            </span>
          </div>

          <!-- Title + description -->
          <div class="space-y-6 max-w-2xl">
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-[var(--color-text)] leading-[1.15] tracking-tight group-hover:text-[var(--color-accent)] transition-colors"
                style="font-family: var(--font-display);">
              {featured.data.title}
            </h2>
            <p class="text-base md:text-lg text-[var(--color-text-muted)] leading-relaxed line-clamp-3">
              {featured.data.description}
            </p>
          </div>

          <!-- CTA -->
          <div class="flex items-center gap-2 mt-10 text-sm font-bold uppercase tracking-widest group-hover:gap-4 transition-all"
               style={`color: ${getColor(featured.data.category)};`}>
            <span>자세히 읽기</span>
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14m-7-7l7 7-7 7"/></svg>
          </div>
        </div>
      </a>

      <!-- Sidebar: Most Read (번호 기반, 이미지 없음) -->
      <aside class="lg:col-span-4 space-y-8">
        <div>
          <h3 class="text-sm font-bold uppercase tracking-widest text-[var(--color-text-faint)] mb-6">인기 글</h3>
          <div class="space-y-5">
            {mostRead.map((post, idx) => (
              <a href={`${base}${lang}/blog/${post.id}/`} class="group flex gap-5 cursor-pointer">
                <div class="flex-shrink-0 w-14 h-14 rounded-lg flex items-center justify-center font-extrabold text-xl"
                     style={`background-color: ${getColor(post.data.category)}15; color: ${getColor(post.data.category)}; font-family: var(--font-display);`}>
                  0{idx + 1}
                </div>
                <div class="flex-1 min-w-0">
                  <span class="text-[10px] font-bold uppercase tracking-wider block mb-1"
                        style={`color: ${getColor(post.data.category)};`}>
                    {categoryLabels[post.data.category] || post.data.category}
                  </span>
                  <h4 class="font-bold text-sm text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors leading-snug line-clamp-2">
                    {post.data.title}
                  </h4>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Series -->
        <div class="rounded-2xl bg-[var(--color-bg-card)] p-6 shadow-ambient-sm">
          <h3 class="text-sm font-bold uppercase tracking-widest text-[var(--color-text-faint)] mb-4">시리즈</h3>
          <div class="space-y-4">
            <a href={`${base}${lang}/blog/2024-01-15-ratb-ai-national-exam/`} class="group block">
              <div class="flex items-center gap-3 mb-1">
                <div class="w-2 h-2 rounded-full" style={`background-color: ${categoryColors.planning};`}></div>
                <span class="text-[10px] uppercase font-bold tracking-widest text-[var(--color-text-faint)]">기획 · 5편</span>
              </div>
              <p class="text-sm font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">RATB 운용기</p>
            </a>
            <a href={`${base}${lang}/blog/2026-03-23-aed-quant-tool-overview/`} class="group block">
              <div class="flex items-center gap-3 mb-1">
                <div class="w-2 h-2 rounded-full" style={`background-color: ${categoryColors.project};`}></div>
                <span class="text-[10px] uppercase font-bold tracking-widest text-[var(--color-text-faint)]">프로젝트 · 7편</span>
              </div>
              <p class="text-sm font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">퀀트 플랫폼</p>
            </a>
          </div>
        </div>
      </aside>

      <!-- Rest of posts: 컬러 바 + 타이포 그리드 (이미지 없음) -->
      <div class="lg:col-span-12 grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-12 mt-4">
        {restPosts.map((post) => (
          <a href={`${base}${lang}/blog/${post.id}/`} class="group blog-post relative pl-6" data-category={post.data.category}>
            <div class="absolute left-0 top-1 bottom-1 w-[3px] rounded-full transition-all group-hover:w-[5px]"
                 style={`background-color: ${getColor(post.data.category)};`}></div>
            <div class="space-y-3">
              <div class="flex items-center gap-3 text-[10px] font-bold uppercase tracking-wider">
                <span style={`color: ${getColor(post.data.category)};`}>
                  {categoryLabels[post.data.category] || post.data.category}
                </span>
                <span class="w-1 h-1 rounded-full bg-[var(--color-outline-variant)]"></span>
                <span class="text-[var(--color-text-faint)]">{post.data.date.toISOString().slice(0, 10)}</span>
              </div>
              <h3 class="text-xl md:text-2xl font-extrabold text-[var(--color-text)] leading-tight group-hover:text-[var(--color-accent)] transition-colors" style="font-family: var(--font-display);">
                {post.data.title}
              </h3>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed line-clamp-3">
                {post.data.description}
              </p>
              <div class="flex flex-wrap gap-2 pt-1">
                {post.data.tags.slice(0, 3).map((tag: string) => (
                  <span class="rounded-full bg-[var(--color-secondary-container)] px-2.5 py-0.5 text-[10px] font-medium text-[var(--color-on-secondary-container)]">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn');
  const posts = document.querySelectorAll<HTMLElement>('.blog-post');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;

      buttons.forEach(b => {
        b.classList.remove('active', 'bg-[var(--color-accent)]', 'text-[var(--color-on-accent)]');
        b.classList.add('bg-[var(--color-secondary-container)]', 'text-[var(--color-on-secondary-container)]');
      });
      btn.classList.remove('bg-[var(--color-secondary-container)]', 'text-[var(--color-on-secondary-container)]');
      btn.classList.add('active', 'bg-[var(--color-accent)]', 'text-[var(--color-on-accent)]');

      posts.forEach(post => {
        if (category === 'all' || post.dataset.category === category) {
          post.style.display = '';
        } else {
          post.style.display = 'none';
        }
      });
    });
  });
</script>
