---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer';
import BottomNav from '../../../components/BottomNav';

const lang = 'ko';
const base = import.meta.env.BASE_URL;
---

<Layout title="주주톡 — 우혜빈 포트폴리오">
  <Navbar lang={lang} client:load />

  <main class="pt-32 pb-24 px-6 max-w-7xl mx-auto space-y-32">

    <!-- Section 1: Hero -->
    <section class="relative">
      <div class="max-w-4xl space-y-8">
        <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold leading-[1.1] tracking-tight text-[var(--color-text)]" style="font-family: var(--font-display);">
          AI 하나의 의견은 <span class="italic font-extrabold text-[var(--color-accent)]">편향</span>일 수 있다는 가설에서 시작한 이야기
        </h1>
        <p class="text-lg sm:text-xl text-[var(--color-text-muted)] max-w-2xl leading-relaxed">
          6명의 전문 AI 에이전트와 4가지 투자 페르소나가 상호작용하며 객관적인 투자 인사이트를 도출합니다. 데이터 뒤에 숨겨진 진실을 찾는 여정.
        </p>
        <div class="flex gap-6">
          <div class="jt-glass p-6 rounded-2xl flex flex-col gap-1 -rotate-2 hover:rotate-0 transition-transform duration-500">
            <span class="text-xs uppercase tracking-widest text-[var(--color-text-muted)]">Line of Code</span>
            <span class="text-3xl font-extrabold text-[var(--color-accent)]" style="font-family: var(--font-display);">31K+</span>
          </div>
          <div class="jt-glass p-6 rounded-2xl flex flex-col gap-1 rotate-3 hover:rotate-0 transition-transform duration-500">
            <span class="text-xs uppercase tracking-widest text-[var(--color-text-muted)]">Unit Tests</span>
            <span class="text-3xl font-extrabold" style="font-family: var(--font-display); color: #4f6354;">147</span>
          </div>
        </div>
      </div>
      <!-- Decorative background -->
      <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full -z-10" style="background-color: rgba(69, 98, 114, 0.05); filter: blur(120px);"></div>
      <div class="absolute top-48 left-1/2 w-64 h-64 rounded-full -z-10" style="background-color: rgba(79, 99, 84, 0.05); filter: blur(100px);"></div>
    </section>

    <!-- Section 2: Impact Metrics -->
    <section class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
      <div class="space-y-2 p-6 md:p-8 jt-glass rounded-[2rem]">
        <div class="text-4xl md:text-5xl font-extrabold" style="font-family: var(--font-display); color: #4f6354;">6</div>
        <div class="text-xs uppercase tracking-widest text-[var(--color-text-muted)]">Specialized Agents</div>
      </div>
      <div class="space-y-2 p-6 md:p-8 jt-glass rounded-[2rem] md:translate-y-4">
        <div class="text-4xl md:text-5xl font-extrabold" style="font-family: var(--font-display); color: #615a7d;">4</div>
        <div class="text-xs uppercase tracking-widest text-[var(--color-text-muted)]">Unique Personas</div>
      </div>
      <div class="space-y-2 p-6 md:p-8 jt-glass rounded-[2rem]">
        <div class="text-4xl md:text-5xl font-extrabold text-[var(--color-accent)]" style="font-family: var(--font-display); text-shadow: 0 0 20px rgba(69, 98, 114, 0.2);">3</div>
        <div class="text-xs uppercase tracking-widest text-[var(--color-text-muted)]">Round Debates</div>
      </div>
      <div class="space-y-2 p-6 md:p-8 jt-glass rounded-[2rem] md:translate-y-4">
        <div class="text-4xl md:text-5xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">147</div>
        <div class="text-xs uppercase tracking-widest text-[var(--color-text-muted)]">Test Cases</div>
      </div>
    </section>

    <!-- Section 3: Problem Definition -->
    <section class="space-y-16">
      <div class="text-center max-w-2xl mx-auto space-y-4">
        <h2 class="text-3xl md:text-4xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">단일 AI 의견의 객관성 착시</h2>
        <p class="text-[var(--color-text-muted)]">하나의 모델이 내놓는 확신은 때로 가장 위험한 신호가 됩니다.</p>
      </div>
      <div class="relative py-12 flex justify-center items-center overflow-hidden">
        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12 relative z-10">
          <div class="jt-glass px-8 md:px-10 py-10 md:py-12 rounded-[2.5rem] text-center bg-white">
            <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="mx-auto mb-4 text-[var(--color-accent)]/40"><path d="M12 4v1m6.364 1.636l-.707.707M21 12h-1m-1.636 6.364l-.707-.707M12 20v-1m-6.364-1.636l.707-.707M3 12h1m1.636-6.364l.707.707M12 8a4 4 0 100 8 4 4 0 000-8z"/></svg>
            <p class="uppercase text-xs tracking-tighter text-[var(--color-text-muted)] font-bold">Single AI</p>
          </div>
          <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-text-muted)]/30 rotate-90 md:rotate-0"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          <div class="jt-glass px-8 md:px-10 py-10 md:py-12 rounded-[2.5rem] text-center" style="background-color: #f2f3f7;">
            <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="mx-auto mb-4 text-[var(--color-text-muted)]/40"><path d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
            <p class="uppercase text-xs tracking-tighter text-[var(--color-text-muted)] font-bold">Narrow View</p>
          </div>
          <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-text-muted)]/30 rotate-90 md:rotate-0"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          <div class="px-8 md:px-10 py-10 md:py-12 rounded-[2.5rem] text-center" style="background-color: rgba(179, 38, 30, 0.05); box-shadow: 0 10px 40px -10px rgba(0,0,0,0.05);">
            <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="mx-auto mb-4" style="color: #b3261e;"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            <p class="uppercase text-xs tracking-tighter font-bold" style="color: #b3261e;">Hidden Bias</p>
          </div>
        </div>
        <div class="absolute inset-0 flex items-center justify-center opacity-10 pointer-events-none">
          <div class="w-full h-[2px]" style="background: linear-gradient(to right, transparent, #b3261e, transparent);"></div>
        </div>
      </div>
    </section>

    <!-- Section 4: Research Insight -->
    <section class="jt-asymmetric-grid items-center">
      <div class="space-y-12">
        <h2 class="text-3xl md:text-4xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">The Empathy Paradox</h2>
        <div class="space-y-8">
          <div class="relative pl-8">
            <div class="absolute left-0 top-0 bottom-0 w-[4px] rounded-full" style="background-color: #e0e2ec;"></div>
            <p class="text-sm uppercase tracking-widest text-[var(--color-text-muted)] mb-2 font-bold">What they said</p>
            <p class="text-xl md:text-2xl text-[var(--color-text-muted)] italic">"빠르고 명확한 하나의 결론을 원해요."</p>
          </div>
          <div class="relative pl-8">
            <div class="absolute left-0 top-0 bottom-0 w-[4px] rounded-full bg-[var(--color-accent)]"></div>
            <p class="text-sm uppercase tracking-widest text-[var(--color-accent)] mb-2 font-bold">What they needed</p>
            <p class="text-2xl md:text-3xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">"내 판단을 확신할 수 있는 논리적 충돌의 과정이 필요합니다."</p>
          </div>
        </div>
      </div>
      <div class="relative h-96 rounded-[3rem] overflow-hidden" style="box-shadow: 0 10px 40px -10px rgba(0,0,0,0.05);">
        <img alt="Abstract data visual" class="w-full h-full object-cover grayscale opacity-30" src={`${base}assets/landing/jujutok/paradox-visual.jpg`}/>
        <div class="absolute inset-0" style="background: linear-gradient(to top right, var(--color-bg), transparent, transparent);"></div>
      </div>
    </section>

    <!-- Section 5: Technical Decision -->
    <section class="space-y-12 p-8 md:p-12 rounded-[3rem]" style="background-color: #f2f3f7; box-shadow: 0 10px 40px -10px rgba(0,0,0,0.05);">
      <div class="flex flex-col md:flex-row gap-12">
        <div class="w-full md:w-1/2 space-y-6">
          <h2 class="text-3xl md:text-4xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">Parallel Multi-Agent Architecture</h2>
          <p class="text-[var(--color-text-muted)] leading-relaxed">
            하나의 명령어가 6개의 전문 도메인(거시경제, 기술적 분석, 공시, 뉴스, 재무, 온체인)으로 분산되어 동시에 분석을 시작합니다. 이후 4명의 가상 투자자들이 이 데이터를 바탕으로 실전 토론을 벌여 최종 인사이트를 정제합니다.
          </p>
          <div class="flex flex-wrap gap-4">
            <span class="px-4 py-2 jt-glass rounded-full text-xs font-bold text-[var(--color-accent)]">Parallel Processing</span>
            <span class="px-4 py-2 jt-glass rounded-full text-xs font-bold" style="color: #4f6354;">3-Round Debate</span>
            <span class="px-4 py-2 jt-glass rounded-full text-xs font-bold" style="color: #615a7d;">SSE Streaming</span>
          </div>
        </div>
        <div class="w-full md:w-1/2 rounded-2xl overflow-hidden bg-white shadow-xl p-6 md:p-8 font-mono text-xs md:text-sm text-[var(--color-text-muted)] leading-relaxed">
          <div class="flex gap-2 mb-6">
            <div class="w-3 h-3 rounded-full" style="background-color: rgba(179, 38, 30, 0.2);"></div>
            <div class="w-3 h-3 rounded-full" style="background-color: rgba(79, 99, 84, 0.2);"></div>
            <div class="w-3 h-3 rounded-full" style="background-color: rgba(69, 98, 114, 0.2);"></div>
          </div>
          <pre><code><span class="text-[var(--color-accent)] font-bold">async function</span> <span style="color:#4f6354;">startDebate</span>(topic) &#123;
  <span style="color:#615a7d;">const</span> agents = <span class="text-[var(--color-accent)]">await</span> AgentPool.init(6);
  <span style="color:#615a7d;">const</span> rawData = <span class="text-[var(--color-accent)]">await</span> Promise.all(
    agents.map(a =&gt; a.analyze(topic))
  );

  <span class="italic text-slate-400">// Start 3-round persona synthesis</span>
  <span style="color:#615a7d;">for</span> (let r = 0; r &lt; 3; r++) &#123;
    <span class="text-[var(--color-accent)]">await</span> supervisor.mediate(rawData);
  &#125;
  <span class="text-[var(--color-accent)]">return</span> supervisor.getConsensus();
&#125;</code></pre>
        </div>
      </div>
    </section>

    <!-- Section 6: System Workflow -->
    <section class="space-y-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-center text-[var(--color-text)]" style="font-family: var(--font-display);">System Workflow</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 relative">
        <div class="absolute top-1/2 left-0 right-0 h-[2px] -z-10 hidden md:block" style="background-color: rgba(224, 226, 236, 0.3);"></div>
        {[
          { num: '6 Agents', label: 'Parallel Extraction', icon: 'M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z', color: 'accent' },
          { num: '4 Personas', label: 'Sequential Debate', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z', color: 'sage' },
          { num: 'SSE Stream', label: 'Real-time Delivery', icon: 'M13 10V3L4 14h7v7l9-11h-7z', color: 'tertiary' },
          { num: 'Supervisor', label: 'Final Synthesis', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', color: 'accent' },
        ].map((item) => (
          <div class="jt-glass p-6 md:p-8 rounded-[2rem] text-center space-y-4 hover:bg-white transition-all group">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto group-hover:scale-110 transition-transform"
                 style={`background-color: ${item.color === 'accent' ? 'rgba(69, 98, 114, 0.1)' : item.color === 'sage' ? 'rgba(79, 99, 84, 0.1)' : 'rgba(97, 90, 125, 0.1)'}; color: ${item.color === 'accent' ? '#456272' : item.color === 'sage' ? '#4f6354' : '#615a7d'};`}>
              <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d={item.icon}/>
              </svg>
            </div>
            <h3 class="font-extrabold text-base md:text-lg text-[var(--color-text)]" style="font-family: var(--font-display);">{item.num}</h3>
            <p class="text-[10px] md:text-xs text-[var(--color-text-muted)] uppercase font-bold tracking-wider">{item.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Section 7: Transformation + Testimonial -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div class="space-y-8">
        <h2 class="text-3xl md:text-4xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">The Transformation</h2>
        <div class="space-y-4">
          <div class="p-6 rounded-2xl flex items-center justify-between opacity-60" style="background-color: #f2f3f7;">
            <div class="flex items-center gap-4">
              <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color: rgba(179, 38, 30, 0.6);"><path d="M6 18L18 6M6 6l12 12"/></svg>
              <span class="text-[var(--color-text-muted)]">Single Answer</span>
            </div>
            <span class="text-xs text-[var(--color-text-muted)] uppercase tracking-widest">Static</span>
          </div>
          <div class="p-8 rounded-[2.5rem] bg-white flex items-center justify-between" style="box-shadow: 0 10px 40px -10px rgba(0,0,0,0.05);">
            <div class="flex items-center gap-4">
              <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><path d="M12 0a12 12 0 100 24 12 12 0 000-24zm5.28 10.22l-6 6a1.5 1.5 0 01-2.12 0l-3-3a1.5 1.5 0 012.12-2.12L10.5 12.88l4.94-4.94a1.5 1.5 0 012.12 2.12l-.28.16z"/></svg>
              <span class="font-extrabold text-lg text-[var(--color-accent)]" style="font-family: var(--font-display);">Debate &amp; Synthesis</span>
            </div>
            <span class="text-xs text-[var(--color-accent)] font-bold uppercase tracking-widest">Dynamic</span>
          </div>
        </div>
      </div>
      <div class="jt-glass p-10 md:p-12 rounded-[3rem] flex flex-col justify-center space-y-8" style="background-color: rgba(255, 255, 255, 0.4);">
        <svg width="60" height="60" fill="currentColor" viewBox="0 0 24 24" class="text-[var(--color-accent)]/20">
          <path d="M14.017 21v-7.391C14.017 9.488 16.97 6 21 6v2c-2.968 0-5.5 2.6-5.5 5.5h5.5V21h-6.983zm-12 0v-7.391C2.017 9.488 4.97 6 9 6v2c-2.968 0-5.5 2.6-5.5 5.5H9V21H2.017z"/>
        </svg>
        <p class="text-xl md:text-2xl leading-relaxed text-[var(--color-text)] italic">
          "I don't just trust AI, <span class="text-[var(--color-accent)] font-bold not-italic">I understand it.</span> JujuTok provides the 'why' behind the 'what'."
        </p>
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-full overflow-hidden" style="background-color: rgba(69, 98, 114, 0.1);">
            <img alt="User avatar" src={`${base}assets/landing/jujutok/user-avatar.jpg`} class="w-full h-full object-cover"/>
          </div>
          <div>
            <p class="font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">Dong-woo Kim</p>
            <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-widest">Lead Quant Researcher</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 8: Next Steps -->
    <section class="jt-glass p-10 md:p-16 rounded-[4rem] text-center space-y-12 relative overflow-hidden" style="background-color: #f2f3f7;">
      <div class="absolute -bottom-24 -left-24 w-64 h-64 rounded-full" style="background-color: rgba(69, 98, 114, 0.05); filter: blur(100px);"></div>
      <div class="max-w-2xl mx-auto space-y-6 relative z-10">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">Next Steps</h2>
        <p class="text-[var(--color-text-muted)]">우리는 멈추지 않습니다. 더 정교한 분석을 위한 다음 목표.</p>
      </div>
      <div class="flex flex-col md:flex-row justify-center gap-8 relative z-10">
        <div class="p-8 rounded-3xl space-y-4 flex-1 hover:-translate-y-1 transition-transform" style="background-color: rgba(255, 255, 255, 0.6); box-shadow: 0 10px 40px -10px rgba(0,0,0,0.05);">
          <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color: #4f6354;"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          <h4 class="font-extrabold text-xl text-[var(--color-text)]" style="font-family: var(--font-display);">Real-time Data</h4>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">초단위 시장 데이터 연동을 통한 실시간 에이전트 브리핑</p>
        </div>
        <div class="p-8 rounded-3xl space-y-4 flex-1 hover:-translate-y-1 transition-transform" style="background-color: rgba(255, 255, 255, 0.6); box-shadow: 0 10px 40px -10px rgba(0,0,0,0.05);">
          <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color: #615a7d;"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          <h4 class="font-extrabold text-xl text-[var(--color-text)]" style="font-family: var(--font-display);">Persona Custom</h4>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">사용자의 투자 성향을 학습한 맞춤형 페르소나 생성</p>
        </div>
      </div>
      <div class="pt-8 relative z-10">
        <a href={`${base}${lang}/#contact`} class="inline-block bg-[var(--color-accent)] text-[var(--color-on-accent)] px-12 py-4 rounded-full font-extrabold text-lg shadow-xl hover:shadow-2xl hover:scale-105 active:scale-95 transition-all duration-300" style="font-family: var(--font-display);">
          Launch Alpha Now
        </a>
      </div>
    </section>
  </main>

  <Footer />
  <BottomNav lang={lang} client:load />
</Layout>

<style is:global>
  .jt-glass {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 8px 32px rgba(69, 98, 114, 0.08);
  }
  .jt-asymmetric-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2rem;
  }
  @media (max-width: 768px) {
    .jt-asymmetric-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
