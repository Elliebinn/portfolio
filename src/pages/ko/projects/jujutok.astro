---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer';
import BottomNav from '../../../components/BottomNav';

const lang = 'ko';
const base = import.meta.env.BASE_URL;
---

<Layout title="주주톡 — 우혜빈 포트폴리오">
  <Navbar lang={lang} client:load />

  <main class="pt-24">
    <!-- Hero -->
    <section class="relative min-h-[870px] flex items-center px-6 md:px-8 max-w-7xl mx-auto overflow-hidden">
      <div class="grid lg:grid-cols-2 gap-12 items-center z-10">
        <div class="space-y-8 opacity-0 animate-fade-up" style="animation-delay: 0.1s;">
          <h1 class="text-4xl sm:text-5xl lg:text-7xl font-extrabold text-[var(--color-text)] leading-[1.1] tracking-tight" style="font-family: var(--font-display);">
            AI 하나의 답은<br/>
            <span class="text-[var(--color-accent)] italic">편향</span>일 수 있다
          </h1>
          <p class="text-lg text-[var(--color-text-muted)] max-w-lg leading-relaxed">
            모든 AI 분석이 "객관적인 답"을 내놓지만, 그 뒤에는 학습 데이터의 편향이 숨어 있어요. 이 문제를 시스템 구조로 해결하기 위해, 6개 에이전트가 분석하고 4명 페르소나가 토론하는 플랫폼을 1인 기획·개발했어요.
          </p>
          <div class="flex gap-4 flex-wrap">
            <span class="px-4 py-2 rounded-full text-sm font-semibold tracking-wide" style="background-color: #d3e4fe; color: #435368;">AI AGENT DESIGN</span>
            <span class="px-4 py-2 rounded-full text-sm font-semibold tracking-wide" style="background-color: #d3e4fe; color: #435368;">BIAS MITIGATION</span>
          </div>
        </div>
        <div class="relative opacity-0 animate-fade-up" style="animation-delay: 0.3s;">
          <div class="bg-[var(--color-bg-card)] rounded-xl overflow-hidden shadow-ambient aspect-video relative">
            <img class="w-full h-full object-cover" alt="주주톡 토론 UI" src={`${base}assets/landing/project-jujutok.jpg`}/>
            <div class="absolute top-6 right-6 p-6 rounded-xl shadow-ambient glass">
              <div class="flex items-center gap-3">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-[var(--color-accent)]">
                  <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-accent)]">System</p>
                  <p class="text-lg font-extrabold text-[var(--color-text)]">6 Agents · 4 Personas</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Impact Metrics -->
    <section class="py-24" style="background-color: var(--color-bg-secondary);">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
          {[
            { value: '6개', label: 'AI 에이전트', sub: '병렬 분석' },
            { value: '4명', label: '투자 페르소나', sub: '3라운드 토론' },
            { value: '9회', label: 'LLM 호출', sub: '토론당 평균' },
            { value: '1개월', label: '1인 풀스택', sub: '기획 → 배포' },
          ].map((metric) => (
            <div class="bg-[var(--color-bg-card)] p-6 md:p-10 rounded-xl transition-shadow hover:shadow-ambient shadow-ambient-sm">
              <p class="text-3xl md:text-4xl font-extrabold text-[var(--color-accent)] mb-2" style="font-family: var(--font-display);">{metric.value}</p>
              <p class="text-[0.7rem] uppercase font-bold tracking-widest text-[var(--color-text-muted)]">{metric.label}</p>
              <p class="text-[0.75rem] text-[var(--color-text-faint)] mt-2">{metric.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 01. Problem Definition -->
    <section class="py-32 px-6 md:px-8 max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">
        <div class="space-y-6">
          <p class="text-[var(--color-accent)] font-bold tracking-widest text-sm uppercase">01. Problem Definition</p>
          <h2 class="text-3xl md:text-4xl font-extrabold leading-tight text-[var(--color-text)]" style="font-family: var(--font-display);">
            단일 AI 의견의<br/>객관성 착시
          </h2>
          <div class="space-y-4 text-[var(--color-text-muted)] text-lg leading-relaxed">
            <p>모든 증권사와 AI 분석 서비스가 "단일 관점 분석"을 제공해요. 강세론자는 항상 사라 하고, 약세론자는 항상 팔라 하죠.</p>
            <p>하나의 AI가 내놓는 "객관적인" 분석 뒤에는 <span class="text-[var(--color-text)] font-semibold">학습 데이터의 편향과 프롬프트 설계자의 관점</span>이 숨어 있어요. 투자자는 그 편향을 감지하지 못한 채 결정을 내립니다.</p>
            <p>이건 단순한 UX 문제가 아니라, <span class="text-[var(--color-text)] font-semibold">금융 의사결정의 구조적 결함</span>이었어요.</p>
          </div>
        </div>
        <div class="p-12 rounded-xl relative" style="background-color: var(--color-bg-secondary);">
          <div class="relative z-10">
            <h3 class="text-sm font-bold uppercase tracking-widest text-[var(--color-text-muted)] mb-8 text-center">Single AI Pipeline</h3>
            <div class="space-y-4">
              <div class="flex items-center justify-between gap-2">
                <div class="px-3 py-3 rounded text-xs font-mono text-center flex-1" style="background-color: var(--color-bg-detail); color: var(--color-text);">Training Data</div>
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-text-faint)] flex-shrink-0"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                <div class="px-3 py-3 rounded text-xs font-mono text-center flex-1" style="background-color: rgba(159, 64, 61, 0.1); border: 1px solid rgba(159, 64, 61, 0.3); color: #752121;">Hidden Bias</div>
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-text-faint)] flex-shrink-0"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                <div class="px-3 py-3 rounded text-xs font-mono text-center flex-1" style="background-color: var(--color-bg-detail); color: var(--color-text);">One Answer</div>
              </div>
              <div class="h-16 w-[2px] mx-auto" style="background-color: rgba(113, 124, 130, 0.3);"></div>
              <div class="text-center italic text-sm text-[var(--color-text-muted)]">검증 불가능한 "객관성"</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 02. Research Insight -->
    <section class="py-32" style="background-color: var(--color-bg);">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <div class="mb-16">
          <p class="text-[var(--color-accent)] font-bold tracking-widest text-sm uppercase mb-4">02. Research Insight</p>
          <h2 class="text-3xl md:text-4xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">Cognitive Shift</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="p-10 md:p-12 rounded-xl flex flex-col justify-between" style="background-color: var(--color-bg-secondary);">
            <div>
              <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-outline)] mb-6">
                <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              <p class="text-sm font-bold uppercase tracking-widest text-[var(--color-text-muted)] mb-4">What investors said</p>
              <p class="text-xl md:text-2xl font-semibold leading-snug text-[var(--color-text)]">"AI 분석 리포트가 너무 많은데, 뭘 믿어야 할지 모르겠어요."</p>
            </div>
            <div class="mt-12 pt-8">
              <p class="text-sm text-[var(--color-text-muted)] font-medium">Focus: Information Overload</p>
            </div>
          </div>
          <div class="p-10 md:p-12 rounded-xl flex flex-col justify-between shadow-ambient" style="background-color: var(--color-accent); color: var(--color-on-accent);">
            <div>
              <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="mb-6">
                <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
              </svg>
              <p class="text-sm font-bold uppercase tracking-widest opacity-70 mb-4">What they needed</p>
              <p class="text-xl md:text-2xl font-semibold leading-snug">AI 하나의 답이 아니라, '왜 이 결론에 도달했는지'를 투명하게 보여주는 구조</p>
            </div>
            <div class="mt-12 pt-8">
              <p class="text-sm font-medium opacity-70">Focus: Transparent Debate Structure</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 03. Technical Decision -->
    <section class="py-32 px-6 md:px-8 max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div class="order-2 lg:order-1 rounded-xl overflow-hidden shadow-ambient" style="background-color: #0f172a;">
          <div class="px-6 py-3 flex items-center gap-2" style="background-color: #1e293b;">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full" style="background-color: #f43f5e;"></div>
              <div class="w-3 h-3 rounded-full" style="background-color: #f59e0b;"></div>
              <div class="w-3 h-3 rounded-full" style="background-color: #10b981;"></div>
            </div>
            <span class="ml-4 text-xs font-mono" style="color: #94a3b8;">pipeline.ts</span>
          </div>
          <div class="p-6 md:p-8 font-mono text-sm leading-relaxed overflow-x-auto">
            <pre style="color: #cbd5e1;"><code><span style="color:#c084fc;">interface</span> <span style="color:#93c5fd;">Agent</span> &#123;
  name: <span style="color:#6ee7b7;">'Technical' | 'Fundamental'</span>
      | <span style="color:#6ee7b7;">'Macro' | 'News'</span>
      | <span style="color:#6ee7b7;">'Commodity' | 'Related'</span>;
  analyze: (ticker: <span style="color:#fcd34d;">string</span>) =&gt; <span style="color:#fcd34d;">Analysis</span>;
&#125;

<span style="color:#c084fc;">interface</span> <span style="color:#93c5fd;">Persona</span> &#123;
  role: <span style="color:#6ee7b7;">'Trader' | 'Value'</span>
      | <span style="color:#6ee7b7;">'Growth' | 'Risk'</span>;
  debate: (input: <span style="color:#fcd34d;">Analysis</span>[]) =&gt; <span style="color:#fcd34d;">Verdict</span>;
&#125;

<span style="color:#c084fc;">const</span> pipeline = agents.<span style="color:#93c5fd;">parallel</span>()
  .<span style="color:#93c5fd;">then</span>(personas.<span style="color:#93c5fd;">debate</span>(&#123; rounds: <span style="color:#fcd34d;">3</span> &#125;))
  .<span style="color:#93c5fd;">then</span>(supervisor.<span style="color:#93c5fd;">synthesize</span>);</code></pre>
          </div>
        </div>
        <div class="order-1 lg:order-2 space-y-8">
          <p class="text-[var(--color-accent)] font-bold tracking-widest text-sm uppercase">03. Technical Decision</p>
          <h2 class="text-3xl md:text-4xl font-extrabold leading-tight text-[var(--color-text)]" style="font-family: var(--font-display);">
            편향을 구조로 상쇄하는<br/>3단 파이프라인
          </h2>
          <p class="text-[var(--color-text-muted)] text-lg leading-relaxed">
            6개 에이전트가 서로 다른 축에서 병렬 분석하고(커버리지), 4명 페르소나가 3라운드 토론하며(편향 상쇄), 수퍼바이저가 최종 합의를 도출해요(일관성). 각 단계마다 근거를 기록해서 사용자가 "왜 이 결론인가"를 역추적할 수 있어요.
          </p>
          <div class="grid grid-cols-2 gap-6">
            <div class="space-y-2">
              <p class="text-[var(--color-accent)] font-bold">Parallel Coverage</p>
              <p class="text-sm text-[var(--color-text-muted)]">6개 에이전트 동시 실행, SSE 스트리밍으로 실시간 반영</p>
            </div>
            <div class="space-y-2">
              <p class="text-[var(--color-accent)] font-bold">Debate Rounds</p>
              <p class="text-sm text-[var(--color-text-muted)]">의견 → 반박 → 종합, 각 라운드에서 페르소나 교차 검증</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 04. Multi-Agent Architecture -->
    <section class="py-32" style="background-color: var(--color-bg-secondary);">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <div class="text-center max-w-2xl mx-auto mb-20">
          <p class="text-[var(--color-accent)] font-bold tracking-widest text-sm uppercase mb-4">04. Architecture</p>
          <h2 class="text-3xl md:text-4xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">Multi-Agent Pipeline</h2>
          <p class="mt-4 text-[var(--color-text-muted)]">각 레이어가 독립적이면서도 서로 검증하는 구조. 편향을 감지하고 상쇄하는 걸 시스템 설계로 해결했어요.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="bg-[var(--color-bg-card)] p-8 rounded-xl space-y-4">
            <p class="text-xs font-bold uppercase tracking-widest opacity-50 text-[var(--color-text)]">Layer 1</p>
            <p class="text-2xl font-extrabold text-[var(--color-accent)]" style="font-family: var(--font-display);">6 Agents</p>
            <p class="text-sm text-[var(--color-text-muted)]">Technical, Fundamental, Macro, News, Commodity, Related — 병렬 분석</p>
          </div>
          <div class="bg-[var(--color-bg-card)] p-8 rounded-xl space-y-4">
            <p class="text-xs font-bold uppercase tracking-widest opacity-50 text-[var(--color-text)]">Layer 2</p>
            <p class="text-2xl font-extrabold text-[var(--color-accent)]" style="font-family: var(--font-display);">4 Personas</p>
            <p class="text-sm text-[var(--color-text-muted)]">Trader, Value, Growth, Risk — 3라운드 토론 (의견→반박→종합)</p>
          </div>
          <div class="bg-[var(--color-bg-card)] p-8 rounded-xl space-y-4">
            <p class="text-xs font-bold uppercase tracking-widest opacity-50 text-[var(--color-text)]">Layer 3</p>
            <p class="text-2xl font-extrabold text-[var(--color-accent)]" style="font-family: var(--font-display);">Supervisor</p>
            <p class="text-sm text-[var(--color-text-muted)]">전체 결과를 종합해서 최종 Verdict + Confidence Score 산출</p>
          </div>
          <div class="bg-[var(--color-bg-card)] p-8 rounded-xl space-y-4">
            <p class="text-xs font-bold uppercase tracking-widest opacity-50 text-[var(--color-text)]">Streaming</p>
            <p class="text-2xl font-extrabold text-[var(--color-accent)]" style="font-family: var(--font-display);">SSE Realtime</p>
            <p class="text-sm text-[var(--color-text-muted)]">분석 진행을 실시간으로 스트리밍, 사용자가 과정을 관찰</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 05. Transformation -->
    <section class="py-32 px-6 md:px-8 max-w-7xl mx-auto">
      <div class="mb-16">
        <p class="text-[var(--color-accent)] font-bold tracking-widest text-sm uppercase mb-4">05. Transformation</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">From Opinion to Verdict</h2>
      </div>
      <div class="grid lg:grid-cols-2 gap-12 mb-20">
        <div class="space-y-6">
          <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)]">기존 AI 분석 서비스</p>
          <div class="bg-[var(--color-bg-secondary)] rounded-xl p-8">
            <div class="space-y-3">
              <div class="flex items-center gap-3">
                <span class="w-2 h-2 rounded-full" style="background-color: #9f403d;"></span>
                <p class="text-sm text-[var(--color-text-muted)]">단일 AI 출력</p>
              </div>
              <p class="text-2xl font-semibold text-[var(--color-text)]" style="font-family: var(--font-display);">"매수 추천"</p>
              <div class="pt-4 mt-4" style="border-top: 1px solid var(--color-bg-detail);">
                <p class="text-xs text-[var(--color-text-faint)] italic mb-1">← 왜 매수인지 근거가 불투명</p>
                <p class="text-xs text-[var(--color-text-faint)] italic mb-1">← 편향 감지 불가능</p>
                <p class="text-xs text-[var(--color-text-faint)] italic">← 반대 의견 없음</p>
              </div>
            </div>
          </div>
        </div>
        <div class="space-y-6">
          <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-accent)]">주주톡 멀티에이전트</p>
          <div class="rounded-xl p-8 shadow-ambient" style="background-color: var(--color-bg-card);">
            <div class="space-y-3">
              <div class="flex items-center gap-3">
                <span class="w-2 h-2 rounded-full bg-[var(--color-accent)]"></span>
                <p class="text-sm text-[var(--color-text-muted)]">6 에이전트 + 4 페르소나 토론</p>
              </div>
              <p class="text-2xl font-semibold text-[var(--color-text)]" style="font-family: var(--font-display);">"매수 (신뢰도 72%)"</p>
              <div class="pt-4 mt-4" style="border-top: 1px solid var(--color-bg-detail);">
                <p class="text-xs text-[var(--color-accent)] mb-1">→ 6개 에이전트가 각각 근거 제시</p>
                <p class="text-xs text-[var(--color-accent)] mb-1">→ 4명 페르소나가 교차 검증</p>
                <p class="text-xs text-[var(--color-accent)]">→ 반대 의견도 함께 표시</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="p-10 md:p-12 rounded-2xl relative" style="background-color: var(--color-bg-detail);">
        <svg width="60" height="60" fill="currentColor" viewBox="0 0 24 24" class="absolute top-8 left-8 opacity-20 text-[var(--color-accent)]">
          <path d="M14.017 21v-7.391C14.017 9.488 16.97 6 21 6v2c-2.968 0-5.5 2.6-5.5 5.5h5.5V21h-6.983zm-12 0v-7.391C2.017 9.488 4.97 6 9 6v2c-2.968 0-5.5 2.6-5.5 5.5H9V21H2.017z"/>
        </svg>
        <div class="relative z-10 max-w-3xl mx-auto text-center">
          <p class="text-xl md:text-2xl font-semibold italic text-[var(--color-text)] leading-relaxed mb-8">
            "AI를 의심하지 않아도 되는 게 아니라,<br/>AI를 의심하는 AI를 만들어야 한다는 걸 배웠어요."
          </p>
          <div class="space-y-1">
            <p class="font-bold text-[var(--color-text)]">프로젝트 회고</p>
            <p class="text-sm text-[var(--color-text-muted)] uppercase tracking-widest">우혜빈, 2026</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 06. Next Steps -->
    <section class="py-32" style="background-color: var(--color-bg-secondary);">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <div class="flex flex-col md:flex-row justify-between items-end gap-8 mb-16">
          <div class="max-w-xl">
            <p class="text-[var(--color-accent)] font-bold tracking-widest text-sm uppercase mb-4">06. Next Steps</p>
            <h2 class="text-3xl md:text-4xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">Forward-Looking Roadmap</h2>
          </div>
