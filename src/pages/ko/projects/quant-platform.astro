---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer';
import BottomNav from '../../../components/BottomNav';

const lang = 'ko';
const base = import.meta.env.BASE_URL;
---

<Layout title="퀀트 전략 분석 플랫폼 — 우혜빈 포트폴리오">
  <Navbar lang={lang} client:load />

  <main class="pt-24">
    <!-- Hero -->
    <section class="relative min-h-[870px] flex items-center px-6 md:px-8 max-w-7xl mx-auto overflow-hidden">
      <div class="grid lg:grid-cols-2 gap-12 items-center z-10">
        <div class="space-y-8 opacity-0 animate-fade-up" style="animation-delay: 0.1s;">
          <h1 class="text-4xl sm:text-5xl lg:text-7xl font-extrabold text-[var(--color-text)] leading-[1.1] tracking-tight" style="font-family: var(--font-display);">
            퀀트 리서처의 불편을<br/>
            <span class="text-[var(--color-accent)] italic">직접 고친</span> 이야기
          </h1>
          <p class="text-lg text-[var(--color-text-muted)] max-w-lg leading-relaxed">
            프론트 0명, 디자이너 0명인 6인 팀에서 리서처 4명이 매일 쓰는 200+ 전략 분석 도구를 직접 기획·설계·구현했어요. "요청된 기능"이 아니라 "실제로 필요한 구조"를 만드는 케이스 스터디.
          </p>
          <div class="flex gap-4 flex-wrap">
            <span class="px-4 py-2 rounded-full text-sm font-semibold tracking-wide" style="background-color: #d3e4fe; color: #435368;">FINTECH UX</span>
            <span class="px-4 py-2 rounded-full text-sm font-semibold tracking-wide" style="background-color: #d3e4fe; color: #435368;">SYSTEM ARCHITECTURE</span>
          </div>
        </div>
        <div class="relative opacity-0 animate-fade-up" style="animation-delay: 0.3s;">
          <div class="bg-[var(--color-bg-card)] rounded-xl overflow-hidden shadow-ambient aspect-video relative">
            <img class="w-full h-full object-cover" alt="퀀트 플랫폼 대시보드" src={`${base}assets/landing/quant/hero-v2.jpg`}/>
            <div class="absolute top-6 right-6 p-6 rounded-xl shadow-ambient glass">
              <div class="flex items-center gap-3">
                <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24" class="text-[var(--color-accent)]">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-accent)]">Status</p>
                  <p class="text-lg font-extrabold text-[var(--color-text)]">IA 재설계 100%</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Impact Metrics -->
    <section class="py-24" style="background-color: var(--color-bg-secondary);">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
          {[
            { value: '20+', label: '페이지 재설계' },
            { value: '25', label: 'HTML 목업 제작' },
            { value: '200+', label: '전략 태그 분류' },
            { value: '83%', label: '운용시간 단축' },
          ].map((metric) => (
            <div class="bg-[var(--color-bg-card)] p-6 md:p-10 rounded-xl transition-shadow hover:shadow-ambient shadow-ambient-sm">
              <p class="text-3xl md:text-4xl font-extrabold text-[var(--color-accent)] mb-2" style="font-family: var(--font-display);">{metric.value}</p>
              <p class="text-[0.7rem] uppercase font-bold tracking-widest text-[var(--color-text-muted)]">{metric.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 01. Problem Definition -->
    <section class="py-32 px-6 md:px-8 max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">
        <div class="space-y-6">
          <p class="text-[var(--color-accent)] font-bold tracking-widest text-sm uppercase">01. Problem Definition</p>
          <h2 class="text-3xl md:text-4xl font-extrabold leading-tight text-[var(--color-text)]" style="font-family: var(--font-display);">
            "검색 추가해주세요" 뒤에<br/>숨은 진짜 문제
          </h2>
          <div class="space-y-4 text-[var(--color-text-muted)] text-lg leading-relaxed">
            <p>리서처 4명이 매일 200+ 전략을 분석하는데, 계속 같은 요청이 반복됐어요 — <span class="text-[var(--color-text)] font-semibold">"검색 추가해주세요", "필터 더 만들어주세요", "날짜 선택이 불편해요".</span></p>
            <p>기능을 하나씩 추가하면 해결될 줄 알았는데, 요청이 멈추지 않았어요. 옆에 앉아서 직접 리서처의 분석 워크플로우를 관찰한 다음에야 알았어요 — <span class="text-[var(--color-text)] font-semibold">진짜 문제는 "분류 체계 부재"</span>였다는 걸요. 검색은 증상이었고, 원인은 구조였어요.</p>
          </div>
        </div>
        <div class="p-12 rounded-xl relative group" style="background-color: var(--color-bg-secondary);">
          <div class="absolute -inset-4 rounded-[2rem] blur-2xl transition-all duration-700" style="background-color: rgba(69, 98, 114, 0.05);"></div>
          <svg class="w-full relative z-10" fill="none" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
            <path d="M50 80H120M280 80H350M200 40V120M200 180V260" stroke="#456272" stroke-linecap="round" stroke-width="4"/>
            <circle cx="200" cy="150" fill="rgba(69, 98, 114, 0.1)" r="40" stroke="#456272" stroke-width="2"/>
            <rect fill="#d9e4ea" height="40" rx="4" width="120" x="140" y="70"/>
            <rect fill="#d9e4ea" height="40" rx="4" width="120" x="140" y="190"/>
            <circle cx="200" cy="150" fill="#456272" r="10"/>
            <text fill="#ffffff" style="font-family: Manrope; font-size: 8px; font-weight: bold;" text-anchor="middle" x="200" y="153">X</text>
          </svg>
          <p class="mt-8 text-center text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)]">Legacy System Bottleneck Analysis</p>
        </div>
      </div>
    </section>

    <!-- 02. Research Insight -->
    <section class="py-32" style="background-color: var(--color-bg);">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <div class="mb-16">
          <p class="text-[var(--color-accent)] font-bold tracking-widest text-sm uppercase mb-4">02. Research Insight</p>
          <h2 class="text-3xl md:text-4xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">요청 → 진짜 니즈 매핑</h2>
          <p class="text-[var(--color-text-muted)] mt-4 max-w-2xl">이전 직장에서 직접 펀드 운용을 지원한 경험을 바탕으로, 리서처가 요청한 기능이 아니라 실제로 필요한 기능을 판별했어요.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          <!-- Mapping 1 -->
          <div class="p-8 rounded-xl" style="background-color: var(--color-bg-secondary);">
            <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] mb-3">They said</p>
            <p class="text-lg font-semibold text-[var(--color-text)] mb-6">"검색 추가해주세요"</p>
            <div class="flex justify-center mb-6">
              <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><path d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            </div>
            <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-accent)] mb-3">Root cause</p>
            <p class="text-base font-semibold text-[var(--color-text)] mb-4">분류 체계 부재</p>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">200+ 전략이 분류 없이 나열됨. 검색은 증상, 태그 기반 분류가 진짜 해결책이었음.</p>
          </div>
          <!-- Mapping 2 -->
          <div class="p-8 rounded-xl" style="background-color: var(--color-bg-secondary);">
            <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] mb-3">They said</p>
            <p class="text-lg font-semibold text-[var(--color-text)] mb-6">"날짜 선택이 불편해요"</p>
            <div class="flex justify-center mb-6">
              <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><path d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            </div>
            <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-accent)] mb-3">Root cause</p>
            <p class="text-base font-semibold text-[var(--color-text)] mb-4">리밸런싱 시점 탐색 어려움</p>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">리서처는 '날짜'가 아니라 '리밸런싱 포인트'를 찾고 있었음. 포인트 기반 네비로 재설계.</p>
          </div>
          <!-- Mapping 3 -->
          <div class="p-8 rounded-xl shadow-ambient" style="background-color: var(--color-accent); color: var(--color-on-accent);">
            <p class="text-xs font-bold uppercase tracking-widest opacity-70 mb-3">They didn't say</p>
            <p class="text-lg font-semibold mb-6">(벤치마크 비교 무의미함)</p>
            <div class="flex justify-center mb-6">
              <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            </div>
            <p class="text-xs font-bold uppercase tracking-widest opacity-70 mb-3">Proactive fix</p>
            <p class="text-base font-semibold mb-4">전략별 동적 벤치마크</p>
            <p class="text-sm leading-relaxed opacity-90">한국 전략을 S&P500과 비교하는 게 무의미하다는 걸 펀드 운용 경험으로 파악. 요청 없이 선제적으로 구현.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 03. Technical Decision -->
    <section class="py-32 px-6 md:px-8 max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div class="order-2 lg:order-1 rounded-xl overflow-hidden shadow-ambient" style="background-color: #0f172a;">
          <div class="px-6 py-3 flex items-center gap-2" style="background-color: #1e293b;">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full" style="background-color: #f43f5e;"></div>
              <div class="w-3 h-3 rounded-full" style="background-color: #f59e0b;"></div>
              <div class="w-3 h-3 rounded-full" style="background-color: #10b981;"></div>
            </div>
            <span class="ml-4 text-xs font-mono" style="color: #94a3b8;">strategySchema.ts</span>
          </div>
          <div class="p-6 md:p-8 font-mono text-sm leading-relaxed overflow-x-auto">
            <pre style="color: #cbd5e1;"><code><span style="color:#c084fc;">interface</span> <span style="color:#93c5fd;">StrategyView</span> &#123;
  id: <span style="color:#fcd34d;">string</span>;
  tags: <span style="color:#fcd34d;">TagSystem</span>[];
  workflow: <span style="color:#fcd34d;">'backtest' | 'live' | 'audit'</span>;
&#125;

<span style="color:#c084fc;">const</span> <span style="color:#93c5fd;">tagSchema</span> = &#123;
  dimension: [<span style="color:#6ee7b7;">'Alpha'</span>, <span style="color:#6ee7b7;">'Risk'</span>, <span style="color:#6ee7b7;">'Beta'</span>],
  assetClass: [<span style="color:#6ee7b7;">'FX'</span>, <span style="color:#6ee7b7;">'Crypto'</span>, <span style="color:#6ee7b7;">'Equity'</span>],
  hierarchy: <span style="color:#93c5fd;">nestedTaxonomy</span>()
&#125;;</code></pre>
          </div>
        </div>
        <div class="order-1 lg:order-2 space-y-8">
          <p class="text-[var(--color-accent)] font-bold tracking-widest text-sm uppercase">03. Technical Decision</p>
          <h2 class="text-3xl md:text-4xl font-extrabold leading-tight text-[var(--color-text)]" style="font-family: var(--font-display);">
            다중 태그 시스템과<br/>워크플로우 중심 재설계
          </h2>
          <p class="text-[var(--color-text-muted)] text-lg leading-relaxed">
            단순한 리스트를 넘어, 리서처의 작업 단계(Backtest → Audit → Live)를 반영한 상태 기반 워크플로우를 도입했어요. 200개 이상의 전략을 Asset, Risk, Dimension 등 다각도에서 즉시 필터링할 수 있는 다중 태그 아키텍처를 설계했어요.
          </p>
          <div class="grid grid-cols-2 gap-6">
            <div class="space-y-2">
              <p class="text-[var(--color-accent)] font-bold">Dynamic Filter</p>
              <p class="text-sm text-[var(--color-text-muted)]">Real-time state sync across all UI components.</p>
            </div>
            <div class="space-y-2">
              <p class="text-[var(--color-accent)] font-bold">JSON Mapping</p>
              <p class="text-sm text-[var(--color-text-muted)]">Schema-driven UI generation for consistency.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 04. Design System -->
    <section class="py-32" style="background-color: var(--color-bg-secondary);">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <div class="text-center max-w-2xl mx-auto mb-20">
          <p class="text-[var(--color-accent)] font-bold tracking-widest text-sm uppercase mb-4">04. Design System</p>
          <h2 class="text-3xl md:text-4xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">The Architect's Framework</h2>
          <p class="mt-4 text-[var(--color-text-muted)]">디자이너 없이, 스케일과 일관성을 유지할 수 있도록 토큰 기반의 시스템을 구축했어요.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
          <!-- Colors -->
          <div class="bg-[var(--color-bg-card)] p-8 rounded-xl space-y-6">
            <p class="text-xs font-bold uppercase tracking-widest opacity-50 text-[var(--color-text)]">Colors</p>
            <div class="space-y-3">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg" style="background-color: #456272;"></div>
                <span class="text-xs font-mono text-[var(--color-text)]">#456272</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg" style="background-color: #d9e4ea;"></div>
                <span class="text-xs font-mono text-[var(--color-text)]">#D9E4EA</span>
              </div>
            </div>
          </div>
          <!-- Typography -->
          <div class="bg-[var(--color-bg-card)] p-8 rounded-xl space-y-6">
            <p class="text-xs font-bold uppercase tracking-widest opacity-50 text-[var(--color-text)]">Typography</p>
            <div class="space-y-2">
              <p class="text-2xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">Aa</p>
              <p class="text-xs text-[var(--color-text-muted)]">Manrope Display</p>
              <p class="text-lg font-medium text-[var(--color-text)]">Aa</p>
              <p class="text-xs text-[var(--color-text-muted)]">Body Sans</p>
            </div>
          </div>
          <!-- Spacing -->
          <div class="bg-[var(--color-bg-card)] p-8 rounded-xl space-y-6">
            <p class="text-xs font-bold uppercase tracking-widest opacity-50 text-[var(--color-text)]">Spacing</p>
            <div class="flex items-end gap-2 h-20">
              <div class="w-4 h-4 bg-[var(--color-bg-emphasis)]"></div>
              <div class="w-4 h-8 bg-[var(--color-bg-emphasis)]"></div>
              <div class="w-4 h-12 bg-[var(--color-bg-emphasis)]"></div>
              <div class="w-4 h-16 bg-[var(--color-bg-emphasis)]"></div>
            </div>
            <p class="text-xs text-[var(--color-text-muted)]">8pt Grid Logic</p>
          </div>
          <!-- Components -->
          <div class="bg-[var(--color-bg-card)] p-8 rounded-xl space-y-6">
            <p class="text-xs font-bold uppercase tracking-widest opacity-50 text-[var(--color-text)]">Components</p>
            <div class="space-y-3">
              <div class="h-8 rounded-full w-full" style="background-color: rgba(69, 98, 114, 0.1);"></div>
              <div class="h-8 rounded-md w-2/3" style="background-color: #d9e4ea;"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 05. Transformation -->
    <section class="py-32 px-6 md:px-8 max-w-7xl mx-auto">
      <div class="mb-16">
        <p class="text-[var(--color-accent)] font-bold tracking-widest text-sm uppercase mb-4">05. Transformation</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">Visual Evolution</h2>
      </div>
      <div class="grid lg:grid-cols-2 gap-12 mb-20">
        <div class="space-y-6">
          <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)]">Before</p>
          <div class="bg-[var(--color-bg-secondary)] rounded-xl overflow-hidden grayscale opacity-60">
            <img class="w-full aspect-video object-cover" alt="기존 인터페이스" src={`${base}assets/landing/quant/before-v2.jpg`}/>
          </div>
        </div>
        <div class="space-y-6">
          <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-accent)]">After</p>
          <div class="rounded-xl overflow-hidden shadow-ambient" style="background-color: rgba(69, 98, 114, 0.05);">
            <img class="w-full aspect-video object-cover" alt="새 대시보드" src={`${base}assets/landing/quant/after-v2.jpg`}/>
          </div>
        </div>
      </div>
      <div class="p-10 md:p-12 rounded-2xl relative" style="background-color: var(--color-bg-detail);">
        <svg width="60" height="60" fill="currentColor" viewBox="0 0 24 24" class="absolute top-8 left-8 opacity-20 text-[var(--color-accent)]">
          <path d="M14.017 21v-7.391C14.017 9.488 16.97 6 21 6v2c-2.968 0-5.5 2.6-5.5 5.5h5.5V21h-6.983zm-12 0v-7.391C2.017 9.488 4.97 6 9 6v2c-2.968 0-5.5 2.6-5.5 5.5H9V21H2.017z"/>
        </svg>
        <div class="relative z-10 max-w-3xl mx-auto text-center">
          <p class="text-xl md:text-2xl font-semibold italic text-[var(--color-text)] leading-relaxed mb-8">
            "이제 데이터 시각화의 흐름이 끊기지 않아요. 필요한 지표를 찾는 데 들던 에너지를 전략 최적화에만 집중할 수 있게 되었습니다."
          </p>
          <div class="space-y-1">
            <p class="font-bold text-[var(--color-text)]">Senior Quant Researcher</p>
            <p class="text-sm text-[var(--color-text-muted)] uppercase tracking-widest">Global Asset Management Firm</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 06. Next Steps -->
    <section class="py-32" style="background-color: var(--color-bg-secondary);">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <div class="flex flex-col md:flex-row justify-between items-end gap-8 mb-16">
          <div class="max-w-xl">
            <p class="text-[var(--color-accent)] font-bold tracking-widest text-sm uppercase mb-4">06. Next Steps</p>
            <h2 class="text-3xl md:text-4xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">Forward-Looking Roadmap</h2>
          </div>
          <div class="h-[2px] flex-grow mb-4 hidden md:block" style="background-color: var(--color-bg-detail);"></div>
        </div>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-[var(--color-bg-card)] p-10 md:p-12 rounded-xl group transition-colors duration-500 hover:bg-[var(--color-accent)]">
            <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)] mb-6 group-hover:text-[var(--color-on-accent)] transition-colors">
