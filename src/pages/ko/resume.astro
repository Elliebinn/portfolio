---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';

const lang = 'ko';
---

<Layout title="이력서 — 우혜빈">
  <Navbar lang={lang} client:load />

  <main class="pt-32 pb-24 px-6 md:px-12 max-w-5xl mx-auto">

    <!-- Masthead -->
    <header class="mb-16">
      <div class="flex items-baseline justify-between border-b-2 border-[var(--color-text)] pb-2 mb-8">
        <span class="text-[10px] font-extrabold uppercase tracking-[0.3em] text-[var(--color-text)]">Curriculum Vitae</span>
        <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--color-text-muted)]">2026 · AI Product Planner</span>
      </div>

      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8">
        <div>
          <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-[var(--color-text)] leading-[0.95] mb-3" style="font-family: var(--font-display);">
            우혜빈 <span class="text-[var(--color-text-faint)] font-medium">Hye Bin Woo</span>
          </h1>
          <p class="text-base font-bold uppercase tracking-[0.2em] text-[var(--color-accent)]">
            AI Product Planner · Finance Domain
          </p>
        </div>
        <div class="flex flex-col gap-1.5 text-sm text-[var(--color-text-muted)] md:text-right">
          <a href="tel:+821049991517" class="hover:text-[var(--color-accent)] transition-colors tabular-nums">010-4999-1517</a>
          <a href="mailto:elliebinn@gmail.com" class="hover:text-[var(--color-accent)] transition-colors">elliebinn@gmail.com</a>
          <a href="https://github.com/Elliebinn" target="_blank" class="hover:text-[var(--color-accent)] transition-colors">github.com/Elliebinn</a>
          <a href="https://hyebin.dev/portfolio" target="_blank" class="hover:text-[var(--color-accent)] transition-colors">hyebin.dev/portfolio</a>
        </div>
      </div>
    </header>

    <!-- Summary -->
    <section class="mb-16">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-[10px] font-extrabold uppercase tracking-[0.3em] text-[var(--color-text)]">Summary</h2>
        <span class="flex-1 ml-4 h-[1px] bg-[var(--color-text)] opacity-30"></span>
      </div>
      <p class="text-lg md:text-xl text-[var(--color-text)] leading-[1.6] max-w-3xl font-extrabold" style="font-family: var(--font-display);">
        금융 도메인을 알고, AI로 직접 만드는 서비스 기획자입니다.
      </p>
      <p class="text-[15px] text-[var(--color-text-muted)] leading-[1.8] max-w-3xl mt-4">
        에셋플러스자산운용에서 AI 공모펀드 운용지원 시스템을 기획해 매매·운용시간을 <strong class="text-[var(--color-text)]">83% 단축</strong>시켰고, 38개 AI 투자 알고리즘의 국가 심사를 통과시켰습니다. 현재는 퀀트 리서치팀이 매일 사용하는 전략 모니터링·운용 관리 대시보드를 처음부터 다시 설계하고 있으며, 화면 설계부터 AI 코딩 도구를 활용한 구현까지 직접 수행합니다. 사이드 프로젝트로 AI 멀티에이전트 주식 분석 플랫폼을 1인으로 기획·개발했습니다.
      </p>
    </section>

    <!-- Work Experience -->
    <section class="mb-16">
      <div class="flex items-baseline justify-between mb-10">
        <h2 class="text-[10px] font-extrabold uppercase tracking-[0.3em] text-[var(--color-text)]">Work Experience</h2>
        <span class="flex-1 ml-4 h-[1px] bg-[var(--color-text)] opacity-30"></span>
      </div>

      <!-- AlphaBridge -->
      <div class="mb-14">
        <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2 mb-1">
          <div>
            <h3 class="text-2xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">
              알파브릿지 <span class="text-[var(--color-text-muted)] font-bold text-lg">— AI서비스기획본부</span>
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] mt-1">에셋플러스자산운용 자회사 · 정규직</p>
          </div>
          <span class="text-xs font-bold uppercase tracking-[0.15em] text-[var(--color-accent)] tabular-nums whitespace-nowrap">2025.03 — 현재</span>
        </div>

        <!-- Project 1 -->
        <div class="mt-6 mb-6">
          <p class="text-[15px] font-extrabold text-[var(--color-text)] mb-3" style="font-family: var(--font-display);">
            전략 모니터링 · 성과 분석 · 운용 관리 대시보드 서비스 기획
          </p>
          <ul class="space-y-2.5 text-[14px] text-[var(--color-text-muted)] leading-[1.7]">
            <li class="flex gap-3">
              <span class="text-[var(--color-accent)] mt-[7px] flex-shrink-0 text-[8px]">●</span>
              <span>펀드 운용 경험을 바탕으로 사용자 요청 뒤 진짜 니즈를 파악하여 <strong class="text-[var(--color-text)]">리밸런싱 포인트 네비게이션, 태그 기반 전략 분류</strong> 등 요청에 없던 기능 선제 설계</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[var(--color-accent)] mt-[7px] flex-shrink-0 text-[8px]">●</span>
              <span><strong class="text-[var(--color-text)]">200개+ 전략 탐색 구조 재편</strong> — 태그 기반 분류 체계 설계, 사이드바 13개 메뉴를 워크플로우 기반으로 재구조화</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[var(--color-accent)] mt-[7px] flex-shrink-0 text-[8px]">●</span>
              <span>디자인 시스템 직접 구축(DESIGN.md 문서화) 후 AI 코딩 도구로 HTML 목업 25개 → 20개+ 분석 페이지 일관되게 전환</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[var(--color-accent)] mt-[7px] flex-shrink-0 text-[8px]">●</span>
              <span>외부 UX/UI 디자이너 2인 피드백(2.5/5, 3.9/5) → 7개 요구사항 분해 → Bloomberg·Morningstar 등 14개 레퍼런스 기반 개선</span>
            </li>
          </ul>
        </div>

        <!-- Project 2 -->
        <div>
          <p class="text-[15px] font-extrabold text-[var(--color-text)] mb-3" style="font-family: var(--font-display);">
            로보어드바이저 AI 알고리즘 기획 및 운용심사 수행 (RATB 22~25차)
          </p>
          <ul class="space-y-2.5 text-[14px] text-[var(--color-text-muted)] leading-[1.7]">
            <li class="flex gap-3">
              <span class="text-[var(--color-accent)] mt-[7px] flex-shrink-0 text-[8px]">●</span>
              <span><strong class="text-[var(--color-text)]">38개 AI 투자 알고리즘</strong> 기획 및 KOSCOM 로보어드바이저 테스트베드 운용심사 전 과정 주도 (PM 역할)</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[var(--color-accent)] mt-[7px] flex-shrink-0 text-[8px]">●</span>
              <span>22~24차 운용심사 전원 통과 / 최고 수익률 <strong class="text-[var(--color-text)]">1년 기준 19.5%</strong> (2024.12 기준)</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- AssetPlus -->
      <div>
        <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2 mb-1">
          <div>
            <h3 class="text-2xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">
              에셋플러스자산운용 <span class="text-[var(--color-text-muted)] font-bold text-lg">— AI자산운용팀</span>
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] mt-1">정규직</p>
          </div>
          <span class="text-xs font-bold uppercase tracking-[0.15em] text-[var(--color-accent)] tabular-nums whitespace-nowrap">2023.09 — 2025.03</span>
        </div>

        <div class="mt-6">
          <ul class="space-y-2.5 text-[14px] text-[var(--color-text-muted)] leading-[1.7]">
            <li class="flex gap-3">
              <span class="text-[var(--color-accent)] mt-[7px] flex-shrink-0 text-[8px]">●</span>
              <span><strong class="text-[var(--color-text)]">S&P500 AI 공모펀드 2건 출시</strong> (S&P 성장/배당 포커스 30) — 현재 고객 자금 운용 중</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[var(--color-accent)] mt-[7px] flex-shrink-0 text-[8px]">●</span>
              <span>AI 공모펀드 운용지원 시스템 기획 — 매매·운용시간 1시간+ → 10분 (<strong class="text-[var(--color-text)]">83% 단축</strong>). 운용역 실제 워크플로우 관찰 → 자동화/사람 판단 단계 분리 → 요건정의서 작성</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[var(--color-accent)] mt-[7px] flex-shrink-0 text-[8px]">●</span>
              <span>ETF 유니버스 분류 체계(4그룹) 설계, 투자자 성향별 배분 로직 기획</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[var(--color-accent)] mt-[7px] flex-shrink-0 text-[8px]">●</span>
              <span>ETF 기획: MartinGale 전략 AI 알고리즘화, NASDAQ/KOSPI ETF 상장 준비, 다올자산운용 MOU 체결</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Side Project -->
    <section class="mb-16">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-[10px] font-extrabold uppercase tracking-[0.3em] text-[var(--color-text)]">Side Project</h2>
        <span class="flex-1 ml-4 h-[1px] bg-[var(--color-text)] opacity-30"></span>
      </div>

      <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2 mb-4">
        <h3 class="text-2xl font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">
          주주톡 <span class="text-[var(--color-text-muted)] font-bold text-lg">— AI 주식 분석 플랫폼</span>
        </h3>
        <span class="text-xs font-bold uppercase tracking-[0.15em] text-[var(--color-accent)] whitespace-nowrap">1인 기획 · 풀스택 개발</span>
      </div>
      <p class="text-[14px] text-[var(--color-text-muted)] leading-[1.8] max-w-3xl mb-4 italic font-serif">
        "단일 AI의 편향을 시스템 구조로 해결할 수 있을까?"
      </p>
      <ul class="space-y-2.5 text-[14px] text-[var(--color-text-muted)] leading-[1.7]">
        <li class="flex gap-3">
          <span class="text-[var(--color-accent)] mt-[7px] flex-shrink-0 text-[8px]">●</span>
          <span>6개 AI 에이전트(거시/기술/공시/뉴스/재무/온체인)로 분석 축 분리, 4명 투자 페르소나(가치/성장/거시/모멘텀)가 3라운드 토론하는 구조 설계</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[var(--color-accent)] mt-[7px] flex-shrink-0 text-[8px]">●</span>
          <span>서비스 컨셉·정보구조·UX 플로우 직접 설계 후 FastAPI + React 19 + Claude API로 풀스택 구현</span>
        </li>
      </ul>
    </section>

    <!-- 2-col: Education | Certifications -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-14 mb-14">

      <!-- Education -->
      <section>
        <div class="flex items-baseline justify-between mb-6">
          <h2 class="text-[10px] font-extrabold uppercase tracking-[0.3em] text-[var(--color-text)]">Education</h2>
          <span class="flex-1 ml-4 h-[1px] bg-[var(--color-text)] opacity-30"></span>
        </div>
        <div class="space-y-5">
          <div>
            <div class="flex items-baseline justify-between gap-3 mb-1">
              <h4 class="text-base font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">Johns Hopkins University</h4>
              <span class="text-[10px] font-bold uppercase tracking-wider text-[var(--color-text-faint)] tabular-nums whitespace-nowrap">2017.08 — 2019.05</span>
            </div>
            <p class="text-sm text-[var(--color-text-muted)]">B.A. Economics · Minor in Marketing</p>
          </div>
          <div>
            <div class="flex items-baseline justify-between gap-3 mb-1">
              <h4 class="text-base font-extrabold text-[var(--color-text)]" style="font-family: var(--font-display);">Fullerton College</h4>
              <span class="text-[10px] font-bold uppercase tracking-wider text-[var(--color-text-faint)] tabular-nums whitespace-nowrap">2016.01 — 2017.05</span>
            </div>
            <p class="text-sm text-[var(--color-text-muted)]">A.A. Economics</p>
          </div>
        </div>
      </section>

      <!-- Certifications -->
      <section>
        <div class="flex items-baseline justify-between mb-6">
          <h2 class="text-[10px] font-extrabold uppercase tracking-[0.3em] text-[var(--color-text)]">Certifications</h2>
          <span class="flex-1 ml-4 h-[1px] bg-[var(--color-text)] opacity-30"></span>
        </div>
        <div class="space-y-2.5">
          {[
            { name: 'SQL 개발자 (SQLD)', date: '2026.03' },
            { name: '증권투자권유자문인력', date: '2024.05' },
            { name: '파생상품투자권유자문인력', date: '2024.02' },
            { name: '펀드투자권유자문인력', date: '2023.12' },
            { name: 'AFPK', date: '2022.04' },
            { name: '투자자산운용사', date: '2021.12' },
          ].map((cert) => (
            <div class="flex items-baseline justify-between gap-3">
              <p class="text-sm font-bold text-[var(--color-text)]">{cert.name}</p>
              <span class="text-[10px] font-bold uppercase tracking-wider text-[var(--color-text-faint)] tabular-nums whitespace-nowrap">{cert.date}</span>
            </div>
          ))}
        </div>
      </section>
    </div>

    <!-- Skills / Additional Information -->
    <section>
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-[10px] font-extrabold uppercase tracking-[0.3em] text-[var(--color-text)]">Additional Information</h2>
        <span class="flex-1 ml-4 h-[1px] bg-[var(--color-text)] opacity-30"></span>
      </div>
      <div class="space-y-4 text-[14px] leading-[1.8]">
        <div class="flex flex-col md:flex-row md:gap-6">
          <span class="text-[var(--color-accent)] font-extrabold uppercase tracking-wider text-xs md:w-36 md:flex-shrink-0 md:pt-1">기획 · UX</span>
          <span class="text-[var(--color-text-muted)]">서비스 기획 · 정보구조(IA) 설계 · UX 재설계 · 디자인 시스템 구축 · 요건정의서 작성</span>
        </div>
        <div class="flex flex-col md:flex-row md:gap-6">
          <span class="text-[var(--color-accent)] font-extrabold uppercase tracking-wider text-xs md:w-36 md:flex-shrink-0 md:pt-1">AI · 개발</span>
          <span class="text-[var(--color-text-muted)]">Claude Code · Claude API · AI 에이전트 설계 · 프롬프트 엔지니어링 · Python · FastAPI · React · TypeScript · SQL · n8n 자동화</span>
        </div>
        <div class="flex flex-col md:flex-row md:gap-6">
          <span class="text-[var(--color-accent)] font-extrabold uppercase tracking-wider text-xs md:w-36 md:flex-shrink-0 md:pt-1">데이터 · 시각화</span>
          <span class="text-[var(--color-text-muted)]">ClickHouse · MySQL · Pandas · Plotly · ECharts · Highcharts</span>
        </div>
        <div class="flex flex-col md:flex-row md:gap-6">
          <span class="text-[var(--color-accent)] font-extrabold uppercase tracking-wider text-xs md:w-36 md:flex-shrink-0 md:pt-1">언어</span>
          <span class="text-[var(--color-text-muted)]">한국어 (모국어) · 영어 (비즈니스 고급 · 미국 대학 졸업)</span>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
