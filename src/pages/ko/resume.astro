---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';

const lang = 'ko';
---

<Layout title="이력서 — 우혜빈">
  <Navbar lang={lang} client:load />

  <main class="pt-32 pb-24 px-6 md:px-12 max-w-7xl mx-auto">

    <!-- Header: 2-column (소개 + 연락처) -->
    <header class="mb-20 flex flex-col md:flex-row justify-between items-end gap-8">
      <div class="max-w-2xl">
        <span class="text-xs font-bold text-[var(--color-accent)] tracking-widest uppercase mb-4 block">Curriculum Vitae</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6 leading-[1.15] text-[var(--color-text)]" style="font-family: var(--font-display);">
          금융 도메인을 알고,<br/>
          <span class="text-[var(--color-accent)]">AI로 직접 만드는 서비스 기획자.</span>
        </h1>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
          에셋플러스자산운용에서 AI 공모펀드 운용지원 시스템을 기획해 매매·운용시간을 <strong class="text-[var(--color-text)]">83% 단축</strong>시켰고, <strong class="text-[var(--color-text)]">38개 AI 투자 알고리즘</strong>의 국가 심사를 통과시켰습니다. 현재는 퀀트 리서치팀이 매일 쓰는 대시보드를 처음부터 다시 설계하고 있으며, 화면 설계부터 AI 코딩 도구를 활용한 구현까지 직접 수행합니다.
        </p>
      </div>
      <div class="flex flex-col gap-3 items-start md:items-end w-full md:w-auto">
        <a href="mailto:elliebinn@gmail.com" class="flex items-center gap-3 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <span class="text-sm font-medium">elliebinn@gmail.com</span>
        </a>
        <a href="https://www.linkedin.com/in/hyebin-woo-62a261291/" target="_blank" class="flex items-center gap-3 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
          <span class="text-sm font-medium">LinkedIn</span>
        </a>
        <a href="https://github.com/Elliebinn" target="_blank" class="flex items-center gap-3 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>
          <span class="text-sm font-medium">GitHub</span>
        </a>
        <div class="flex items-center gap-3 text-[var(--color-text-muted)]">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span class="text-sm font-medium">서울 / 원격</span>
        </div>
        <a href={`${import.meta.env.BASE_URL}${lang}/resume-pdf/`} target="_blank" rel="noopener"
           class="mt-3 inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-[var(--color-accent)] text-[var(--color-on-accent)] text-sm font-bold hover:opacity-90 transition-all shadow-ambient-sm">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
          PDF 다운로드
        </a>
      </div>
    </header>

    <!-- 2-column: 8/12 + 4/12 -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">

      <!-- Left: Experience Timeline -->
      <div class="lg:col-span-8">
        <h2 class="text-3xl font-bold tracking-tight mb-12 flex items-center gap-4 text-[var(--color-text)]" style="font-family: var(--font-display);">
          경력
          <span class="h-[2px] flex-grow bg-[var(--color-bg-emphasis)]"></span>
        </h2>

        <div class="relative pl-8">
          <!-- Timeline vertical line -->
          <div class="absolute left-0 top-2 bottom-0 w-[2px] bg-[var(--color-bg-emphasis)]"></div>

          <!-- 알파브릿지 -->
          <div class="mb-16 relative">
            <div class="absolute -left-[37px] top-1.5 w-4 h-4 rounded-full border-4 border-[var(--color-bg)] bg-[var(--color-accent)]"></div>
            <div class="flex flex-col md:flex-row justify-between items-start mb-5 gap-2">
              <div>
                <h3 class="text-2xl font-bold text-[var(--color-text)]">알파브릿지 — AI서비스기획본부</h3>
                <p class="text-sm text-[var(--color-text-muted)] mt-1">에셋플러스자산운용 자회사 · 정규직</p>
              </div>
              <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] bg-[var(--color-bg-detail)] px-3 py-1 rounded-full">2025.03 — 현재</span>
            </div>

            <!-- Project 1: 대시보드 -->
            <div class="mb-7">
              <p class="font-bold text-[var(--color-text)] mb-3 text-[15px]" style="font-family: var(--font-display);">
                전략 모니터링 · 성과 분석 · 운용 관리 대시보드 서비스 기획
              </p>
              <ul class="space-y-3 text-[var(--color-text-muted)] leading-relaxed">
                <li class="flex gap-3">
                  <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                  <span>펀드 운용 경험을 바탕으로 사용자 요청 뒤 진짜 니즈를 파악하여 <strong class="text-[var(--color-text)]">리밸런싱 포인트 네비게이션, 태그 기반 전략 분류</strong> 등 요청에 없던 기능 선제 설계</span>
                </li>
                <li class="flex gap-3">
                  <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                  <span><strong class="text-[var(--color-text)]">200개+ 전략 탐색 구조 재편</strong> — 태그 기반 분류 체계 설계, 사이드바 13개 메뉴를 워크플로우 기반으로 재구조화</span>
                </li>
                <li class="flex gap-3">
                  <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                  <span>디자인 시스템 직접 구축(DESIGN.md 문서화) 후 AI 코딩 도구로 HTML 목업 25개 → 20개+ 분석 페이지 일관되게 전환</span>
                </li>
                <li class="flex gap-3">
                  <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                  <span>외부 UX/UI 디자이너 2인 피드백(2.5/5, 3.9/5) → 7개 요구사항 분해 → Bloomberg·Morningstar 등 14개 레퍼런스 기반 개선</span>
                </li>
              </ul>
            </div>

            <!-- Project 2: RATB -->
            <div>
              <p class="font-bold text-[var(--color-text)] mb-3 text-[15px]" style="font-family: var(--font-display);">
                로보어드바이저 AI 알고리즘 기획 및 운용심사 수행 (RATB 22~25차)
              </p>
              <ul class="space-y-3 text-[var(--color-text-muted)] leading-relaxed">
                <li class="flex gap-3">
                  <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                  <span><strong class="text-[var(--color-text)]">38개 AI 투자 알고리즘</strong> 기획 및 KOSCOM 로보어드바이저 테스트베드 운용심사 전 과정 주도 (PM 역할)</span>
                </li>
                <li class="flex gap-3">
                  <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                  <span>22~24차 운용심사 전원 통과 / 최고 수익률 <strong class="text-[var(--color-text)]">1년 기준 19.5%</strong> (2024.12 기준)</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- 에셋플러스 -->
          <div class="mb-16 relative">
            <div class="absolute -left-[37px] top-1.5 w-4 h-4 rounded-full border-4 border-[var(--color-bg)] bg-[var(--color-accent)]"></div>
            <div class="flex flex-col md:flex-row justify-between items-start mb-5 gap-2">
              <div>
                <h3 class="text-2xl font-bold text-[var(--color-text)]">에셋플러스자산운용 — AI자산운용팀</h3>
                <p class="text-sm text-[var(--color-text-muted)] mt-1">정규직</p>
              </div>
              <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] bg-[var(--color-bg-detail)] px-3 py-1 rounded-full">2023.09 — 2025.03</span>
            </div>
            <ul class="space-y-3 text-[var(--color-text-muted)] leading-relaxed">
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                <span><strong class="text-[var(--color-text)]">S&P500 AI 공모펀드 2건 출시</strong> (S&P 성장/배당 포커스 30) — 현재 고객 자금 운용 중</span>
              </li>
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                <span>AI 공모펀드 운용지원 시스템 기획 — 매매·운용시간 1시간+ → 10분 (<strong class="text-[var(--color-text)]">83% 단축</strong>). 운용역 실제 워크플로우 관찰 → 자동화/사람 판단 단계 분리 → 요건정의서 작성</span>
              </li>
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                <span>ETF 유니버스 분류 체계(4그룹) 설계, 투자자 성향별 배분 로직 기획</span>
              </li>
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                <span>ETF 기획: MartinGale 전략 AI 알고리즘화, NASDAQ/KOSPI ETF 상장 준비, 다올자산운용 MOU 체결</span>
              </li>
            </ul>
          </div>

          <!-- 사이드 프로젝트 -->
          <div class="relative">
            <div class="absolute -left-[37px] top-1.5 w-4 h-4 rounded-full border-4 border-[var(--color-bg)] bg-[var(--color-accent)]"></div>
            <div class="flex flex-col md:flex-row justify-between items-start mb-4 gap-2">
              <div>
                <h3 class="text-2xl font-bold text-[var(--color-text)]">주주톡 — AI 주식 분석 플랫폼</h3>
                <p class="text-sm text-[var(--color-text-muted)] mt-1">사이드 프로젝트 · 1인 기획+풀스택 개발</p>
              </div>
            </div>
            <p class="text-[var(--color-text-muted)] leading-relaxed italic mb-4 pl-4 border-l-2 border-[var(--color-accent)]">
              "단일 AI의 편향을 시스템 구조로 해결할 수 있을까?"
            </p>
            <ul class="space-y-3 text-[var(--color-text-muted)] leading-relaxed">
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                <span>6개 AI 에이전트(거시/기술/공시/뉴스/재무/온체인)로 분석 축 분리, 4명 투자 페르소나(가치/성장/거시/모멘텀)가 3라운드 토론하는 구조 설계</span>
              </li>
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                <span>서비스 컨셉·정보구조·UX 플로우 직접 설계 후 FastAPI + React 19 + Claude API로 풀스택 구현</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Right: Sidebar -->
      <div class="lg:col-span-4 space-y-12">

        <!-- 학력 -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            학력
          </h2>
          <div class="space-y-6">
            <div class="bg-[var(--color-bg-card)] p-6 rounded-xl">
              <h4 class="font-bold text-lg mb-1 text-[var(--color-text)]">Johns Hopkins University</h4>
              <p class="text-[var(--color-accent)] font-medium mb-2">경제학 학사 (부전공: 마케팅)</p>
              <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-faint)]">2017.08 — 2019.05</span>
            </div>
            <div class="bg-[var(--color-bg-card)] p-6 rounded-xl">
              <h4 class="font-bold text-lg mb-1 text-[var(--color-text)]">Fullerton College</h4>
              <p class="text-[var(--color-accent)] font-medium mb-2">경제학</p>
              <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-faint)]">2016.01 — 2017.05</span>
            </div>
          </div>
        </section>

        <!-- 역량 -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            역량
          </h2>
          <div class="space-y-4">
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-text-faint)] mb-2">기획 · UX</p>
              <div class="flex flex-wrap gap-2">
                {['서비스 기획', '정보구조(IA) 설계', 'UX 재설계', '디자인 시스템', '요건정의서'].map((skill) => (
                  <span class="px-3 py-1.5 bg-[var(--color-secondary-container)] text-[var(--color-on-secondary-container)] rounded-full text-xs font-semibold">{skill}</span>
                ))}
              </div>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-text-faint)] mb-2">AI · 개발</p>
              <div class="flex flex-wrap gap-2">
                {['Claude Code', 'Claude API', 'AI 에이전트 설계', '프롬프트 엔지니어링', 'Python', 'FastAPI', 'React', 'TypeScript', 'SQL', 'n8n'].map((skill) => (
                  <span class="px-3 py-1.5 bg-[var(--color-secondary-container)] text-[var(--color-on-secondary-container)] rounded-full text-xs font-semibold">{skill}</span>
                ))}
              </div>
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-[var(--color-text-faint)] mb-2">데이터 · 시각화</p>
              <div class="flex flex-wrap gap-2">
                {['ClickHouse', 'MySQL', 'Pandas', 'Plotly', 'ECharts', 'Highcharts'].map((skill) => (
                  <span class="px-3 py-1.5 bg-[var(--color-secondary-container)] text-[var(--color-on-secondary-container)] rounded-full text-xs font-semibold">{skill}</span>
                ))}
              </div>
            </div>
          </div>
        </section>

        <!-- Stack & Tools -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            도구
          </h2>
          <div class="grid grid-cols-2 gap-4">
            <div class="flex items-center gap-3 p-3 bg-[var(--color-bg-secondary)] rounded-lg">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              <span class="text-sm font-bold text-[var(--color-text)]">Claude Code</span>
            </div>
            <div class="flex items-center gap-3 p-3 bg-[var(--color-bg-secondary)] rounded-lg">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              <span class="text-sm font-bold text-[var(--color-text)]">Figma</span>
            </div>
            <div class="flex items-center gap-3 p-3 bg-[var(--color-bg-secondary)] rounded-lg">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              <span class="text-sm font-bold text-[var(--color-text)]">VS Code</span>
            </div>
            <div class="flex items-center gap-3 p-3 bg-[var(--color-bg-secondary)] rounded-lg">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
              <span class="text-sm font-bold text-[var(--color-text)]">n8n</span>
            </div>
          </div>
        </section>

        <!-- 자격증 -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            자격증
          </h2>
          <div class="space-y-3">
            {[
              { name: 'SQL 개발자', date: '2026.03' },
              { name: '증권투자권유자문인력', date: '2024.05' },
              { name: '파생상품투자권유자문인력', date: '2024.02' },
              { name: '펀드투자권유자문인력', date: '2023.12' },
              { name: 'AFPK', date: '2022.04' },
              { name: '투자자산운용사', date: '2021.12' },
            ].map((cert) => (
              <div class="flex items-baseline justify-between">
                <p class="font-bold text-sm text-[var(--color-text)]">{cert.name}</p>
                <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-faint)]">{cert.date}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- 언어 -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            언어
          </h2>
          <div class="space-y-2">
            <p class="font-bold text-[var(--color-text)]">한국어 (모국어) · 영어 (비즈니스 고급)</p>
            <p class="text-sm text-[var(--color-text-faint)]">미국 대학 졸업 (Johns Hopkins University)</p>
          </div>
        </section>
      </div>
    </div>
  </main>

