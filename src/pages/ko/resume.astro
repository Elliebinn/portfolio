---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';

const lang = 'ko';
---

<Layout title="이력서 — 우혜빈">
  <Navbar lang={lang} client:load />

  <main class="px-6 pt-28 pb-20">
    <div class="mx-auto max-w-7xl">

      <!-- Header -->
      <div class="mb-16">
        <p class="mb-4 text-xs uppercase tracking-[0.15em] text-[var(--color-text-faint)]">Curriculum Vitae</p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-[var(--color-text)] leading-[1.1]" style="font-family: var(--font-display);">
          복잡한 금융 구조를<br/>
          <span class="text-[var(--color-accent)]">이해할 수 있는 경험으로.</span>
        </h1>
        <p class="mt-6 text-lg text-[var(--color-text-muted)] max-w-2xl leading-relaxed">
          AI 투자 알고리즘 38개를 기획하고 국가 심사를 통과시켰고, 200개 이상의 운용 계좌를 동시에 관리하는 프로세스를 설계했습니다. 사용자가 말하지 않은 문제를 찾아 정보구조를 다시 그리고, 필요하면 직접 만듭니다.
        </p>
        <div class="mt-6 flex flex-wrap gap-3 text-sm text-[var(--color-text-faint)]">
          <span>elliebinn@gmail.com</span>
          <span>·</span>
          <a href="https://github.com/Elliebinn" class="text-[var(--color-accent)] hover:underline">GitHub</a>
          <span>·</span>
          <a href="https://www.linkedin.com/in/hyebin-woo-62a261291/" class="text-[var(--color-accent)] hover:underline">LinkedIn</a>
          <span>·</span>
          <span>서울</span>
        </div>
      </div>

      <!-- 2-column layout -->
      <div class="grid gap-12 lg:grid-cols-[1fr_320px]">

        <!-- Left: Experience -->
        <div>
          <h2 class="mb-8 text-sm font-bold uppercase tracking-[0.15em] text-[var(--color-text-faint)]">경력</h2>

          <!-- 알파브릿지 -->
          <div class="mb-12 rounded-xl bg-[var(--color-bg-card)] p-8 shadow-ambient-sm">
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-4">
              <h3 class="text-xl font-bold text-[var(--color-text)]" style="font-family: var(--font-display);">알파브릿지 · AI서비스기획본부</h3>
              <span class="font-mono text-xs text-[var(--color-accent)]">2025.04 — 현재</span>
            </div>
            <p class="text-xs text-[var(--color-text-faint)] mb-4">에셋플러스자산운용 자회사</p>

            <h4 class="font-semibold text-sm text-[var(--color-text)] mb-2">퀀트 전략 분석 플랫폼 서비스 기획</h4>
            <ul class="space-y-2 text-sm text-[var(--color-text-muted)] leading-[1.8] list-disc pl-5 mb-6">
              <li>프론트엔드·디자이너 없는 6인 팀에서 서비스 기획·UX 전담</li>
              <li>200개+ 전략의 탐색 구조를 태그 기반 분류 체계로 재설계</li>
              <li>"검색 추가" 요청의 근본 원인(분류 체계 부재)을 파악하여 선제적 기능 설계</li>
              <li>디자인 시스템 직접 구축 + HTML 목업 25개 → 20개+ 페이지 일관 전환</li>
              <li>UX/UI 디자이너 2인 피드백(2.5/5, 3.9/5) → 7개 요구사항 분해 → 14개 레퍼런스 기반 개선</li>
            </ul>
          </div>

          <!-- 에셋플러스 -->
          <div class="mb-12 rounded-xl bg-[var(--color-bg-card)] p-8 shadow-ambient-sm">
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-4">
              <h3 class="text-xl font-bold text-[var(--color-text)]" style="font-family: var(--font-display);">에셋플러스자산운용 · AI자산운용팀</h3>
              <span class="font-mono text-xs text-[var(--color-accent)]">2023.09 — 2025.03</span>
            </div>

            <h4 class="font-semibold text-sm text-[var(--color-text)] mb-2">RATB 22~24차 로보어드바이저 알고리즘 기획</h4>
            <ul class="space-y-2 text-sm text-[var(--color-text-muted)] leading-[1.8] list-disc pl-5 mb-6">
              <li>38개 AI 투자 알고리즘 기획, 약 200개 운용 계좌 동시 관리</li>
              <li>22~24차 운용심사 전원 통과 / 최고 수익률 19.5%</li>
              <li>ETF 유니버스 분류 체계(4그룹) 직접 설계, 투자자 성향별 배분 로직 기획</li>
            </ul>

            <h4 class="font-semibold text-sm text-[var(--color-text)] mb-2">AI 운용지원 시스템 기획</h4>
            <ul class="space-y-2 text-sm text-[var(--color-text-muted)] leading-[1.8] list-disc pl-5 mb-6">
              <li>운용역 워크플로우 관찰 → 자동화/사람 판단 단계 분리 → 요건정의서 작성</li>
              <li>매매·운용시간 1시간+ → 10분 (83% 단축)</li>
            </ul>

            <h4 class="font-semibold text-sm text-[var(--color-text)] mb-2">금융 투자 상품 기획</h4>
            <ul class="space-y-2 text-sm text-[var(--color-text-muted)] leading-[1.8] list-disc pl-5">
              <li>S&P500 AI 공모펀드 2건 출시 (현재 고객 자금 운용 중)</li>
              <li>외부 자산운용사 대상 AI 포트폴리오 컨설팅, 다올자산운용 MOU 체결</li>
            </ul>
          </div>

          <!-- 사이드 프로젝트 -->
          <div class="rounded-xl bg-[var(--color-bg-card)] p-8 shadow-ambient-sm">
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-4">
              <h3 class="text-xl font-bold text-[var(--color-text)]" style="font-family: var(--font-display);">주주톡 (JujuTok)</h3>
              <span class="font-mono text-xs text-[var(--color-accent)]">사이드 프로젝트</span>
            </div>
            <p class="text-sm text-[var(--color-text-muted)] leading-[1.8] mb-4">
              "단일 AI의 편향을 시스템 구조로 해결할 수 있을까?" — 6개 AI 에이전트로 분석 축을 분리하고, 4명 투자 페르소나가 토론하는 구조를 설계. 기획부터 개발까지 직접 수행.
            </p>
          </div>
        </div>

        <!-- Right: Sidebar -->
        <div class="space-y-8">

          <!-- 학력 -->
          <div class="rounded-xl bg-[var(--color-bg-card)] p-6 shadow-ambient-sm">
            <h2 class="mb-4 text-sm font-bold uppercase tracking-[0.15em] text-[var(--color-text-faint)]">학력</h2>
            <div class="mb-4">
              <p class="text-sm font-semibold text-[var(--color-text)]">Johns Hopkins University</p>
              <p class="text-xs text-[var(--color-text-faint)]">경제학 학사 (부전공: 마케팅)</p>
              <p class="font-mono text-[10px] text-[var(--color-text-faint)]">2017.08 — 2019.05</p>
            </div>
            <div>
              <p class="text-sm font-semibold text-[var(--color-text)]">Fullerton College</p>
              <p class="text-xs text-[var(--color-text-faint)]">경제학</p>
              <p class="font-mono text-[10px] text-[var(--color-text-faint)]">2016.01 — 2017.05</p>
            </div>
          </div>

          <!-- 역량 -->
          <div class="rounded-xl bg-[var(--color-bg-card)] p-6 shadow-ambient-sm">
            <h2 class="mb-4 text-sm font-bold uppercase tracking-[0.15em] text-[var(--color-text-faint)]">역량</h2>
            <div class="flex flex-wrap gap-2">
              {['서비스 기획', '정보구조 설계', 'UX 설계', '요건정의서', '디자인 시스템', 'AI 에이전트 설계', '프롬프트 엔지니어링', 'Claude Code', 'Python', 'React', 'FastAPI', 'SQL'].map((skill) => (
                <span class="rounded-full bg-[var(--color-secondary-container)] px-3 py-1 text-[10px] font-medium text-[var(--color-on-secondary-container)]">
                  {skill}
                </span>
              ))}
            </div>
          </div>

          <!-- 자격증 -->
          <div class="rounded-xl bg-[var(--color-bg-card)] p-6 shadow-ambient-sm">
            <h2 class="mb-4 text-sm font-bold uppercase tracking-[0.15em] text-[var(--color-text-faint)]">자격증</h2>
            <div class="space-y-2">
              {[
                { name: 'SQL 개발자', date: '2026.03' },
                { name: '증권투자권유자문인력', date: '2024.05' },
                { name: '파생상품투자권유자문인력', date: '2024.02' },
                { name: '펀드투자권유자문인력', date: '2023.12' },
                { name: 'AFPK', date: '2022.04' },
                { name: '투자자산운용사', date: '2021.12' },
              ].map((cert) => (
                <div class="flex items-baseline justify-between">
                  <p class="text-sm text-[var(--color-text)]">{cert.name}</p>
                  <p class="font-mono text-[10px] text-[var(--color-text-faint)]">{cert.date}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- 언어 -->
          <div class="rounded-xl bg-[var(--color-bg-card)] p-6 shadow-ambient-sm">
            <h2 class="mb-4 text-sm font-bold uppercase tracking-[0.15em] text-[var(--color-text-faint)]">언어</h2>
            <div class="space-y-2">
              <div class="flex items-baseline justify-between">
                <p class="text-sm text-[var(--color-text)]">한국어</p>
                <p class="text-[10px] text-[var(--color-text-faint)]">모국어</p>
              </div>
              <div class="flex items-baseline justify-between">
                <p class="text-sm text-[var(--color-text)]">영어</p>
                <p class="text-[10px] text-[var(--color-text-faint)]">비즈니스 고급 (미국 대학 졸업)</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
