---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer';
import BottomNav from '../../../components/BottomNav';
import { landingTargets, getLandingTargetSlugs } from '../../../data/landing-targets';

export async function getStaticPaths() {
  return getLandingTargetSlugs().map((slug) => ({
    params: { company: slug },
  }));
}

const { company } = Astro.params;
const data = landingTargets[company as string];

if (!data) {
  throw new Error(`Landing target not found: ${company}`);
}

const lang = 'ko';
const base = import.meta.env.BASE_URL;

const pageTitle = `${data.company} ${data.role} · 우혜빈`;
const jobLabel = data.jobUrlLabel ?? '공고 보기 ↗';
---

<Layout title={pageTitle}>
  {data.noIndex && <meta slot="head" name="robots" content="noindex, nofollow" />}
  <Navbar lang={lang} client:load />

  <main
    class="landing-main"
    style={`--brand: ${data.brand.primary}; --brand-tint: ${data.brand.tint};`}
  >
    <!-- Decorative atmosphere layer -->
    <div class="atmosphere" aria-hidden="true">
      <div class="glow glow-1"></div>
      <div class="glow glow-2"></div>
      <div class="grain"></div>
    </div>

    <div class="landing-content">

      <!-- ================================================= -->
      <!--  HERO                                              -->
      <!-- ================================================= -->
      <section class="hero reveal" style="--delay: 0ms;">
        <div class="hero-body">
          <div class="hero-tag">
            <span class="tag-bar"></span>
            <span class="tag-text">A Candidate Brief · 01 / 05</span>
          </div>
          <h1 class="hero-headline">
            {data.headline}
          </h1>
          <p class="hero-sub">{data.subheadline}</p>
          <div class="hero-actions">
            <a href={`${base}ko/for/${company}/resume/`} class="btn btn-primary">
              이력서 보기
              <span class="btn-arrow">→</span>
            </a>
            <a href="mailto:elliebinn@gmail.com" class="btn btn-ghost">
              elliebinn@gmail.com
            </a>
          </div>
        </div>

        <aside class="hero-meta" aria-label="Brief metadata">
          <div class="hero-meta-row">
            <span class="meta-label">Prepared for</span>
            <span class="meta-value">{data.company}</span>
          </div>
          <div class="hero-meta-row">
            <span class="meta-label">Role</span>
            <span class="meta-value">{data.role}</span>
          </div>
          <div class="hero-meta-row">
            <span class="meta-label">Briefing</span>
            <span class="meta-value mono">{data.updatedAt}</span>
          </div>
          <div class="hero-meta-row">
            <span class="meta-label">Status</span>
            <span class="meta-value status">
              <span class="status-dot"></span>
              Intent to Apply
            </span>
          </div>
        </aside>
      </section>

      <!-- ================================================= -->
      <!--  WHY THIS COMPANY (moved up)                       -->
      <!-- ================================================= -->
      <section class="why reveal" style="--delay: 120ms;">
        <header class="section-header">
          <span class="section-index mono">02 / 05</span>
          <h2 class="section-title">이 회사에 지원하는 이유</h2>
        </header>
        <blockquote class="why-quote">
          <span class="quote-mark" aria-hidden="true">"</span>
          <p>{data.whyCompany}</p>
        </blockquote>
      </section>

      <!-- ================================================= -->
      <!--  PROOF POINTS                                      -->
      <!-- ================================================= -->
      <section class="proof reveal" style="--delay: 200ms;">
        <header class="section-header">
          <span class="section-index mono">03 / 05</span>
          <h2 class="section-title">숫자로 정리한 임팩트</h2>
          <p class="section-note">
            모든 수치는 공개 가능한 실무 성과입니다. 증빙 자료는 별도 요청 시 제공합니다.
          </p>
        </header>
        <div class="proof-grid">
          {data.proofPoints.map((point, i) => (
            <article class="proof-card">
              <div class="proof-idx mono">P{String(i + 1).padStart(2, '0')}</div>
              <div class="proof-value-wrap">
                <span class="proof-value mono">{point.value}</span>
              </div>
              <div class="proof-label">{point.label}</div>
              {point.detail && <p class="proof-detail">{point.detail}</p>}
            </article>
          ))}
        </div>
      </section>

      <!-- ================================================= -->
      <!--  HIGHLIGHTED SKILLS                                -->
      <!-- ================================================= -->
      <section class="skills reveal" style="--delay: 280ms;">
        <header class="section-header">
          <span class="section-index mono">04 / 05</span>
          <h2 class="section-title">
            {data.role} 요구사항에 맞춰 재배치한 역량
          </h2>
          <p class="section-note">
            전체 역량 목록이 아니라, {data.company} 공고의 핵심 요구 순서대로 선별한 상위 역량과 각각의 근거입니다.
          </p>
        </header>
        <ol class="skill-list">
          {data.highlightSkills.map((skill, i) => (
            <li class="skill-item">
              <span class="skill-num mono">{String(i + 1).padStart(2, '0')}</span>
              <div class="skill-body">
                <span class="skill-name">{skill.name}</span>
                <span class="skill-evidence">
                  <span class="arrow mono">→</span>
                  {skill.evidence}
                </span>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <!-- ================================================= -->
      <!--  HIGHLIGHTED PROJECTS                              -->
      <!-- ================================================= -->
      <section class="projects reveal" style="--delay: 360ms;">
        <header class="section-header">
          <span class="section-index mono">05 / 05</span>
          <h2 class="section-title">먼저 봐주셨으면 하는 프로젝트</h2>
          <p class="section-note">
            각 프로젝트가 이번 공고와 <em>어떻게</em> 정합되는지 한 줄로 정리했습니다.
          </p>
        </header>
        <div class="project-grid">
          {data.projectMatches.map((proj, i) => (
            <a href={`${base}ko/projects/${proj.slug}/`} class="project-card">
              <div class="project-top">
                <span class="project-idx mono">Case {String(i + 1).padStart(2, '0')}</span>
                <span class="project-arrow" aria-hidden="true">→</span>
              </div>
              <h3 class="project-title">{proj.title}</h3>
              <div class="project-match">
                <span class="match-label mono">Why it matches</span>
                <p class="match-text">{proj.whyMatch}</p>
              </div>
              <div class="project-cta">상세 케이스 스터디 열기</div>
            </a>
          ))}
        </div>
      </section>

      <!-- ================================================= -->
      <!--  CTA                                               -->
      <!-- ================================================= -->
      <section class="cta reveal" style="--delay: 440ms;">
        <div class="cta-inner">
          <span class="cta-tag mono">END OF BRIEF</span>
          <h2 class="cta-message">{data.ctaMessage}</h2>
          <div class="cta-actions">
            <a href="mailto:elliebinn@gmail.com" class="btn btn-brand">
              elliebinn@gmail.com
            </a>
            {data.jobUrl && (
              <a href={data.jobUrl} target="_blank" rel="noopener noreferrer" class="btn btn-ghost-dark">
                {jobLabel}
              </a>
            )}
          </div>
          <p class="cta-footer mono">
            Briefing prepared · {data.updatedAt} · for {data.company}
          </p>
        </div>
      </section>

    </div>
  </main>

  <Footer />
  <BottomNav lang={lang} client:load />
</Layout>

<style>
  /* ============================================
     LANDING — EDITORIAL FINANCE BRIEF
     Neutral base + precise brand signal
     ============================================ */

  .landing-main {
    position: relative;
    padding: 9rem 1.5rem 6rem;
    max-width: 1200px;
    margin: 0 auto;
    color: var(--color-text);
    word-break: keep-all;
    isolation: isolate;
  }

  /* ---------- atmosphere layer ---------- */
  .atmosphere {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
  }
  .glow-1 {
    top: -6rem;
    right: -6rem;
    width: 32rem;
    height: 32rem;
    background: var(--brand-tint);
    opacity: 0.8;
  }
  .glow-2 {
    top: 60%;
    left: -10rem;
    width: 28rem;
    height: 28rem;
    background: var(--brand-tint);
    opacity: 0.45;
  }
  .grain {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.35'/></svg>");
    mix-blend-mode: multiply;
    opacity: 0.04;
  }

  .landing-content {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 8rem;
  }

  /* ---------- reveal animation ---------- */
  .reveal {
    opacity: 0;
    transform: translateY(16px);
    animation: reveal 700ms cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }
  @keyframes reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  /* ============================================
     HERO
     ============================================ */
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 3rem;
    padding-top: 1rem;
  }
  @media (min-width: 900px) {
    .hero {
      grid-template-columns: minmax(0, 8fr) minmax(0, 4fr);
      gap: 4rem;
      align-items: start;
    }
  }

  .hero-body {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .tag-bar {
    display: inline-block;
    width: 1.5rem;
    height: 1.5px;
    background: var(--brand);
  }

  .hero-headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.25rem, 5vw, 4.5rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--color-text);
    max-width: 22ch;
  }

  .hero-sub {
    font-size: clamp(1rem, 1.3vw, 1.125rem);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 52ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  /* ---------- hero meta panel (right side) ---------- */
  .hero-meta {
    display: flex;
    flex-direction: column;
    padding: 0 0 0.5rem;
    border-top: 1.5px solid var(--brand);
    align-self: start;
  }
  .hero-meta-row {
    display: grid;
    grid-template-columns: 6rem 1fr;
    align-items: baseline;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px dashed var(--color-border);
  }
  .hero-meta-row:last-child {
    border-bottom: none;
  }
  .meta-label {
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.625rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .meta-value {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .meta-value.mono {
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-variant-numeric: tabular-nums;
    font-weight: 500;
  }
  .meta-value.status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand);
    box-shadow: 0 0 0 3px var(--brand-tint);
    animation: pulse 2.2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% {
      box-shadow: 0 0 0 3px var(--brand-tint);
    }
    50% {
      box-shadow: 0 0 0 6px var(--brand-tint);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .status-dot {
      animation: none;
    }
  }

  /* ============================================
     SECTION HEADER (shared)
     ============================================ */
  .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
    max-width: 60ch;
  }
  .section-index {
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--brand);
    font-weight: 600;
  }
  .section-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-text);
  }
  .section-note {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 55ch;
  }
  .section-note em {
    font-style: italic;
    color: var(--brand);
    font-weight: 600;
  }

  /* ============================================
     WHY
     ============================================ */
  .why-quote {
    position: relative;
    padding: 2rem 0 2rem 3rem;
    border-left: 2px solid var(--brand);
    margin: 0;
  }
  .quote-mark {
    position: absolute;
    left: 1rem;
    top: -0.5rem;
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 1;
    color: var(--brand);
    opacity: 0.3;
    font-weight: 800;
  }
  .why-quote p {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1.8vw, 1.625rem);
    line-height: 1.6;
    letter-spacing: -0.005em;
    color: var(--color-text);
    font-weight: 500;
    margin: 0;
  }

  /* ============================================
     PROOF POINTS
     ============================================ */
  .proof-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 720px) {
    .proof-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  .proof-card {
    position: relative;
    padding: 2rem 1.75rem 1.75rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-top: 2px solid var(--brand);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition:
      transform 400ms cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 300ms ease;
    overflow: hidden;
  }
  .proof-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--brand-tint);
    opacity: 0;
    transition: opacity 400ms ease;
    pointer-events: none;
  }
  .proof-card:hover {
    transform: translateY(-3px);
  }
  .proof-card:hover::before {
    opacity: 0.5;
  }
  .proof-card > * {
    position: relative;
  }
  .proof-idx {
    font-size: 0.625rem;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .proof-value-wrap {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    margin: 0.25rem 0 0.75rem;
  }
  .proof-value {
    font-family: var(--font-display);
    font-feature-settings: 'tnum', 'lnum';
    font-variant-numeric: tabular-nums;
    font-size: clamp(3rem, 5.5vw, 4.5rem);
    line-height: 0.95;
    font-weight: 800;
    color: var(--brand);
    letter-spacing: -0.03em;
  }
  .proof-label {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text);
  }
  .proof-detail {
    font-size: 0.75rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  /* ============================================
     SKILL LIST
     ============================================ */
  .skill-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 800px) {
    .skill-list {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 3rem;
    }
  }
  .skill-item {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    align-items: baseline;
    gap: 1rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--color-border);
  }
  .skill-num {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--brand);
    font-weight: 700;
  }
  .skill-body {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .skill-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.4;
  }
  .skill-evidence {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  .skill-evidence .arrow {
    color: var(--brand);
    margin-right: 0.35rem;
    font-weight: 600;
  }

  /* ============================================
     PROJECTS
     ============================================ */
  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 800px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 2rem 1.75rem;
    background: #fff;
    border: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    position: relative;
    transition:
      transform 400ms cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 300ms ease,
      box-shadow 400ms ease;
  }
  .project-card::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--brand);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 450ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .project-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--brand) 40%, var(--color-border));
    box-shadow: 0 20px 40px -24px rgba(0, 0, 0, 0.1);
  }
  .project-card:hover::after {
    transform: scaleX(1);
  }
  .project-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .project-idx {
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 600;
  }
  .project-arrow {
    font-size: 1.25rem;
    color: var(--brand);
    transition: transform 300ms ease;
  }
  .project-card:hover .project-arrow {
    transform: translate(4px, -4px);
  }
  .project-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.2vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin: 0;
  }
  .project-match {
    padding: 1rem 1.1rem;
    background: var(--brand-tint);
    border-left: 2px solid var(--brand);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .match-label {
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--brand);
    font-weight: 700;
  }
  .match-text {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--color-text);
    margin: 0;
  }
  .project-cta {
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-top: auto;
    padding-top: 0.5rem;
  }

  /* ============================================
     CTA
     ============================================ */
  .cta {
    margin-top: 2rem;
  }
  .cta-inner {
    position: relative;
    padding: 4.5rem 2rem;
    background: var(--color-text, #111);
    color: #fff;
    text-align: center;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }
  .cta-inner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--brand);
  }
  .cta-inner::after {
    content: '';
    position: absolute;
    bottom: -50%;
    left: 50%;
    width: 130%;
    height: 100%;
    background: radial-gradient(
      ellipse at center top,
      var(--brand-tint),
      transparent 60%
    );
    transform: translateX(-50%);
    opacity: 0.9;
    pointer-events: none;
  }
  .cta-tag {
    font-size: 0.625rem;
    letter-spacing: 0.3em;
    color: var(--brand);
    text-transform: uppercase;
    font-weight: 700;
    position: relative;
  }
  .cta-message {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.35;
    max-width: 26ch;
    letter-spacing: -0.01em;
    position: relative;
