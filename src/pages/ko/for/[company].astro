---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer';
import BottomNav from '../../../components/BottomNav';
import { landingTargets, getLandingTargetSlugs } from '../../../data/landing-targets';

export async function getStaticPaths() {
  return getLandingTargetSlugs().map((slug) => ({
    params: { company: slug },
  }));
}

const { company } = Astro.params;
const data = landingTargets[company as string];

if (!data) {
  throw new Error(`Landing target not found: ${company}`);
}

const lang = 'ko';
const base = import.meta.env.BASE_URL;

const pageTitle = `${data.company} ${data.role} · 우혜빈`;
const jobLabel = data.jobUrlLabel ?? '공고 보기 ↗';
---

<Layout title={pageTitle}>
  {data.noIndex && <meta slot="head" name="robots" content="noindex, nofollow" />}
  <Navbar lang={lang} client:load />

  <main
    class="landing-main"
    style={`--brand: ${data.brand.primary}; --brand-tint: ${data.brand.tint};`}
  >
    <!-- Decorative atmosphere layer -->
    <div class="atmosphere" aria-hidden="true">
      <div class="glow glow-1"></div>
      <div class="glow glow-2"></div>
      <div class="grain"></div>
    </div>

    <div class="landing-content">

      <!-- ================================================= -->
      <!--  HERO                                              -->
      <!-- ================================================= -->
      <section class="hero reveal" style="--delay: 0ms;">
        <div class="hero-body">
          <h1 class="hero-headline">
            {data.headline}
          </h1>
          <p class="hero-sub">{data.subheadline}</p>
          <div class="hero-actions">
            <a href={`${base}ko/for/${company}/resume/`} class="btn btn-primary">
              이력서 보기
              <span class="btn-arrow">→</span>
            </a>
            <a href="mailto:elliebinn@gmail.com" class="btn btn-ghost">
              elliebinn@gmail.com
            </a>
          </div>
        </div>
      </section>

      <!-- ================================================= -->
      <!--  WHY THIS COMPANY (moved up)                       -->
      <!-- ================================================= -->
      <section class="why reveal" style="--delay: 120ms;">
        <header class="section-header">
          <h2 class="section-title">왜 여기인가</h2>
        </header>
        <blockquote class="why-quote">
          <span class="quote-mark" aria-hidden="true">"</span>
          <p>{data.whyCompany}</p>
        </blockquote>
      </section>

      <!-- ================================================= -->
      <!--  PROOF POINTS                                      -->
      <!-- ================================================= -->
      <section class="proof reveal" style="--delay: 200ms;">
        <header class="section-header">
          <h2 class="section-title">임팩트</h2>
          <p class="section-note">
            모든 수치는 공개 가능한 실무 성과입니다. 증빙 자료는 별도 요청 시 제공합니다.
          </p>
        </header>
        <div class="proof-grid">
          {data.proofPoints.map((point, i) => (
            <article class="proof-card">
              <div class="proof-idx mono">{String(i + 1).padStart(2, '0')}</div>
              <div class="proof-value-wrap">
                <span class="proof-value mono">{point.value}</span>
              </div>
              <div class="proof-label">{point.label}</div>
              {point.detail && <p class="proof-detail">{point.detail}</p>}
            </article>
          ))}
        </div>
      </section>

      <!-- ================================================= -->
      <!--  HIGHLIGHTED SKILLS                                -->
      <!-- ================================================= -->
      <section class="skills reveal" style="--delay: 280ms;">
        <header class="section-header">
          <h2 class="section-title">역량</h2>
          <p class="section-note">
            핵심 역량과 각각의 근거입니다.
          </p>
        </header>
        <ol class="skill-list">
          {data.highlightSkills.map((skill, i) => (
            <li class="skill-item">
              <span class="skill-num mono">{String(i + 1).padStart(2, '0')}</span>
              <div class="skill-body">
                <span class="skill-name">{skill.name}</span>
                <span class="skill-evidence">
                  <span class="arrow mono">→</span>
                  {skill.evidence}
                </span>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <!-- ================================================= -->
      <!--  HIGHLIGHTED PROJECTS                              -->
      <!-- ================================================= -->
      <section class="projects reveal" style="--delay: 360ms;">
        <header class="section-header">
          <h2 class="section-title">프로젝트</h2>
        </header>
        <div class="project-grid">
          {data.projectMatches.map((proj, i) => (
            <a href={`${base}v1/ko/projects/${proj.slug}/`} class="project-card">
              <div class="project-top">
                <span class="project-idx mono">{String(i + 1).padStart(2, '0')}</span>
                <span class="project-arrow" aria-hidden="true">→</span>
              </div>
              <h3 class="project-title">{proj.title}</h3>
              <div class="project-match">
                <span class="match-label mono">Why it matches</span>
                <p class="match-text">{proj.whyMatch}</p>
              </div>
              <div class="project-cta">상세 케이스 스터디 열기</div>
            </a>
          ))}
        </div>
      </section>

      <!-- ================================================= -->
      <!--  CTA                                               -->
      <!-- ================================================= -->
      <section class="cta reveal" style="--delay: 440ms;">
        <div class="cta-inner">
          <h2 class="cta-message">{data.ctaMessage}</h2>
          <div class="cta-actions">
            <a href="mailto:elliebinn@gmail.com" class="btn btn-brand">
              elliebinn@gmail.com
            </a>
            {data.jobUrl && (
              <a href={data.jobUrl} target="_blank" rel="noopener noreferrer" class="btn btn-ghost-dark">
                {jobLabel}
              </a>
            )}
          </div>
          <p class="cta-footer mono">
            {data.updatedAt}
          </p>
        </div>
      </section>

    </div>
  </main>

  <Footer />
  <BottomNav lang={lang} client:load />
</Layout>

<style>
  /* ============================================
     LANDING — BORDERLESS SWISS PRECISION
     Typography + spacing으로 구분. 보더 없음.
     ============================================ */

  .landing-main {
    position: relative;
    padding: 9rem 1.5rem 6rem;
    max-width: 1100px;
    margin: 0 auto;
    color: var(--color-text);
    word-break: keep-all;
    isolation: isolate;
  }

  /* ---------- atmosphere ---------- */
  .atmosphere {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(140px);
  }
  .glow-1 {
    top: -8rem;
    right: -8rem;
    width: 36rem;
    height: 36rem;
    background: var(--brand-tint);
    opacity: 0.6;
  }
  .glow-2 {
    top: 55%;
    left: -12rem;
    width: 30rem;
    height: 30rem;
    background: var(--brand-tint);
    opacity: 0.3;
  }
  .grain {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.35'/></svg>");
    mix-blend-mode: multiply;
    opacity: 0.03;
  }

  .landing-content {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 10rem;
  }

  /* ---------- reveal ---------- */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 800ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }
  @keyframes reveal {
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal { animation: none; opacity: 1; transform: none; }
  }

  /* ============================================
     HERO — single column, wide breathing
     ============================================ */
  .hero {
    padding-top: 2rem;
  }
  .hero-body {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    max-width: 48rem;
  }
  .hero-headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    line-height: 1.06;
    letter-spacing: -0.025em;
    color: var(--color-text);
  }
  .hero-sub {
    font-size: clamp(1.0625rem, 1.4vw, 1.1875rem);
    line-height: 1.75;
    color: var(--color-text-muted);
    max-width: 50ch;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  /* ============================================
     SECTION HEADER
     ============================================ */
  .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 3rem;
    max-width: 55ch;
  }
  .section-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.875rem, 3.2vw, 2.75rem);
    line-height: 1.12;
    letter-spacing: -0.015em;
    color: var(--color-text);
  }
  .section-note {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 50ch;
  }

  /* ============================================
     WHY — left accent line only
     ============================================ */
  .why-quote {
    position: relative;
    padding: 0 0 0 2.5rem;
    margin: 0;
  }
  .why-quote::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.25rem;
    bottom: 0.25rem;
    width: 3px;
    border-radius: 2px;
    background: var(--brand);
    opacity: 0.5;
  }
  .quote-mark {
    position: absolute;
    left: 0.6rem;
    top: -1rem;
    font-family: var(--font-display);
    font-size: 4.5rem;
    line-height: 1;
    color: var(--brand);
    opacity: 0.15;
    font-weight: 800;
  }
  .why-quote p {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2vw, 1.75rem);
    line-height: 1.6;
    letter-spacing: -0.005em;
    color: var(--color-text);
    font-weight: 500;
    margin: 0;
  }

  /* ============================================
     PROOF — no cards, big numbers
     ============================================ */
  .proof-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.5rem;
  }
  @media (min-width: 720px) {
    .proof-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }
  .proof-card {
    position: relative;
    padding: 0;
    background: transparent;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .proof-idx {
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    opacity: 0.5;
  }
  .proof-value-wrap {
    margin: 0.5rem 0 0.75rem;
  }
  .proof-value {
    font-family: var(--font-display);
    font-feature-settings: 'tnum', 'lnum';
    font-variant-numeric: tabular-nums;
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    line-height: 0.9;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.04em;
  }
  .proof-label {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: 0.01em;
  }
  .proof-detail {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  /* ============================================
     SKILLS — no borders, spacing rhythm
     ============================================ */
  .skill-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 800px) {
    .skill-list {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 4rem;
    }
  }
  .skill-item {
    display: grid;
    grid-template-columns: 2rem 1fr;
    align-items: baseline;
    gap: 1rem;
    padding: 1.5rem 0;
  }
  /* thin separator between items — not a border, a whisper */
  .skill-item + .skill-item {
    background-image: linear-gradient(
      to right,
      var(--color-text) 0%,
      var(--color-text) 2rem,
      transparent 2rem
    );
    background-size: 100% 1px;
    background-repeat: no-repeat;
    background-position: top;
    opacity: 1;
  }
  .skill-item + .skill-item::before {
    content: '';
    position: absolute;
  }
  .skill-num {
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    font-weight: 500;
    opacity: 0.4;
  }
  .skill-body {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .skill-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.4;
  }
  .skill-evidence {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  .skill-evidence .arrow {
    color: var(--color-text-muted);
    margin-right: 0.3rem;
    font-weight: 500;
    opacity: 0.5;
  }

  /* ============================================
     PROJECTS — no border, shadow + bg shift
     ============================================ */
  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 800px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 2.25rem 2rem;
    background: rgba(0, 0, 0, 0.015);
    border-radius: 1rem;
    text-decoration: none;
    color: inherit;
    position: relative;
    transition:
      transform 500ms cubic-bezier(0.16, 1, 0.3, 1),
      background 400ms ease,
      box-shadow 500ms ease;
  }
  .project-card:hover {
    transform: translateY(-4px);
    background: rgba(0, 0, 0, 0.025);
    box-shadow: 0 24px 48px -16px rgba(0, 0, 0, 0.08);
  }
  .project-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .project-idx {
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 500;
    opacity: 0.5;
  }
  .project-arrow {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    transition: transform 400ms cubic-bezier(0.16, 1, 0.3, 1), color 300ms ease;
    opacity: 0.4;
  }
  .project-card:hover .project-arrow {
    transform: translate(5px, -5px);
    color: var(--brand);
    opacity: 1;
  }
  .project-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin: 0;
  }
  .project-match {
    padding: 1.25rem 1.25rem;
    background: rgba(0, 0, 0, 0.025);
    border-radius: 0.625rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .match-label {
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 500;
    opacity: 0.6;
  }
  .match-text {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-text);
    margin: 0;
  }
  .project-cta {
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-top: auto;
    padding-top: 0.5rem;
    opacity: 0.5;
    transition: opacity 300ms ease, color 300ms ease;
  }
  .project-card:hover .project-cta {
    opacity: 1;
    color: var(--brand);
  }

  /* ============================================
     CTA — dark, clean
     ============================================ */
  .cta {
    margin-top: 2rem;
  }
  .cta-inner {
    position: relative;
    padding: 5rem 2rem;
    background: var(--color-text, #111);
    color: #fff;
    text-align: center;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    border-radius: 1rem;
  }
  .cta-inner::after {
    content: '';
    position: absolute;
    bottom: -40%;
    left: 50%;
    width: 120%;
    height: 80%;
    background: radial-gradient(
      ellipse at center top,
      var(--brand-tint),
      transparent 55%
    );
    transform: translateX(-50%);
    opacity: 0.7;
    pointer-events: none;
  }
  .cta-message {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3.2vw, 2.5rem);
    font-weight: 700;
    line-height: 1.3;
    max-width: 24ch;
    letter-spacing: -0.01em;
    position: relative;
    margin: 0;
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    position: relative;
  }
  .cta-footer {
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    margin: 1rem 0 0;
    position: relative;
  }

  /* ============================================
     BUTTONS — pill, no ghost border
     ============================================ */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9375rem 1.75rem;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.015em;
    text-decoration: none;
    border-radius: 999px;
    transition:
      transform 400ms cubic-bezier(0.16, 1, 0.3, 1),
      background 300ms ease,
      color 300ms ease,
      filter 300ms ease,
      opacity 300ms ease;
    will-change: transform;
  }
  .btn:hover {
    transform: translateY(-2px);
  }
  .btn-primary {
    background: var(--color-text);
    color: #fff;
  }
  .btn-primary:hover {
    background: var(--brand);
  }
  .btn-brand {
    background: var(--brand);
    color: #fff;
  }
  .btn-brand:hover {
    filter: brightness(1.1);
  }
  .btn-ghost {
    background: rgba(0, 0, 0, 0.04);
    color: var(--color-text-muted);
  }
  .btn-ghost:hover {
    background: rgba(0, 0, 0, 0.08);
    color: var(--color-text);
  }
  .btn-ghost-dark {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.85);
  }
  .btn-ghost-dark:hover {
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
  }
  .btn-arrow {
    display: inline-block;
    transition: transform 300ms ease;
  }
  .btn:hover .btn-arrow {
    transform: translateX(3px);
  }

  /* ============================================
     MONO
     ============================================ */
  .mono {
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-variant-numeric: tabular-nums;
    font-feature-settings: 'tnum', 'lnum';
  }
</style>
