---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Hero from '../../components/Hero';
import About from '../../components/About';
import Methodology from '../../components/Methodology';
import Capabilities from '../../components/Capabilities';
import Projects from '../../components/Projects';
import Skills from '../../components/Skills';
import Journey from '../../components/Journey';
import Certifications from '../../components/Certifications';
import Contact from '../../components/Contact';
import Footer from '../../components/Footer';
import BottomNav from '../../components/BottomNav';
import { getCollection } from 'astro:content';

const lang = 'ko';
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
const base = import.meta.env.BASE_URL;

const categoryLabels: Record<string, string> = {
  project: '프로젝트',
  planning: '기획',
  'deep-dive': '삽질기',
  skill: '스킬',
};
---

<Layout title="HB. | 우혜빈 포트폴리오">
  <Navbar lang={lang} client:load />

  <main>
    <Hero lang={lang} client:load />
    <About lang={lang} client:visible />
    <Methodology lang={lang} client:visible />
    <Capabilities lang={lang} client:visible />
    <Projects lang={lang} client:visible />

    <section id="blog" class="py-24 max-w-[1440px] mx-auto px-6 md:px-8">
      <div class="flex items-end justify-between mb-16">
        <div class="flex flex-col gap-4">
          <span class="text-xs font-bold text-[var(--color-accent)] uppercase tracking-widest">05 / 블로그</span>
          <h2 class="text-[2.5rem] font-bold text-[var(--color-text)]" style="font-family: var(--font-display);">최근 글</h2>
        </div>
        <a href={`${base}${lang}/blog/`} class="text-sm font-bold text-[var(--color-accent)] hover:underline hidden sm:inline-flex items-center gap-2">
          전체 보기 →
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
        {posts.map((post, i) => (
          <a href={`${base}${lang}/blog/${post.id}/`} class="group grid grid-cols-[48px_1fr_auto] items-start gap-4 py-6 transition-all hover:pl-2" style="border-top: 1px solid var(--color-border);">
            <span class="text-2xl font-bold text-[var(--color-outline-variant)] group-hover:text-[var(--color-accent)] transition-colors" style="font-family: var(--font-display);">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <h3 class="text-base font-bold leading-snug text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">{post.data.title}</h3>
              <p class="mt-1 text-xs text-[var(--color-text-faint)] line-clamp-2">{post.data.description}</p>
            </div>
            <div class="text-right flex-shrink-0">
              <p class="text-[10px] uppercase tracking-widest text-[var(--color-accent)] font-bold">{categoryLabels[post.data.category] || post.data.category}</p>
              <p class="mt-1 text-[10px] text-[var(--color-text-faint)]">{post.data.date.toISOString().slice(0, 10)}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <Skills lang={lang} client:visible />
    <Journey lang={lang} client:visible />
    <Certifications lang={lang} client:visible />
    <Contact lang={lang} client:visible />
  </main>
  <Footer />
  <BottomNav lang={lang} client:load />
</Layout>
