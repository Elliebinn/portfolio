<script>
  // Preloader — show only once per session
  const preloader = document.getElementById('preloader');
  if (sessionStorage.getItem('preloaded')) {
    preloader.classList.add('done');
  } else {
    window.addEventListener('load', () => {
      setTimeout(() => {
        preloader.classList.add('done');
        sessionStorage.setItem('preloaded', '1');
      }, 1400);
    });
  }

  // Page transition — split-panel wipe on internal link click
  const pt = document.getElementById('pageTransition');
  document.querySelectorAll('.work-card[href^="/"], .nav-link[href^="/ko/resume"], .nav-link[href^="/ko/writing"], .view-cv[href^="/"]').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const href = link.getAttribute('href');
      pt.classList.add('exit');
      setTimeout(() => { window.location.href = href; }, 500);
    });
  });

  // Nav scroll — brand slides from left, links from right, merge into pill
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  });

  // Scroll indicator
  const scrollFill = document.getElementById('scrollFill');
  const scrollIndicator = document.getElementById('scrollIndicator');
  window.addEventListener('scroll', () => {
    const pct = Math.min(100, (window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100);
    scrollFill.style.height = pct + '%';
    if (pct > 95) scrollIndicator.classList.add('hidden');
    else scrollIndicator.classList.remove('hidden');
  });

  // Custom cursor — ring + dot
  const cursor = document.getElementById('cursor');
  const cursorLabel = document.getElementById('cursorLabel');
  let mx = 0, my = 0, cx = 0, cy = 0;
  document.addEventListener('mousemove', (e) => { mx = e.clientX; my = e.clientY; });
  function loop() {
    cx += (mx - cx) * 0.5; cy += (my - cy) * 0.5;
    cursor.style.transform = `translate(${cx}px, ${cy}px)`;
    requestAnimationFrame(loop);
  }
  loop();

  document.querySelectorAll('[data-cursor]').forEach(el => {
    el.addEventListener('mouseenter', () => {
      cursor.classList.add('hover', 'has-label');
      cursorLabel.textContent = el.dataset.cursor;
    });
    el.addEventListener('mouseleave', () => {
      cursor.classList.remove('hover', 'has-label');
    });
  });
  document.querySelectorAll('a, button').forEach(el => {
    if (!el.dataset.cursor) {
      el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
      el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
    }
  });

  // Copy email
  document.querySelectorAll('a[href^="mailto:"]').forEach(a => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      const email = a.href.replace('mailto:', '');
      navigator.clipboard?.writeText(email);
      cursorLabel.textContent = 'Copied ✓';
      setTimeout(() => { cursorLabel.textContent = 'Copy'; }, 1500);
    });
  });

  // Theme toggle
  const toggle = document.getElementById('themeToggle');
  const themeIcon = document.getElementById('themeIcon');
  const saved = localStorage.getItem('hb-theme');
  if (saved) document.documentElement.setAttribute('data-theme', saved);
  function updateIcon() {
    const t = document.documentElement.getAttribute('data-theme');
    themeIcon.outerHTML = t === 'dark'
      ? '<ph-sun weight="regular" size="16" id="themeIcon"></ph-sun>'
      : '<ph-moon weight="regular" size="16" id="themeIcon"></ph-moon>';
  }
  updateIcon();
  toggle.addEventListener('click', () => {
    const cur = document.documentElement.getAttribute('data-theme');
    const next = cur === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('hb-theme', next);
    updateIcon();
  });

  // Reader overlay
  const overlay = document.getElementById('readerOverlay');
  const readerBody = document.getElementById('readerBody');
  const readerFull = document.getElementById('readerFull');

  function openReader(card) {
    const slug = card.dataset.postSlug;
    const url = card.dataset.blogUrl;
    const tpl = document.getElementById('post-' + slug);

    if (tpl) {
      readerBody.innerHTML = tpl.innerHTML;
    } else {
      // Fallback to description
      readerBody.innerHTML = `
        <div class="reader-meta">
          <span class="cat">${card.dataset.postCat}</span>
          <span class="sep">&middot;</span>
          <span>${card.dataset.postDate}</span>
          <span class="sep">&middot;</span>
          <span>${card.dataset.postRead}</span>
        </div>
        <h1 class="reader-title">${card.dataset.postTitle}</h1>
        <div class="reader-divider"></div>
        <div class="reader-text"><p>${card.dataset.postDesc}</p></div>
      `;
    }
    readerFull.href = url;
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
    overlay.querySelector('.reader-panel').scrollTop = 0;
  }

  function closeReader() {
    overlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  document.getElementById('readerClose').addEventListener('click', closeReader);
  document.getElementById('readerBackdrop').addEventListener('click', closeReader);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay.classList.contains('active')) closeReader();
  });

  document.querySelectorAll('.writing-card').forEach(card => {
    card.addEventListener('click', (e) => {
      e.preventDefault();
      openReader(card);
    });
  });

  // PDF viewer overlay
  const pdfOverlay = document.getElementById('pdfOverlay');
  const pdfBody = document.getElementById('pdfBody');
  const pdfTitle = document.getElementById('pdfTitle');
  const pdfFrame = document.getElementById('pdfFrame');

  function openPDF(card) {
    const pdfUrl = card.dataset.pdf;
    const title = card.dataset.portfolioTitle;

    pdfTitle.textContent = title;
    // Add #toolbar=0&navpanes=0 to hide toolbar and navigation panes
    pdfFrame.src = pdfUrl + '#toolbar=0&navpanes=0&scrollbar=0';
    pdfOverlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closePDF() {
    pdfOverlay.classList.remove('active');
    document.body.style.overflow = '';
    pdfFrame.src = '';
  }

  document.getElementById('pdfClose').addEventListener('click', closePDF);
  document.getElementById('pdfBackdrop').addEventListener('click', closePDF);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && pdfOverlay.classList.contains('active')) closePDF();
  });

  document.querySelectorAll('.portfolio-card').forEach(card => {
    card.addEventListener('click', (e) => {
      e.preventDefault();
      openPDF(card);
    });
  });

  // Reveal
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  // Portfolio reveal animations
  document.querySelectorAll('.portfolio-slide-up, .portfolio-fade-scale').forEach(el => io.observe(el));
</script>

</V2Layout>
