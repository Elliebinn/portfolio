      const readTime = estimateReadTime(post.body || '');
      const blogUrl = `/ko/writing#${post.id}`;
      return (
        <a
          href={blogUrl}
          class={`writing-card${i === 0 ? ' feature' : ''}`}
          data-cursor="Read"
          data-num={num}
          data-blog-url={blogUrl}
          data-post-title={post.data.title}
          data-post-desc={post.data.description}
          data-post-cat={catLabel}
          data-post-date={formatDate(post.data.date)}
          data-post-read={`${readTime} min read`}
          data-post-slug={post.id}
          style={`--card-accent: ${color};`}
