---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import BottomNav from '../../components/BottomNav';
import { getCollection } from 'astro:content';
import ColorPlaceholder from '../../components/placeholders/ColorPlaceholder';

const lang = 'ko';
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
const base = import.meta.env.BASE_URL;

const categoryLabels: Record<string, string> = {
  project: '프로젝트',
  planning: '기획',
  'deep-dive': '삽질기',
  skill: '스킬',
};
---

<Layout title="HB. | 우혜빈 포트폴리오">
  <Navbar lang={lang} client:load />

  <main>
    <!-- Hero Section -->
    <section id="home" class="min-h-screen pt-32 pb-24 px-6 md:px-8 max-w-[1440px] mx-auto flex flex-col justify-between">
      <div class="flex justify-between items-start w-full opacity-0 animate-fade-up" style="animation-delay: 0.1s;">
        <div class="text-[0.625rem] font-bold tracking-[0.2em] text-[var(--color-outline-variant)] uppercase">
          AI 서비스 기획 · 금융 도메인 · UX 설계
        </div>
        <div class="text-[0.625rem] font-bold tracking-[0.2em] text-[var(--color-accent)] uppercase flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] animate-pulse"></span>
          Seoul, South Korea
        </div>
      </div>
      <div class="flex-grow flex flex-col justify-center py-20">
        <div class="relative opacity-0 animate-fade-up" style="animation-delay: 0.3s;">
          <span class="text-[clamp(3rem,10vw,8rem)] font-extrabold leading-none tracking-tight block mb-[-2vw] text-[var(--color-bg-emphasis)]" style="font-family: var(--font-display);">Portfolio by</span>
          <h1 class="text-[clamp(4.5rem,15vw,14rem)] font-extrabold leading-[0.85] tracking-tighter text-[var(--color-text)]" style="font-family: var(--font-display);">Hyebin Woo</h1>
        </div>
        <div class="mt-16 flex flex-wrap gap-x-16 gap-y-8 opacity-0 animate-fade-up" style="animation-delay: 0.5s;">
          <div class="flex flex-col gap-2 transition-transform duration-300 hover:scale-105 cursor-default">
            <span class="text-4xl md:text-5xl font-extrabold text-[var(--color-text)] tracking-tight" style="font-family: var(--font-display);">38</span>
            <span class="text-[0.625rem] font-bold text-[var(--color-text-faint)] uppercase tracking-widest">AI 알고리즘 기획</span>
          </div>
          <div class="flex flex-col gap-2 transition-transform duration-300 hover:scale-105 cursor-default">
            <span class="text-4xl md:text-5xl font-extrabold text-[var(--color-text)] tracking-tight" style="font-family: var(--font-display);">200+</span>
            <span class="text-[0.625rem] font-bold text-[var(--color-text-faint)] uppercase tracking-widest">운용 계좌 관리</span>
          </div>
          <div class="flex flex-col gap-2 transition-transform duration-300 hover:scale-105 cursor-default">
            <span class="text-4xl md:text-5xl font-extrabold text-[var(--color-text)] tracking-tight" style="font-family: var(--font-display);">20+</span>
            <span class="text-[0.625rem] font-bold text-[var(--color-text-faint)] uppercase tracking-widest">페이지 정보구조 재설계</span>
          </div>
        </div>
      </div>
      <div class="flex justify-center animate-bounce">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-outline-variant)]">
          <path d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </div>
    </section>

    <!-- About Section -->
    <section id="about" class="py-24 px-6 md:px-8 max-w-[1440px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
        <div class="lg:col-span-5">
          <span class="text-xs font-bold text-[var(--color-accent)] uppercase tracking-widest mb-6 block">01 / 소개</span>
          <h2 class="text-[2.5rem] md:text-[3rem] font-extrabold tracking-tight leading-[1.1] text-[var(--color-text)]" style="font-family: var(--font-display);">
            금융을 이해하는 <span class="text-[var(--color-accent)]">기획자</span>,<br/>
            기술로 검증하는 <span class="text-[var(--color-accent)]">실행자</span>.
          </h2>
        </div>
        <div class="lg:col-span-7 flex flex-col gap-8 lg:mt-6">
          <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
            에셋플러스자산운용에서 AI 투자 알고리즘 38개를 기획하고, 200개 이상의 운용 계좌를 동시에 관리했어요.
            사용자가 말하지 않은 문제를 찾아 정보구조를 다시 설계하고, 필요하면 직접 만듭니다.
            디자이너 없는 팀에서 20개 이상의 분석 페이지를 설계했고, AI 멀티에이전트 주식 분석 플랫폼을 혼자 기획부터 개발까지 해봤어요.
          </p>
          <div class="flex flex-wrap gap-2">
            {['서비스 기획', '정보구조 설계', 'AI 에이전트', '금융 도메인', 'UX 설계', '프로토타이핑'].map((skill) => (
              <span class="px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider transition-all cursor-default" style="background-color: var(--color-bg-detail); color: var(--color-text);">
                {skill}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Core Methodology — sticky left + scrolling right steps -->
    <section id="methodology" class="py-24" style="background-color: var(--color-bg-secondary);">
      <div class="max-w-[1440px] mx-auto px-6 md:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
          <!-- Left: sticky title + visual -->
          <div class="lg:col-span-5 lg:sticky lg:top-24 lg:self-start">
            <div class="flex flex-col gap-4 mb-8">
              <span class="text-xs font-bold text-[var(--color-accent)] uppercase tracking-widest">02 / 기획 프로세스</span>
              <h2 class="text-[2.5rem] font-bold text-[var(--color-text)]" style="font-family: var(--font-display);">문제 발견에서 검증까지</h2>
            </div>
            <div class="bg-[var(--color-bg-card)] p-8 rounded-xl shadow-ambient">
              <div class="aspect-video rounded-lg overflow-hidden relative" style="background-color: var(--color-bg-detail);">
                <ColorPlaceholder variant="geometric" colors={["--color-bg-detail", "--color-accent"]} className="w-full h-full" />
                <div class="absolute inset-0" style="background: linear-gradient(to top right, rgba(69, 98, 114, 0.2), transparent);"></div>
              </div>
              <div class="mt-6 flex justify-between items-center">
                <div class="flex gap-2">
                  <span class="w-3 h-3 rounded-full" style="background-color: rgba(159, 64, 61, 0.2);"></span>
                  <span class="w-3 h-3 rounded-full" style="background-color: rgba(69, 98, 114, 0.2);"></span>
                  <span class="w-3 h-3 rounded-full" style="background-color: #d3e4ff;"></span>
                </div>
                <span class="text-xs font-bold text-[var(--color-text-faint)] uppercase tracking-wider">기획 프로세스 v2</span>
              </div>
            </div>
          </div>
          <!-- Right: scrolling steps -->
          <div class="lg:col-span-7 flex flex-col gap-0">
            {[
              { num: '01', title: '문제 발견', desc: "사용자가 '검색 추가해주세요'라고 하면, 그 뒤에 있는 근본 원인(분류 체계 부재)을 찾습니다." },
              { num: '02', title: '구조 설계', desc: 'ETF 유니버스를 4그룹(성장/가치/배당/섹터+테마)으로 분류하고, 투자자 성향별 배분 로직을 설계합니다.' },
              { num: '03', title: '해상도 높이기', desc: "'비중 이탈 시 리밸런싱'이라는 한 줄을, 개발자가 질문 없이 구현할 수 있는 수준으로 구체화합니다." },
              { num: '04', title: '검증 후 확장', desc: '22→23→24차로 알고리즘을 2개→8개→28개로 검증하며 확장합니다. 22~24차 전원 통과.' },
            ].map((step, i) => (
              <div class={`method-step flex gap-6 items-start group py-12 ${i < 3 ? 'border-b border-[var(--color-border)]' : ''}`}>
                <span class="method-number bg-[var(--color-accent)] text-[var(--color-on-accent)] w-10 h-10 rounded-full flex items-center justify-center font-bold flex-shrink-0 transition-all">{step.num}</span>
                <div>
                  <h3 class="text-xl font-bold mb-2 text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">{step.title}</h3>
                  <p class="text-[var(--color-text-muted)] leading-relaxed">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Capabilities -->
    <section id="stack" class="py-24 max-w-[1440px] mx-auto px-6 md:px-8">
      <div class="flex flex-col gap-4 mb-16">
        <span class="text-xs font-bold text-[var(--color-accent)] uppercase tracking-widest">03 / 역량</span>
        <h2 class="text-[2.5rem] font-bold text-[var(--color-text)]" style="font-family: var(--font-display);">금융, 기획, 그리고 기술</h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
        <div class="lg:col-span-5 flex flex-col justify-center">
          <p class="text-lg text-[var(--color-text-muted)] mb-12 max-w-md leading-relaxed">금융을 이해하는 기획자는 단순한 화면 설계에 그치지 않습니다. 시장의 투자 구조, 사용자의 실제 워크플로우, 그리고 AI 모델의 가능성을 동시에 봅니다.</p>
          <div class="p-12 rounded-full aspect-square flex items-center justify-center relative" style="background-color: var(--color-bg-secondary);">
            <svg class="w-full h-full" viewBox="0 0 100 100" data-radar>
              <polygon class="radar-grid" fill="rgba(69, 98, 114, 0.1)" points="50,10 90,40 75,90 25,90 10,40" stroke="rgba(69, 98, 114, 0.3)" stroke-width="0.5"></polygon>
              <polygon class="radar-grid" fill="none" points="50,20 80,45 68,80 32,80 20,45" stroke="rgba(69, 98, 114, 0.3)" stroke-width="0.5"></polygon>
              <polygon class="radar-grid" fill="none" points="50,30 70,50 61,70 39,70 30,50" stroke="rgba(69, 98, 114, 0.3)" stroke-width="0.5"></polygon>
              <polygon class="radar-value" fill="rgba(69, 98, 114, 0.4)" points="50,15 85,35 70,85 30,75 15,45" stroke="#456272" stroke-width="1"></polygon>
            </svg>
            <div class="absolute top-4 left-1/2 -translate-x-1/2 text-xs font-bold uppercase text-[var(--color-text)]">AI 활용</div>
            <div class="absolute top-1/3 right-0 text-xs font-bold uppercase translate-x-4 text-[var(--color-text)]">서비스 기획</div>
            <div class="absolute bottom-4 right-1/4 text-xs font-bold uppercase text-[var(--color-text)]">UX 설계</div>
            <div class="absolute bottom-4 left-1/4 text-xs font-bold uppercase text-[var(--color-text)]">리서치</div>
            <div class="absolute top-1/3 left-0 text-xs font-bold uppercase -translate-x-4 text-[var(--color-text)]">금융 도메인</div>
          </div>
        </div>
        <div class="lg:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-6">
          {[
            { title: '서비스 기획', desc: '문제 정의, 정보구조 설계, 요건정의서 작성까지 기획 전 과정을 수행합니다.', icon: 'M3 7h18M3 12h18M3 17h18' },
            { title: '사용자 리서치', desc: '현업 워크플로우를 직접 관찰해서 요청 뒤의 진짜 니즈를 발견합니다.', icon: 'M21 21l-4.35-4.35M17 10a7 7 0 11-14 0 7 7 0 0114 0z' },
            { title: 'UX 설계', desc: '와이어프레임부터 디자인 시스템 구축, 20개+ 페이지를 직접 설계합니다.', icon: 'M4 6h16M4 12h16M4 18h16' },
            { title: 'AI 활용', desc: 'Claude Code, 멀티에이전트 설계, 프롬프트 엔지니어링으로 기획을 검증합니다.', icon: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5' },
          ].map((cap) => (
            <div class="capability-card p-8 rounded-xl flex flex-col gap-4 transition-all duration-300 hover:-translate-y-2 hover:shadow-ambient cursor-pointer group" style="background-color: var(--color-bg-secondary);">
              <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)] group-hover:scale-110 transition-transform">
                <path d={cap.icon}/>
              </svg>
              <h3 class="text-xl font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">{cap.title}</h3>
              <p class="text-[var(--color-text-muted)] text-sm">{cap.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section id="projects" class="py-24" style="background-color: var(--color-bg-secondary);">
      <div class="max-w-[1440px] mx-auto px-6 md:px-8">
        <div class="flex flex-col gap-4 mb-16">
          <span class="text-xs font-bold text-[var(--color-accent)] uppercase tracking-widest">04 / 프로젝트</span>
          <h2 class="text-[2.5rem] font-bold text-[var(--color-text)]" style="font-family: var(--font-display);">만들어 온 것들</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          {[
            { title: '퀀트 전략 분석 플랫폼', badge: '서비스 기획', desc: '리서처 4명이 매일 쓰는 도구. 200개+ 전략의 정보구조를 재설계하고, 20개+ 페이지를 직접 설계했어요.', img: 'assets/landing/project-quant.jpg', href: `${base}${lang}/projects/quant-platform/` },
            { title: '주주톡: AI 주식 분석', badge: 'AI 설계', desc: '6개 AI 에이전트가 병렬 분석하고, 4명의 투자 페르소나가 토론하는 구조를 설계했어요.', img: 'assets/landing/project-jujutok.jpg', href: `${base}${lang}/projects/jujutok/` },
            { title: 'RATB 로보어드바이저 운용', badge: '전원 통과', desc: '38개 AI 투자 알고리즘을 기획하고, 200개 계좌를 동시에 관리하는 프로세스를 설계했어요.', img: 'assets/landing/project-ratb.jpg', href: `${base}${lang}/blog/2024-01-15-ratb-ai-national-exam/` },
            { title: 'AI 운용지원 시스템', badge: '83% 단축', desc: '운용역 워크플로우를 관찰해서 자동화/판단 단계를 분리. 매매·운용시간을 83% 단축했어요.', img: 'assets/landing/project-aum.jpg', href: `${base}${lang}/projects/quant-platform/` },
          ].map((project) => (
            <a href={project.href} class="project-card group cursor-pointer">
              <div class="bg-[var(--color-bg-card)] rounded-xl overflow-hidden mb-6 aspect-video transition-all duration-500 group-hover:scale-[1.03] shadow-ambient-sm group-hover:shadow-ambient">
                <ColorPlaceholder variant="label" label={project.title} colors={["--color-bg-detail", "--color-accent"]} className="w-full h-full" />
              </div>
              <div class="flex flex-col gap-3">
                <div class="flex justify-between items-start">
                  <h3 class="text-2xl font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">{project.title}</h3>
                  <span class="px-3 py-1 rounded-full text-xs font-bold transition-transform group-hover:scale-110 bg-[var(--color-secondary-container)] text-[var(--color-on-secondary-container)]">{project.badge}</span>
                </div>
                <p class="text-[var(--color-text-muted)]">{project.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Blog Section -->
    <section id="blog" class="py-24 max-w-[1440px] mx-auto px-6 md:px-8">
      <div class="flex items-end justify-between mb-16">
        <div class="flex flex-col gap-4">
          <span class="text-xs font-bold text-[var(--color-accent)] uppercase tracking-widest">05 / 블로그</span>
          <h2 class="text-[2.5rem] font-bold text-[var(--color-text)]" style="font-family: var(--font-display);">최근 글</h2>
        </div>
        <a href={`${base}${lang}/blog/`} class="text-sm font-bold text-[var(--color-accent)] hover:underline hidden sm:inline-flex items-center gap-2">
          전체 보기 →
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
        {posts.map((post, i) => (
          <a href={`${base}${lang}/blog/${post.id}/`} class="blog-item group grid grid-cols-[48px_1fr_auto] items-start gap-4 py-6 transition-all hover:pl-2" style="border-top: 1px solid var(--color-border);">
            <span class="text-2xl font-bold text-[var(--color-outline-variant)] group-hover:text-[var(--color-accent)] transition-colors" style="font-family: var(--font-display);">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <h3 class="text-base font-bold leading-snug text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">{post.data.title}</h3>
              <p class="mt-1 text-xs text-[var(--color-text-faint)] line-clamp-2">{post.data.description}</p>
            </div>
            <div class="text-right flex-shrink-0">
              <p class="text-[10px] uppercase tracking-widest text-[var(--color-accent)] font-bold">{categoryLabels[post.data.category] || post.data.category}</p>
              <p class="mt-1 text-[10px] text-[var(--color-text-faint)]">{post.data.date.toISOString().slice(0, 10)}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Experience Timeline -->
    <section id="timeline" class="py-24 max-w-[1440px] mx-auto px-6 md:px-8">
      <div class="flex flex-col gap-4 mb-24 text-center">
        <span class="text-xs font-bold text-[var(--color-accent)] uppercase tracking-widest">06 / 걸어온 길</span>
        <h2 class="text-[2.5rem] font-bold text-[var(--color-text)]" style="font-family: var(--font-display);">경험의 확장</h2>
      </div>
      <div class="relative space-y-32 timeline-container">
        <!-- Vertical connecting line -->
        <div class="hidden md:block absolute left-1/2 top-6 bottom-6 w-[2px] -translate-x-1/2" style="background: linear-gradient(to bottom, rgba(69, 98, 114, 0.4), rgba(69, 98, 114, 0.2), rgba(69, 98, 114, 0.4));"></div>

        <!-- Step 1 -->
        <div class="timeline-item flex flex-col md:flex-row gap-12 md:items-center">
          <div class="md:w-1/2 md:text-right">
            <span class="text-xs font-bold text-[var(--color-text-faint)] uppercase mb-2 block">2025.04 — 현재</span>
            <h3 class="text-2xl font-bold text-[var(--color-accent)]">알파브릿지 · AI서비스기획본부</h3>
            <p class="text-[var(--color-text-muted)] mt-4 leading-relaxed max-w-lg md:ml-auto">프론트·디자이너 없는 6인 팀에서 퀀트 전략 분석 플랫폼의 서비스 기획·UX·구현을 전담. 200개+ 전략의 정보구조를 재설계하고, 20개+ 페이지를 직접 설계했어요.</p>
          </div>
          <div class="timeline-dot hidden md:flex flex-shrink-0 w-12 h-12 bg-[var(--color-accent)] rounded-full items-center justify-center text-[var(--color-on-accent)] z-10" style="box-shadow: 0 0 0 12px var(--color-bg);">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
          </div>
          <div class="md:w-1/2">
            <div class="p-6 rounded-xl inline-flex gap-2" style="background-color: var(--color-bg-secondary);">
              <span class="px-3 py-1 rounded-full text-xs font-bold uppercase" style="background-color: var(--color-bg-detail); color: var(--color-text);">서비스 기획</span>
              <span class="px-3 py-1 rounded-full text-xs font-bold uppercase" style="background-color: var(--color-bg-detail); color: var(--color-text);">UX 설계</span>
            </div>
          </div>
        </div>

        <!-- Step 2 -->
