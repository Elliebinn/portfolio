---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Hero from '../../components/Hero';
import About from '../../components/About';
import Projects from '../../components/Projects';
import Skills from '../../components/Skills';
import Journey from '../../components/Journey';
import Certifications from '../../components/Certifications';
import Contact from '../../components/Contact';
import Footer from '../../components/Footer';
import BottomNav from '../../components/BottomNav';
import { getCollection } from 'astro:content';

const lang = 'ko';
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const base = import.meta.env.BASE_URL;
---

<Layout title="우혜빈 — AI 서비스 기획자 & 프로덕트 엔지니어">
  <Navbar lang={lang} client:load />
  <main>
    <Hero lang={lang} />
    <About lang={lang} />
    <Projects lang={lang} />

    <section id="blog" class="border-t border-[var(--color-border)] px-6 py-28">
      <div class="mx-auto max-w-7xl">
        <p class="mb-8 font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-muted)]">글</p>
        <div class="mb-12 flex items-end justify-between">
          <h2 class="text-4xl font-bold sm:text-5xl" style="font-family: var(--font-display);">최근 블로그</h2>
          <a href={`${base}blog/`} class="hidden items-center gap-2 text-sm font-medium text-[var(--color-accent-light)] transition-colors hover:text-[var(--color-text)] sm:inline-flex">
            전체 보기 &rarr;
          </a>
        </div>
        <div class="grid gap-[1px] overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-border)] lg:grid-cols-3">
          {posts.map((post) => (
            <a href={`${base}blog/${post.id}/`} class="flex flex-col bg-[var(--color-bg)] p-8 transition-colors hover:bg-[var(--color-bg-card)] group">
              <p class="mb-3 font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-accent-light)]">{post.data.category}</p>
              <h3 class="mb-3 text-lg font-bold leading-snug transition-colors group-hover:text-[var(--color-accent-light)]">{post.data.title}</h3>
              <p class="mb-4 flex-1 text-sm leading-relaxed text-[var(--color-text-muted)]">{post.data.description}</p>
              <p class="font-mono text-[10px] text-[var(--color-text-muted)]">{post.data.date.toISOString().slice(0, 10)}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Skills lang={lang} />
    <Journey lang={lang} />
    <Certifications lang={lang} />
    <Contact lang={lang} />
  </main>
  <Footer />
  <BottomNav lang={lang} client:load />
</Layout>
