  </div>
</section>

<!-- About -->
<section class="section" id="about">
  <div class="section-head reveal">
    <div>
      <p class="section-label">05 / 소개</p>
      <h2 class="section-title syne">금융을 아는 PM이<br/><em>직접 만들면.</em></h2>
    </div>
  </div>

  <div class="about-grid reveal">
    <div>
      <p class="about-lead">
        금융을 이해하는 기획자, 기술로 검증하는 실행자.
      </p>
      <p class="about-body">
        AssetPlus 자산운용에서 AI 투자 알고리즘 38개를 기획했고, 200개 이상의 운용 계좌를 동시에 관리했어요. 디자이너 없는 팀에서 20개+ 분석 페이지를 설계했고, AI 멀티에이전트 주식 분석 플랫폼을 혼자 기획부터 개발까지 했어요. 기획서, 디자인 시스템, 지표 감사까지 — PM이 할 수 있는 rigor의 범위를 넓히는 중.
      </p>
    </div>
    <div>
      <div class="about-details">
        <div>
          <p class="about-kv-label">학력</p>
          <p class="about-kv-value">Johns Hopkins<br/>M.S. Finance</p>
        </div>
        <div>
          <p class="about-kv-label">현재</p>
          <p class="about-kv-value">AssetPlus<br/>2022 — Now</p>
        </div>
        <div>
          <p class="about-kv-label">Domain</p>
          <p class="about-kv-value">Finance &middot; AI<br/>Robo-advisor</p>
        </div>
        <div>
          <p class="about-kv-label">Stack</p>
          <p class="about-kv-value">Figma &middot; Next.js<br/>FastAPI &middot; Claude</p>
        </div>
      </div>
      <div class="skills">
        <span class="skill-pill">Service Planning</span>
        <span class="skill-pill">AI Agents</span>
        <span class="skill-pill">Finance</span>
        <span class="skill-pill">IA Design</span>
        <span class="skill-pill">Prototyping</span>
        <span class="skill-pill">UX Research</span>
      </div>
    </div>
  </div>
</section>

<!-- Contact -->
<section class="contact" id="contact">
  <div class="reveal">
    <p class="section-label">06 / 연락</p>
    <h2 class="contact-title syne">Plan.<br/>Build.<br/><em>Prove.</em></h2>
  </div>
  <div class="contact-grid reveal">
    <div class="contact-item">
      <span class="section-label">Email</span>
      <a href="mailto:elliebinn@gmail.com" data-cursor="Copy">elliebinn@gmail.com <ph-copy weight="regular" size="14"></ph-copy></a>
    </div>
    <div class="contact-item">
      <span class="section-label">LinkedIn</span>
      <a href="#" data-cursor="Visit">hyebin-woo <ph-arrow-up-right weight="regular" size="14"></ph-arrow-up-right></a>
    </div>
    <div class="contact-item">
      <span class="section-label">GitHub</span>
      <a href="#" data-cursor="Visit">Elliebinn <ph-arrow-up-right weight="regular" size="14"></ph-arrow-up-right></a>
    </div>
  </div>
  <footer class="footer">
    <p>&copy; 2026 우혜빈 &middot; Made in Seoul</p>
    <p>포트폴리오 목업 &middot; v1</p>
  </footer>
</section>

<script>
  // Preloader
  window.addEventListener('load', () => {
    setTimeout(() => document.getElementById('preloader').classList.add('done'), 1400);
  });

  // Nav scroll
  const nav = document.getElementById('nav');
  let lastY = 0;
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (y > 60) nav.classList.add('scrolled'); else nav.classList.remove('scrolled');
    lastY = y;
  });

  // Scroll indicator
  const scrollFill = document.getElementById('scrollFill');
  const scrollIndicator = document.getElementById('scrollIndicator');
  window.addEventListener('scroll', () => {
    const pct = Math.min(100, (window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100);
    scrollFill.style.height = pct + '%';
    if (pct > 95) scrollIndicator.classList.add('hidden');
    else scrollIndicator.classList.remove('hidden');
  });

  // Custom cursor — ring + dot
  const cursor = document.getElementById('cursor');
  const cursorLabel = document.getElementById('cursorLabel');
  let mx = 0, my = 0, cx = 0, cy = 0;
  document.addEventListener('mousemove', (e) => { mx = e.clientX; my = e.clientY; });
  function loop() {
    cx += (mx - cx) * 0.5; cy += (my - cy) * 0.5;
    cursor.style.transform = `translate(${cx}px, ${cy}px)`;
    requestAnimationFrame(loop);
  }
  loop();

  document.querySelectorAll('[data-cursor]').forEach(el => {
    el.addEventListener('mouseenter', () => {
      cursor.classList.add('hover', 'has-label');
      cursorLabel.textContent = el.dataset.cursor;
    });
    el.addEventListener('mouseleave', () => {
      cursor.classList.remove('hover', 'has-label');
    });
  });
  document.querySelectorAll('a, button').forEach(el => {
    if (!el.dataset.cursor) {
      el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
      el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
    }
  });

  // Copy email
  document.querySelectorAll('a[href^="mailto:"]').forEach(a => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      const email = a.href.replace('mailto:', '');
      navigator.clipboard?.writeText(email);
      cursorLabel.textContent = 'Copied ✓';
      setTimeout(() => { cursorLabel.textContent = 'Copy'; }, 1500);
    });
  });

  // Theme toggle
  const toggle = document.getElementById('themeToggle');
  const themeIcon = document.getElementById('themeIcon');
  const saved = localStorage.getItem('hb-theme');
  if (saved) document.documentElement.setAttribute('data-theme', saved);
  function updateIcon() {
    const t = document.documentElement.getAttribute('data-theme');
    themeIcon.outerHTML = t === 'dark'
      ? '<ph-sun weight="regular" size="16" id="themeIcon"></ph-sun>'
      : '<ph-moon weight="regular" size="16" id="themeIcon"></ph-moon>';
  }
  updateIcon();
  toggle.addEventListener('click', () => {
    const cur = document.documentElement.getAttribute('data-theme');
    const next = cur === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('hb-theme', next);
    updateIcon();
  });

  // Reveal
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>

</V2Layout>
