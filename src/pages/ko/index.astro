<style is:global>
  /* Hero animations */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up { animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }

  /* Timeline scroll reveal */
  .timeline-item {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .timeline-item.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .timeline-dot {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }
  .timeline-item:hover .timeline-dot {
    transform: scale(1.15);
  }
  .timeline-item:hover h3 {
    color: var(--color-accent-light);
  }

  /* Method step hover */
  .method-step {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .method-step:hover {
    transform: translateX(8px);
  }
  .method-step:hover .method-number {
    transform: scale(1.1);
  }
  .method-number {
    transition: transform 0.4s ease;
  }

  /* Blog item hover */
  .blog-item {
    transition: padding-left 0.3s ease;
  }

  /* Radar SVG draw animation (I1 variant — PRD §10.3 Capabilities) */
  .radar-grid,
  .radar-value {
    stroke-dasharray: 500;
    stroke-dashoffset: 500;
    transition: none;
  }
  .radar-value {
    fill-opacity: 0;
  }
  [data-radar].is-visible .radar-grid {
    animation: radar-draw 600ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  [data-radar].is-visible .radar-value {
    animation: radar-draw 600ms cubic-bezier(0.22, 1, 0.36, 1) 200ms forwards,
               radar-fill 400ms ease 600ms forwards;
  }
  @keyframes radar-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes radar-fill {
    to { fill-opacity: 1; }
  }

  /* prefers-reduced-motion: 즉시 표시 */
  @media (prefers-reduced-motion: reduce) {
    .radar-grid,
    .radar-value {
      stroke-dashoffset: 0;
      fill-opacity: 1;
      animation: none !important;
    }
  }
</style>

<script>
  // Timeline scroll fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.2,
    rootMargin: '0px 0px -80px 0px'
  });

  document.querySelectorAll('.timeline-item').forEach(item => {
    observer.observe(item);
  });

  // Radar SVG draw-on-scroll (Capabilities section)
  const radarSvg = document.querySelector('[data-radar]');
  if (radarSvg) {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) {
      radarSvg.classList.add('is-visible');
    } else {
      const radarObs = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            radarObs.disconnect();
          }
        });
      }, { threshold: 0.3 });
      radarObs.observe(radarSvg);
    }
  }
</script>
