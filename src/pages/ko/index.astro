---
import V2Layout from '../../layouts/V2Layout.astro';
---
<V2Layout title="Hyebin Woo — AI Product Manager" lang="ko">

<!-- Preloader -->
<div id="preloader">
  <div class="pl-name"><span>Hyebin</span>&nbsp;<span>Woo</span></div>
  <div class="pl-bar"><div class="pl-fill"></div></div>
</div>

<!-- Scroll Indicator -->
<div class="scroll-indicator" id="scrollIndicator">
  <div class="scroll-line"><div class="scroll-line-fill" id="scrollFill"></div></div>
  <span class="scroll-label">Scroll</span>
</div>

<!-- Custom Cursor -->
<div class="cursor" id="cursor">
  <div class="cursor-dot"></div>
  <div class="cursor-ring"></div>
  <div class="cursor-label" id="cursorLabel"></div>
</div>

<!-- Navigation -->
<nav class="nav" id="nav">
  <a href="#home" class="nav-brand">Hyebin.</a>
  <div class="nav-links">
    <a href="#work" class="nav-link">Work</a>
    <a href="#about" class="nav-link">About</a>
    <a href="#contact" class="nav-link">Contact</a>
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
      <ph-sun weight="regular" size="16" id="themeIcon"></ph-sun>
    </button>
    <a href="#contact" class="nav-cta">연락하기 <ph-hand-waving weight="fill" size="14"></ph-hand-waving></a>
  </div>
</nav>

<!-- Hero -->
<section class="hero" id="home">
  <div class="hero-meta">
    <div class="hero-meta-col">
      <span class="label">Based in</span>
      <span>Seoul, KR</span>
    </div>
    <div class="hero-meta-col" style="text-align: right;">
      <span class="label">Portfolio</span>
      <span>2026 / v1</span>
    </div>
  </div>

  <div>
    <div>
      <p class="label" style="margin-bottom: 32px;">AI Product Manager &middot; 2022—Now</p>
      <h1 class="hero-title syne">
        <span class="line"><span>Hyebin</span></span>
        <span class="line"><span><em>Woo.</em></span></span>
      </h1>
      <p class="hero-subtitle">
        PRD를 쓰고, HTML 목업을 만들고, 지표 산식까지 감사하는 AI PM. 38개 AI 투자 알고리즘 기획, 200+ 실운용 계좌, 운용시간 83% 단축.
      </p>
    </div>
  </div>
</section>

<!-- Marquee -->
<div class="marquee">
  <div class="marquee-track">
    <span class="marquee-item">Service Planning</span><span class="marquee-item marquee-dot">&#10022;</span>
    <span class="marquee-item">AI Agents</span><span class="marquee-item marquee-dot">&#10022;</span>
    <span class="marquee-item">Finance Domain</span><span class="marquee-item marquee-dot">&#10022;</span>
    <span class="marquee-item">Information Architecture</span><span class="marquee-item marquee-dot">&#10022;</span>
    <span class="marquee-item">UX Design</span><span class="marquee-item marquee-dot">&#10022;</span>
    <span class="marquee-item">Prototyping</span><span class="marquee-item marquee-dot">&#10022;</span>
    <span class="marquee-item">Service Planning</span><span class="marquee-item marquee-dot">&#10022;</span>
    <span class="marquee-item">AI Agents</span><span class="marquee-item marquee-dot">&#10022;</span>
    <span class="marquee-item">Finance Domain</span><span class="marquee-item marquee-dot">&#10022;</span>
    <span class="marquee-item">Information Architecture</span><span class="marquee-item marquee-dot">&#10022;</span>
    <span class="marquee-item">UX Design</span><span class="marquee-item marquee-dot">&#10022;</span>
    <span class="marquee-item">Prototyping</span><span class="marquee-item marquee-dot">&#10022;</span>
  </div>
</div>

<!-- Work -->
<section class="section" id="work">
  <div class="section-head reveal">
    <div>
      <p class="section-label">01 / 주요 작업</p>
      <h2 class="section-title syne"><em>세 번의</em> 판단.</h2>
    </div>
    <p class="section-label">2022 — 2026</p>
  </div>

  <div class="work-grid">

    <!-- Case 1 -->
    <a href="#" class="work-card reveal" data-cursor="View case">
      <div class="work-card-meta">
        <div class="work-num">&#8470; 01 &middot; 케이스 스터디 &middot; FinTech Platform</div>
        <div>
          <h3 class="work-title">리서처가 매일 여는<br/>첫 화면을<br/>다시 만들었습니다.</h3>
          <p class="work-sub">리서처 4명이 매일 쓰는 도구. 디자이너도, 프론트엔드 개발자도 없는 팀에서 200개+ 전략의 정보구조를 재설계하고, HTML 목업이 그대로 제품이 됐어요.</p>
        </div>
        <div class="work-details">
          <div class="work-info">
            <div class="work-info-item">
              <span class="work-info-label">Company</span>
              <span class="work-info-value">AssetPlus</span>
            </div>
            <div class="work-info-item">
              <span class="work-info-label">Role</span>
              <span class="work-info-value">AI Product Manager</span>
            </div>
            <div class="work-info-item">
              <span class="work-info-label">Year</span>
              <span class="work-info-value">2025 — Now</span>
            </div>
          </div>
          <div class="work-metrics">
            <div>
              <div class="work-metric-value">32<em>&uarr;</em></div>
              <div class="work-metric-label">목업 제작</div>
            </div>
            <div>
              <div class="work-metric-value">20<em>+</em></div>
              <div class="work-metric-label">페이지 설계</div>
            </div>
          </div>
        </div>
      </div>
      <div class="work-visual">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="work-corner"><ph-arrow-up-right weight="regular" size="20"></ph-arrow-up-right></div>
        <div class="work-mock">
          <div style="display: flex; gap: 6px; margin-bottom: 8px;">
            <span style="width:8px;height:8px;border-radius:50%;background:var(--border);"></span>
            <span style="width:8px;height:8px;border-radius:50%;background:var(--border);"></span>
            <span style="width:8px;height:8px;border-radius:50%;background:var(--border);"></span>
          </div>
          <div class="mock-bar md"></div>
          <div class="mock-bar sm"></div>
          <div class="mock-grid">
            <div class="mock-cell accent"></div>
            <div class="mock-cell"></div>
            <div class="mock-cell"></div>
          </div>
          <div class="mock-bar lg"></div>
          <div class="mock-bar md"></div>
          <div class="mock-bar sm"></div>
        </div>
      </div>
    </a>

    <!-- Case 2 -->
    <a href="#" class="work-card reveal" data-cursor="View case">
      <div class="work-card-meta">
        <div class="work-num">&#8470; 02 &middot; 케이스 스터디 &middot; Solo Build</div>
        <div>
          <h3 class="work-title">6개 AI 에이전트,<br/>4명의 투자자가<br/>토론합니다.</h3>
          <p class="work-sub">AI 멀티에이전트 주식 분석 플랫폼. 에이전트가 분석하고, 투자 페르소나가 토론한 뒤 결론을 내리는 bias-mitigation 구조. 기획부터 개발까지 혼자.</p>
        </div>
        <div class="work-details">
          <div class="work-info">
            <div class="work-info-item">
              <span class="work-info-label">Type</span>
              <span class="work-info-value">Solo Build</span>
            </div>
            <div class="work-info-item">
              <span class="work-info-label">Role</span>
              <span class="work-info-value">PM + Engineer</span>
            </div>
            <div class="work-info-item">
              <span class="work-info-label">Year</span>
              <span class="work-info-value">2025</span>
            </div>
          </div>
          <div class="work-metrics">
            <div>
              <div class="work-metric-value">6</div>
              <div class="work-metric-label">에이전트</div>
            </div>
            <div>
              <div class="work-metric-value">31<em>k</em></div>
              <div class="work-metric-label">LOC Solo</div>
            </div>
          </div>
        </div>
      </div>
      <div class="work-visual">
        <div class="blob blob-1" style="background: #6884A0;"></div>
        <div class="blob blob-2" style="background: #3D8268;"></div>
        <div class="work-corner"><ph-arrow-up-right weight="regular" size="20"></ph-arrow-up-right></div>
        <div class="work-mock">
          <div class="mock-bar md"></div>
          <div class="mock-bar lg"></div>
          <div class="mock-grid" style="grid-template-columns: repeat(2, 1fr);">
            <div class="mock-cell"></div>
            <div class="mock-cell accent"></div>
            <div class="mock-cell"></div>
            <div class="mock-cell"></div>
          </div>
          <div class="mock-bar sm"></div>
        </div>
      </div>
    </a>

    <!-- Case 3 -->
    <a href="#" class="work-card reveal" data-cursor="View case">
      <div class="work-card-meta">
        <div class="work-num">&#8470; 03 &middot; 케이스 스터디 &middot; Regulated Review</div>
        <div>
          <h3 class="work-title">로보어드바이저<br/>국가 심사,<br/>3회 전원 통과.</h3>
          <p class="work-sub">RATB 알고리즘 운용. 22차(2개) &rarr; 23차(8개) &rarr; 24차(28개)로 확장하며 전원 통과.</p>
        </div>
        <div class="work-details">
          <div class="work-info">
            <div class="work-info-item">
              <span class="work-info-label">Company</span>
              <span class="work-info-value">AssetPlus</span>
            </div>
            <div class="work-info-item">
              <span class="work-info-label">Role</span>
              <span class="work-info-value">Algorithm Planner</span>
            </div>
            <div class="work-info-item">
              <span class="work-info-label">Year</span>
              <span class="work-info-value">2022 — 2024</span>
            </div>
          </div>
          <div class="work-metrics">
            <div>
              <div class="work-metric-value">38</div>
              <div class="work-metric-label">알고리즘</div>
            </div>
            <div>
              <div class="work-metric-value">3<em>/3</em></div>
              <div class="work-metric-label">심사 통과</div>
            </div>
          </div>
        </div>
      </div>
      <div class="work-visual">
        <div class="blob blob-1" style="background: #D4833D;"></div>
        <div class="blob blob-2" style="background: #7E6EA0;"></div>
        <div class="work-corner"><ph-arrow-up-right weight="regular" size="20"></ph-arrow-up-right></div>
        <div class="work-mock">
          <div class="mock-bar lg"></div>
          <div class="mock-bar md"></div>
          <div style="height: 60px; background: linear-gradient(to top right, var(--border), transparent); border-radius: 4px; margin: 8px 0; position: relative;">
            <div style="position: absolute; right: 20%; top: 30%; width: 8px; height: 8px; border-radius: 50%; background: var(--accent);"></div>
          </div>
          <div class="mock-bar sm"></div>
        </div>
      </div>
