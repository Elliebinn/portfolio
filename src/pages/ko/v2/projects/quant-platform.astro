---
import EditorialLayout from '../../../../layouts/EditorialLayout.astro';
import Navbar from '../../../../components/editorial/Navbar';
import CaseStudy from '../../../../components/editorial/CaseStudy';
import Footer from '../../../../components/editorial/Footer';
import { quantPlatform } from '../../../../data/projects';

const lang = 'ko';
const project = quantPlatform[lang];
---

<EditorialLayout title={`${project.title} — HYEBIN.DEV`}>
  <Navbar lang={lang} client:load />
  <main>
    <CaseStudy project={project} lang={lang} />
  </main>
  <Footer lang={lang} />
</EditorialLayout>
