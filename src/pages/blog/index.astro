---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categoryLabels: Record<string, string> = {
  project: 'Project',
  tech: 'Tech',
  planning: 'Planning',
  retrospective: 'Retrospective',
};

const base = import.meta.env.BASE_URL;
---

<Layout title="Blog — Hyebin Woo">
  <Navbar client:load />

  <main class="px-6 pt-32 pb-20">
    <div class="mx-auto max-w-7xl">
      <p class="mb-8 font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-muted)]">
        Writings
      </p>
      <h1 class="mb-4 text-4xl font-bold sm:text-5xl" style="font-family: var(--font-display);">
        Blog
      </h1>
      <p class="mb-16 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)]">
        프로젝트 회고, 기술적 의사결정, 기획 인사이트를 기록합니다.
      </p>

      <div class="space-y-0">
        {posts.map((post, i) => (
          <a
            href={`${base}blog/${post.id}/`}
            class={`group grid items-start gap-6 py-10 lg:grid-cols-[120px_1fr_1fr] ${
              i !== posts.length - 1 ? 'border-b border-[var(--color-border)]' : ''
            }`}
          >
            <div class="flex items-center gap-3">
              <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-accent-light)]">
                {categoryLabels[post.data.category]}
              </span>
            </div>
            <div>
              <h2 class="mb-2 text-xl font-bold transition-colors group-hover:text-[var(--color-accent-light)]" style="font-family: var(--font-display);">
                {post.data.title}
              </h2>
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag: string) => (
                  <span class="rounded-full border border-[var(--color-border)] px-2.5 py-0.5 font-mono text-[10px] text-[var(--color-text-muted)]">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
            <div>
              <p class="mb-3 text-sm leading-[1.8] text-[var(--color-text-muted)]">
                {post.data.description}
              </p>
              <p class="font-mono text-[10px] text-[var(--color-text-muted)]">
                {post.data.date.toISOString().slice(0, 10)}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
