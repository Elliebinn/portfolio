---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Hero from '../../components/Hero';
import About from '../../components/About';
import Projects from '../../components/Projects';
import Skills from '../../components/Skills';
import Journey from '../../components/Journey';
import Certifications from '../../components/Certifications';
import Contact from '../../components/Contact';
import Footer from '../../components/Footer';
import BottomNav from '../../components/BottomNav';
import { getCollection } from 'astro:content';

const lang = 'en';
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const base = import.meta.env.BASE_URL;
---

<Layout title="HYEBIN.DEV">
  <Navbar lang={lang} client:load />
  <main>
    <Hero lang={lang} />
    <About lang={lang} />
    <Projects lang={lang} />

    <section id="blog" class="border-t border-[var(--color-border)] px-6 py-28">
      <div class="mx-auto max-w-7xl">
        <p class="mb-8 text-xs uppercase tracking-[0.15em] text-[var(--color-text-muted)]">Writings</p>
        <div class="mb-12 flex items-end justify-between">
          <h2 class="text-4xl font-bold sm:text-5xl" style="font-family: var(--font-display);">From the Blog</h2>
          <a href={`${base}blog/`} class="hidden items-center gap-2 text-sm font-medium text-[var(--color-accent-light)] transition-colors hover:text-[var(--color-text)] sm:inline-flex">
            View all &rarr;
          </a>
        </div>

        {/* Numbered list */}
        <div>
          {posts.map((post, i) => (
            <a href={`${base}blog/${post.id}/`} class="group grid grid-cols-[48px_1fr_auto] sm:grid-cols-[64px_1fr_auto] items-center gap-4 sm:gap-6 border-t border-[var(--color-border)] py-6 transition-[padding] hover:pl-2">
              <span class="text-3xl sm:text-4xl font-bold text-[var(--color-text)]/10 transition-colors group-hover:text-[var(--color-accent-light)]" style="font-family: var(--font-mono);">
                {String(i + 1).padStart(2, '0')}
              </span>
              <div>
                <h3 class="text-[15px] sm:text-base font-bold leading-snug transition-colors group-hover:text-[var(--color-accent-light)]">{post.data.title}</h3>
                <p class="mt-1 hidden text-sm leading-relaxed text-[var(--color-text-muted)] sm:line-clamp-1">{post.data.description}</p>
              </div>
              <div class="text-right">
                <p class="text-xs uppercase tracking-[0.15em] text-[var(--color-accent-light)]">{post.data.category}</p>
                <p class="mt-1 text-xs text-[var(--color-text-muted)]" style="font-family: var(--font-mono);">{post.data.date.toISOString().slice(0, 10)}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Skills lang={lang} />
    <Journey lang={lang} />
    <Certifications lang={lang} />
    <Contact lang={lang} />
  </main>
  <Footer />
  <BottomNav lang={lang} client:load />
</Layout>
