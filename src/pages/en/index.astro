    <a href="/ko/work/aed" class="work-card reveal" data-cursor="View case" style="grid-template-columns: 1fr 1fr;">
      <div class="work-card-meta">
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:24px;">
          <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--muted);">01</span>
          <span class="wip-badge">● Work in Progress</span>
        </div>
        <div>
          <p style="font-size:13px; color:var(--muted); margin-bottom:8px;">Alphabridge / 2025 — Now</p>
