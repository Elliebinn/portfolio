          <div style="display:flex; gap:8px; margin-bottom:24px;">
            <span style="font-size:11px; padding:4px 12px; border:1px solid var(--border); border-radius:100px; color:var(--muted);">FinTech</span>
            <span style="font-size:11px; padding:4px 12px; border:1px solid var(--border); border-radius:100px; color:var(--muted);">Dashboard</span>
          </div>
        </div>
