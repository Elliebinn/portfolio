---
import EditorialLayout from '../../../layouts/EditorialLayout.astro';
import Navbar from '../../../components/editorial/Navbar';
import Hero from '../../../components/editorial/Hero';
import About from '../../../components/editorial/About';
import Projects from '../../../components/editorial/Projects';
import Skills from '../../../components/editorial/Skills';
import Journey from '../../../components/editorial/Journey';
import Certifications from '../../../components/editorial/Certifications';
import Contact from '../../../components/editorial/Contact';
import { TextColor } from '../../../components/ui/text-color';
import Footer from '../../../components/editorial/Footer';
import { getCollection } from 'astro:content';

const lang = 'en';
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const base = import.meta.env.BASE_URL;
---

<EditorialLayout title="HYEBIN.DEV — Editorial">
  <Navbar lang={lang} client:load />
  <main>
    <Hero lang={lang} />
    <About lang={lang} />
    <Projects lang={lang} />

    <!-- Blog section (inline Astro) -->
    <section
      class="px-6 py-20 sm:py-28 rounded-3xl mx-4 sm:mx-8"
      style="background-color: var(--ed-surface-container-low);"
    >
      <div class="mx-auto max-w-4xl text-center mb-16">
        <h2
          class="text-3xl font-bold sm:text-4xl mb-4"
          style="font-family: var(--ed-font-display); color: var(--ed-on-surface); letter-spacing: -0.02em;"
        >
          Insights & Musings
        </h2>
        <p style="color: var(--ed-on-surface-variant); font-family: var(--ed-font-body);">
          Project retrospectives, technical decisions, and planning insights.
        </p>
      </div>

      <div class="mx-auto max-w-4xl grid grid-cols-1 md:grid-cols-2 gap-6">
        {posts.map((post) => (
          <a
            href={`${base}blog/${post.id}/`}
            class="group rounded-2xl p-8 transition-transform duration-300 hover:-translate-y-1"
            style="background-color: var(--ed-surface-white);"
          >
            <time
              class="text-sm mb-4 block"
              style="color: var(--ed-outline); font-family: var(--ed-font-body);"
            >
              {post.data.date.toISOString().slice(0, 10)}
            </time>
            <h4
              class="text-xl font-bold mb-4 group-hover:opacity-70 transition-opacity"
              style="font-family: var(--ed-font-display); color: var(--ed-on-surface);"
            >
              {post.data.title}
            </h4>
            <p
              class="text-sm mb-6 line-clamp-2"
              style="color: var(--ed-on-surface-variant); font-family: var(--ed-font-body);"
            >
              {post.data.description}
            </p>
            <span
              class="text-sm font-bold flex items-center gap-1"
              style="font-family: var(--ed-font-display); color: var(--ed-primary);"
            >
              Read article
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            </span>
          </a>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a
          href={`${base}blog/`}
          class="text-sm font-bold"
          style="font-family: var(--ed-font-display); color: var(--ed-primary);"
        >
          View all posts &rarr;
        </a>
      </div>
    </section>

    <Skills lang={lang} />
    <Journey lang={lang} />
    <Certifications lang={lang} />
    <Contact lang={lang} />
    <TextColor client:visible />
  </main>
  <Footer lang={lang} />
</EditorialLayout>
