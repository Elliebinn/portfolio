---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';

const lang = 'en';
---

<Layout title="Resume — Hyebin Woo">
  <Navbar lang={lang} client:load />

  <main class="pt-32 pb-24 px-6 md:px-12 max-w-7xl mx-auto">

    <!-- Header: 2-column (intro + contact) -->
    <header class="mb-20 flex flex-col md:flex-row justify-between items-end gap-8">
      <div class="max-w-2xl">
        <span class="text-xs font-bold text-[var(--color-accent)] tracking-widest uppercase mb-3 block">Curriculum Vitae</span>
        <div class="mb-6 pb-6 border-b border-[var(--color-bg-emphasis)]">
          <p class="text-2xl md:text-3xl font-bold text-[var(--color-text)] tracking-tight" style="font-family: var(--font-display);">
            Hyebin Woo <span class="text-[var(--color-text-faint)] font-medium">/ 우혜빈</span>
          </p>
          <p class="text-sm font-semibold tracking-widest uppercase text-[var(--color-text-muted)] mt-1">
            AI Product Planner · Finance
          </p>
        </div>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight mb-6 leading-[1.15] text-[var(--color-text)] break-keep" style="font-family: var(--font-display);">
          Turning financial complexity<br/>
          <span class="text-[var(--color-accent)]">into product simplicity.</span>
        </h1>
        <p class="text-xl text-[var(--color-text-muted)] leading-relaxed break-keep">
          Planned 38 AI investment algorithms and passed national regulatory review. Designed the ops process that manages 200+ accounts simultaneously.
        </p>
      </div>
      <div class="flex flex-col gap-3 items-start md:items-end w-full md:w-auto">
        <a href="mailto:elliebinn@gmail.com" class="flex items-center gap-3 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          <span class="text-sm font-medium">elliebinn@gmail.com</span>
        </a>
        <a href="https://www.linkedin.com/in/hyebin-woo-62a261291/" target="_blank" class="flex items-center gap-3 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
          <span class="text-sm font-medium">LinkedIn</span>
        </a>
        <a href="https://github.com/Elliebinn" target="_blank" class="flex items-center gap-3 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>
          <span class="text-sm font-medium">GitHub</span>
        </a>
        <div class="flex items-center gap-3 text-[var(--color-text-muted)]">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span class="text-sm font-medium">Seoul / Remote</span>
        </div>
      </div>
    </header>

    <!-- 2-column: 8/12 + 4/12 -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">

      <!-- Left: Experience Timeline -->
      <div class="lg:col-span-8">
        <h2 class="text-3xl font-bold tracking-tight mb-12 flex items-center gap-4 text-[var(--color-text)]" style="font-family: var(--font-display);">
          Experience
          <span class="h-[2px] flex-grow bg-[var(--color-bg-emphasis)]"></span>
        </h2>

        <div class="relative pl-8">
          <!-- Timeline vertical line -->
          <div class="absolute left-0 top-2 bottom-0 w-[2px] bg-[var(--color-bg-emphasis)]"></div>

          <!-- AlphaBridge -->
          <div class="mb-16 relative">
            <div class="absolute -left-[37px] top-1.5 w-4 h-4 rounded-full border-4 border-[var(--color-bg)] bg-[var(--color-accent)]"></div>
            <div class="flex flex-col md:flex-row justify-between items-start mb-4 gap-2">
              <div>
                <h3 class="text-2xl font-bold text-[var(--color-text)]">AI Service Planning Division</h3>
                <p class="text-lg font-semibold text-[var(--color-accent)]">AlphaBridge · AssetPlus Asset Management Subsidiary</p>
              </div>
              <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] bg-[var(--color-bg-detail)] px-3 py-1 rounded-full">2025.04 — Present</span>
            </div>
            <ul class="space-y-4 text-[var(--color-text-muted)] leading-relaxed">
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                Sole service planning & UX lead on a 6-person team with no frontend engineers or designers
              </li>
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                Redesigned the taxonomy for 200+ strategies with a tag-based classification system, restructured 13 sidebar menus around actual workflows
              </li>
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                Identified that an "add search" request was actually a missing classification system — designed the feature users hadn't articulated
              </li>
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                Built the design system from scratch + converted 25 HTML mockups into 20+ consistent pages
              </li>
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                UX/UI designer feedback (2.5/5 → 3.9/5) → decomposed into 7 requirements → improved using 14 references
              </li>
            </ul>
          </div>

          <!-- AssetPlus -->
          <div class="mb-16 relative">
            <div class="absolute -left-[37px] top-1.5 w-4 h-4 rounded-full border-4 border-[var(--color-bg)] bg-[var(--color-accent)]"></div>
            <div class="flex flex-col md:flex-row justify-between items-start mb-4 gap-2">
              <div>
                <h3 class="text-2xl font-bold text-[var(--color-text)]">AI Asset Management Team</h3>
                <p class="text-lg font-semibold text-[var(--color-accent)]">AssetPlus Asset Management</p>
              </div>
              <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] bg-[var(--color-bg-detail)] px-3 py-1 rounded-full">2023.09 — 2025.03</span>
            </div>
            <ul class="space-y-4 text-[var(--color-text-muted)] leading-relaxed">
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                Planned 38 AI investment algorithms, managed ~200 accounts concurrently. All 22nd–24th regulatory reviews passed / top return 19.5%
              </li>
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                Designed the ETF universe classification framework (4 groups) and investor-profile allocation logic
              </li>
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                Planned AI trading support system — reduced execution time from 1hr+ to 10min (83% reduction)
              </li>
              <li class="flex gap-3">
                <span class="text-[var(--color-accent)] mt-1.5 flex-shrink-0">●</span>
                Launched 2 S&P500 AI mutual funds (currently managing client capital), signed MOU with Daol Asset Management
              </li>
            </ul>
          </div>

          <!-- Side Project -->
          <div class="relative">
            <div class="absolute -left-[37px] top-1.5 w-4 h-4 rounded-full border-4 border-[var(--color-bg)] bg-[var(--color-accent)]"></div>
            <div class="flex flex-col md:flex-row justify-between items-start mb-4 gap-2">
              <div>
                <h3 class="text-2xl font-bold text-[var(--color-text)]">JujuTok</h3>
                <p class="text-lg font-semibold text-[var(--color-accent)]">Side Project · Solo Planning + Development</p>
              </div>
            </div>
            <p class="text-[var(--color-text-muted)] leading-relaxed">
              "Can the bias of a single AI be solved through system structure?" — Designed a system where 6 AI agents separate the analytical axes and 4 investor personas debate before reaching a conclusion. Planned and built end-to-end.
            </p>
          </div>
        </div>
      </div>

      <!-- Right: Sidebar -->
      <div class="lg:col-span-4 space-y-12">

        <!-- Education -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            Education
          </h2>
          <div class="space-y-6">
            <div class="bg-[var(--color-bg-card)] p-6 rounded-xl">
              <h4 class="font-bold text-lg mb-1 text-[var(--color-text)]">Johns Hopkins University</h4>
              <p class="text-[var(--color-accent)] font-medium mb-2">B.A. Economics (Minor: Marketing)</p>
              <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-faint)]">2017.08 — 2019.05</span>
            </div>
            <div class="bg-[var(--color-bg-card)] p-6 rounded-xl">
              <h4 class="font-bold text-lg mb-1 text-[var(--color-text)]">Fullerton College</h4>
              <p class="text-[var(--color-accent)] font-medium mb-2">A.A. Economics</p>
              <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-faint)]">2016.01 — 2017.05</span>
            </div>
          </div>
        </section>

        <!-- Skills -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            Skills
          </h2>
          <div class="flex flex-wrap gap-2">
            {['Service Planning', 'Information Architecture', 'UX Design', 'Requirement Specs', 'Design Systems', 'AI Agent Design', 'Prompt Engineering', 'Claude Code', 'Python', 'React', 'FastAPI', 'SQL'].map((skill) => (
              <span class="px-4 py-2 bg-[var(--color-secondary-container)] text-[var(--color-on-secondary-container)] rounded-full text-sm font-semibold">
                {skill}
              </span>
            ))}
          </div>
        </section>

        <!-- Tools -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            Tools
          </h2>
          <div class="grid grid-cols-2 gap-4">
            <div class="flex items-center gap-3 p-3 bg-[var(--color-bg-secondary)] rounded-lg">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              <span class="text-sm font-bold text-[var(--color-text)]">Claude Code</span>
            </div>
            <div class="flex items-center gap-3 p-3 bg-[var(--color-bg-secondary)] rounded-lg">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              <span class="text-sm font-bold text-[var(--color-text)]">Figma</span>
            </div>
            <div class="flex items-center gap-3 p-3 bg-[var(--color-bg-secondary)] rounded-lg">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              <span class="text-sm font-bold text-[var(--color-text)]">VS Code</span>
            </div>
            <div class="flex items-center gap-3 p-3 bg-[var(--color-bg-secondary)] rounded-lg">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="text-[var(--color-accent)]"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
              <span class="text-sm font-bold text-[var(--color-text)]">n8n</span>
            </div>
          </div>
        </section>

        <!-- Certifications -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            Certifications
          </h2>
          <div class="space-y-3">
            {[
              { name: 'SQL Developer (SQLD)', date: '2026.03' },
              { name: 'Securities Investment Advisory', date: '2024.05' },
              { name: 'Derivatives Investment Advisory', date: '2024.02' },
              { name: 'Fund Investment Advisory', date: '2023.12' },
              { name: 'AFPK', date: '2022.04' },
              { name: 'Investment Asset Manager', date: '2021.12' },
            ].map((cert) => (
              <div class="flex items-baseline justify-between">
                <p class="font-bold text-sm text-[var(--color-text)]">{cert.name}</p>
                <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-faint)]">{cert.date}</span>
              </div>
            ))}
          </div>
        </section>

        <!-- Languages -->
        <section>
          <h2 class="text-xl font-bold tracking-tight mb-6 uppercase text-[var(--color-accent)]" style="font-family: var(--font-display); border-bottom: 1px solid var(--color-bg-emphasis); padding-bottom: 0.5rem;">
            Languages
          </h2>
          <div class="space-y-2">
            <p class="font-bold text-[var(--color-text)]">Korean (Native) · English (Business Advanced)</p>
            <p class="text-sm text-[var(--color-text-faint)]">B.A. from Johns Hopkins University</p>
          </div>
        </section>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
