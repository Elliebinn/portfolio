---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/translations';

const lang = 'en';
const tr = t(lang);

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categoryLabels: Record<string, string> = {
  project: 'Project',
  planning: 'Planning',
  'deep-dive': 'Deep Dive',
  skill: 'Skill',
};

const base = import.meta.env.BASE_URL;
---

<Layout title={`${tr.blog.pageTitle} — Hyebin Woo`}>
  <Navbar lang={lang} client:load />

  <main class="px-6 pt-32 pb-20">
    <div class="mx-auto max-w-7xl">
      <p class="mb-8 font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-muted)]">
        {tr.blog.section}
      </p>
      <h1 class="mb-4 text-4xl font-bold sm:text-5xl" style="font-family: var(--font-display);">
        {tr.blog.pageTitle}
      </h1>
      <p class="mb-10 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)]">
        {tr.blog.pageDescription}
      </p>

      <div class="mb-12 flex flex-wrap gap-2" id="category-filters">
        <button
          data-category="all"
          class="category-btn active rounded-full border border-[var(--color-accent-light)] bg-[var(--color-accent-light)] px-4 py-1.5 font-mono text-[11px] uppercase tracking-[0.15em] text-[var(--color-bg)] transition-all"
        >
          All
        </button>
        {Object.entries(categoryLabels).map(([key, label]) => (
          <button
            data-category={key}
            class="category-btn rounded-full border border-[var(--color-border)] px-4 py-1.5 font-mono text-[11px] uppercase tracking-[0.15em] text-[var(--color-text-muted)] transition-all hover:border-[var(--color-accent-light)] hover:text-[var(--color-accent-light)]"
          >
            {label}
          </button>
        ))}
      </div>

      <div class="space-y-0">
        {posts.map((post, i) => (
          <a
            href={`${base}${lang}/blog/${post.id}/`}
            data-category={post.data.category}
            class={`blog-post group grid items-start gap-6 py-10 lg:grid-cols-[120px_1fr_1fr] ${
              i !== posts.length - 1 ? 'border-b border-[var(--color-border)]' : ''
            }`}
          >
            <div class="flex items-center gap-3">
              <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-accent-light)]">
                {categoryLabels[post.data.category] || post.data.category}
              </span>
            </div>
            <div>
              <h2 class="mb-2 text-xl font-bold transition-colors group-hover:text-[var(--color-accent-light)]" style="font-family: var(--font-display);">
                {post.data.title}
              </h2>
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag: string) => (
                  <span class="rounded-full border border-[var(--color-border)] px-2.5 py-0.5 font-mono text-[10px] text-[var(--color-text-muted)]">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
            <div>
              <p class="mb-3 text-sm leading-[1.8] text-[var(--color-text-muted)]">
                {post.data.description}
              </p>
              <p class="font-mono text-[10px] text-[var(--color-text-muted)]">
                {post.data.date.toISOString().slice(0, 10)}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn');
  const posts = document.querySelectorAll<HTMLElement>('.blog-post');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;

      buttons.forEach(b => {
        b.classList.remove('active', 'border-[var(--color-accent-light)]', 'bg-[var(--color-accent-light)]', 'text-[var(--color-bg)]');
        b.classList.add('border-[var(--color-border)]', 'text-[var(--color-text-muted)]');
      });
      btn.classList.remove('border-[var(--color-border)]', 'text-[var(--color-text-muted)]');
      btn.classList.add('active', 'border-[var(--color-accent-light)]', 'bg-[var(--color-accent-light)]', 'text-[var(--color-bg)]');

      posts.forEach(post => {
        if (category === 'all' || post.dataset.category === category) {
          post.style.display = '';
        } else {
          post.style.display = 'none';
        }
      });
    });
  });
</script>
