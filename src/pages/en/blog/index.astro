---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/translations';

const lang = 'en';
const tr = t(lang);

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categoryLabels: Record<string, string> = {
  project: 'Project',
  planning: 'Planning',
  'deep-dive': 'Deep Dive',
  skill: 'Skill',
};

const base = import.meta.env.BASE_URL;
---

<Layout title={`${tr.blog.pageTitle} — HYEBIN.DEV`}>
  <Navbar lang={lang} client:load />

  <main class="px-6 pt-32 pb-20">
    <div class="mx-auto max-w-7xl">
      <p class="mb-8 text-xs uppercase tracking-[0.15em] text-[var(--color-text-muted)]">
        {tr.blog.section}
      </p>
      <h1 class="mb-4 text-4xl font-bold sm:text-5xl" style="font-family: var(--font-display);">
        {tr.blog.pageTitle}
      </h1>
      <p class="mb-10 max-w-xl text-sm leading-relaxed text-[var(--color-text-muted)]">
        {tr.blog.pageDescription}
      </p>

      <div class="relative mb-12 flex flex-wrap gap-2" id="category-filters">
        <button
          data-category="all"
          class="category-btn active relative z-10 rounded-full border border-transparent px-4 py-1.5 font-mono text-[11px] uppercase tracking-[0.15em] text-[var(--color-bg)] transition-colors duration-200"
        >
          All
        </button>
        {Object.entries(categoryLabels).map(([key, label]) => (
          <button
            data-category={key}
            class="category-btn relative z-10 rounded-full border border-[var(--color-border)] px-4 py-1.5 font-mono text-[11px] uppercase tracking-[0.15em] text-[var(--color-text-muted)] transition-colors duration-200 hover:border-[var(--color-accent-light)] hover:text-[var(--color-accent-light)]"
          >
            {label}
          </button>
        ))}
        <!-- B2: sliding pill background -->
        <span id="filter-pill-bg" class="pointer-events-none absolute rounded-full bg-[var(--color-accent-light)]" aria-hidden="true" style="transition: left 0.25s ease, top 0.25s ease, width 0.25s ease, height 0.25s ease; will-change: left, top, width, height;"></span>
      </div>

      <div class="space-y-0">
        {posts.map((post, i) => (
          <a
            href={`${base}${lang}/blog/${post.id}/`}
            data-category={post.data.category}
            class={`blog-post blog-card-stagger group grid items-start gap-6 py-10 lg:grid-cols-[120px_1fr_1fr] ${
              i !== posts.length - 1 ? 'border-b border-[var(--color-border)]' : ''
            }`}
            style={`animation-delay: ${i * 80}ms`}
          >
            <div class="flex items-center gap-3">
              <span class="text-xs uppercase tracking-[0.15em] text-[var(--color-accent-light)]">
                {categoryLabels[post.data.category] || post.data.category}
              </span>
            </div>
            <div>
              <h2 class="mb-2 text-xl font-bold transition-colors group-hover:text-[var(--color-accent-light)]" style="font-family: var(--font-display);">
                {post.data.title}
              </h2>
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag: string) => (
                  <span class="rounded-full border border-[var(--color-border)] px-2.5 py-0.5 font-mono text-[10px] text-[var(--color-text-muted)]">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
            <div>
              <p class="mb-3 text-sm leading-[1.8] text-[var(--color-text-muted)]">
                {post.data.description}
              </p>
              <p class="font-mono text-[10px] text-[var(--color-text-muted)]">
                {post.data.date.toISOString().slice(0, 10)}
              </p>
            </div>
          </a>
        ))}
      </div>

      <!-- B4: Empty Filter Feedback -->
      <div id="empty-filter" class="hidden py-20 text-center" aria-live="polite">
        <div class="mx-auto mb-6 flex h-24 w-24 items-center justify-center rounded-full" style="background-color: var(--color-bg-detail);">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
            <rect x="4" y="8" width="32" height="24" rx="4" stroke="var(--color-outline-variant)" stroke-width="1.5" fill="none" />
            <line x1="12" y1="18" x2="28" y2="18" stroke="var(--color-outline-variant)" stroke-width="1.5" stroke-linecap="round" />
            <line x1="12" y1="24" x2="22" y2="24" stroke="var(--color-outline-variant)" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </div>
        <p class="text-lg font-bold text-[var(--color-text)]">No posts in this category yet</p>
        <p class="mt-2 text-sm text-[var(--color-text-muted)]">Try another category or browse all posts.</p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @keyframes blog-fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: no-preference) {
    .blog-card-stagger {
      opacity: 0;
      animation: blog-fade-up 0.4s ease forwards;
    }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn');
  const posts = document.querySelectorAll<HTMLElement>('.blog-post');
  const pill = document.getElementById('filter-pill-bg');
  const container = document.getElementById('category-filters');
  const emptyState = document.getElementById('empty-filter');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function movePillTo(btn: HTMLElement) {
    if (!pill || !container) return;
    const containerRect = container.getBoundingClientRect();
    const btnRect = btn.getBoundingClientRect();
    pill.style.left = `${btnRect.left - containerRect.left}px`;
    pill.style.top = `${btnRect.top - containerRect.top}px`;
    pill.style.width = `${btnRect.width}px`;
    pill.style.height = `${btnRect.height}px`;
  }

  function updateEmptyState() {
    if (!emptyState) return;
    const visiblePosts = Array.from(posts).filter(p => p.style.display !== 'none');
    emptyState.classList.toggle('hidden', visiblePosts.length > 0);
  }

  // Init pill on first active button (no transition)
  const initBtn = document.querySelector<HTMLButtonElement>('.category-btn.active');
  if (initBtn && pill) {
    if (prefersReduced) {
      pill.style.transition = 'none';
    }
    movePillTo(initBtn);
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;

      buttons.forEach(b => {
        b.classList.remove('active', 'text-[var(--color-bg)]');
        b.classList.add('border-[var(--color-border)]', 'text-[var(--color-text-muted)]');
      });
      btn.classList.remove('border-[var(--color-border)]', 'text-[var(--color-text-muted)]');
      btn.classList.add('active', 'text-[var(--color-bg)]');

      movePillTo(btn);

      posts.forEach(post => {
        if (category === 'all' || post.dataset.category === category) {
          post.style.display = '';
        } else {
          post.style.display = 'none';
        }
      });

      updateEmptyState();
    });
  });
</script>
